-- GOAL: Router-mediated subagent spawning and dispatch.
-- Caller → route_prompt(prompt) → catalog lookup → domain classification → spawn.
-- Non-terminal agents can spawn children; terminal agents cannot.
-- SubagentConfig: MCP servers, allowed tools, system prompt (md_files), max_turns, budget.
-- Every tool call is hookable: langfuse trace, debug hooks, budget guard, QC sampling.
-- Utility agents available to all: researcher, context-engine, gritql.
-- Source: mcp-toolbelt/arch_diagrams/subagent_lifecycle

use std/agent
use std/json
use std/fs
use std/re

Protocol SubagentConfig = {
  name: Str
  command: Str
  args: List
  terminal: Bool
  max_turns: Int
}

Protocol RouteResult = {domain: Str  confidence: Float  terminal: Bool}

catalog = [
  {name: "researcher"      domain: "research"      terminal: true}
  {name: "context-engine"  domain: "codebase"      terminal: true}
  {name: "gritql"          domain: "ast-search"    terminal: true}
  {name: "agent-auditor"   domain: "security"      terminal: false}
  {name: "research-analyst" domain: "research"     terminal: false}
  {name: "perf-analyzer"   domain: "performance"   terminal: false}
  {name: "project-setup"   domain: "scaffolding"   terminal: false}
]

+main = () {
  prompt = "analyze the rate limiting in our API handlers"
  route = route_prompt prompt
  $echo "routed to: {route.domain} (confidence: {route.confidence})"

  agent_def = catalog | find (a) a.domain == route.domain
  agent_def ? {
    Some def -> {
      config = SubagentConfig {
        name: def.name
        command: "lx"
        args: ["run" "agents/{def.name}.lx"]
        terminal: def.terminal
        max_turns: 30
      }
      result = dispatch config prompt
      $echo "result: {result}"
    }
    None -> $echo "no specialist for domain '{route.domain}', handling directly"
  }
}

route_prompt = (prompt) {
  keywords = %{
    "research": ["research" "compare" "investigate" "how do others"]
    "codebase": ["our code" "codebase" "find where" "grep" "search"]
    "security": ["audit" "injection" "stuck" "suspicious"]
    "performance": ["slow" "latency" "perf" "benchmark" "rate limit"]
    "scaffolding": ["new service" "setup" "scaffold" "create project"]
  }

  scores = keywords | entries | map (domain, words) {
    score = words | filter (w) re.is_match w (lower prompt) | len
    {domain: domain  score: score}
  }

  best = scores | sort_by (.score) | rev | first
  best ? {
    Some b -> RouteResult {
      domain: b.domain
      confidence: b.score > 2 ? 0.9 : (b.score > 0 ? 0.6 : 0.1)
      terminal: catalog | find (a) a.domain == b.domain
        | (x) x ? { Some a -> a.terminal; None -> true }
    }
    None -> RouteResult {domain: "general" confidence: 0.1 terminal: true}
  }
}

dispatch = (config prompt) {
  subagent = agent.spawn {command: config.command args: config.args} ^
  result = subagent ~>? {task: prompt max_turns: config.max_turns} ^
  agent.kill subagent ^
  result
}

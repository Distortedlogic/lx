-- lib_math.lx
-- Exported math utilities for module import tests

+add = (x y) x + y
+mul = (x y) x * y
+square = (x) x * x

+clamp_to = (lo hi x) {
  x < lo ? lo : (x > hi ? hi : x)
}

helper = (x) x * 2
+doubled_square = (x) helper (square x)

+Point = {x: Float  y: Float}

+origin = {x: 0.0  y: 0.0}

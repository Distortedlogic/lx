-- 20_http.lx
-- Tests: std/http module (GET, POST, PUT, DELETE)
-- Requires: python3 for test HTTP server fixture

use std/http
use std/fs

-- Clean up stale files
$rm -f /tmp/lx_http_test_port /tmp/lx_http_test_pid

-- Start HTTP test server in background
${
  python3 tests/fixtures/http_test_server.py >/dev/null 2>&1 &
}

-- Wait for server to write port file
${
  while [ ! -s /tmp/lx_http_test_port ]; do sleep 0.05; done
}

-- Read port
port = fs.read "/tmp/lx_http_test_port" ^ | trim
base = "http://127.0.0.1:{port}"

-- GET JSON endpoint
resp = http.get "{base}/json" ^
assert (resp.status == 200) "http get json status"
assert (resp.body.message == "hello") "http get json body field"
assert (resp.body.count == 42) "http get json body number"

-- GET text endpoint (non-JSON body returned as Str)
resp2 = http.get "{base}/text" ^
assert (resp2.status == 200) "http get text status"
assert (resp2.body == "plain text response") "http get text body"

-- GET non-200 status
resp3 = http.get "{base}/status/404" ^
assert (resp3.status == 404) "http get 404 status"
assert (resp3.body.error == "not found") "http get 404 body"

-- GET with custom headers via record
resp4 = http.get {url: "{base}/echo-headers"  headers: {xtest: "foo"  xauth: "bar"}} ^
assert (resp4.body.xtest == "foo") "http get custom header xtest"
assert (resp4.body.xauth == "bar") "http get custom header xauth"

-- POST with JSON body
resp5 = http.post "{base}/data" {name: "lx"  version: 1} ^
assert (resp5.status == 200) "http post status"
assert (resp5.body.method == "POST") "http post method"
assert (resp5.body.received.name == "lx") "http post body received"

-- PUT with JSON body
resp6 = http.put "{base}/data" {updated: true} ^
assert (resp6.status == 200) "http put status"
assert (resp6.body.method == "PUT") "http put method"
assert (resp6.body.received.updated == true) "http put body received"

-- DELETE
resp7 = http.delete "{base}/resource" ^
assert (resp7.status == 200) "http delete status"
assert (resp7.body.method == "DELETE") "http delete method"

-- Cleanup: kill server
http_pid = fs.read "/tmp/lx_http_test_pid" ^ | trim
$kill {http_pid}
$rm -f /tmp/lx_http_test_port /tmp/lx_http_test_pid
()

use pkg/core/adapter {adapter  coerce}
mk_adapter = adapter
use pkg/core/negotiate_fmt {negotiate_format}

Trait ReviewOutput = {score: Float  label: Str  details: Str}
Trait AnalysisInput = {confidence: Float  category: Str  context: Str}

-- adapter: static field mapping
adapt1 = mk_adapter ReviewOutput AnalysisInput {
  score: "confidence"
  label: "category"
  details: "context"
}

msg = ReviewOutput {score: 0.9  label: "good"  details: "looks fine"}
transformed = adapt1 msg
assert (transformed.confidence == 0.9) "maps score -> confidence"
assert (transformed.category == "good") "maps label -> category"
assert (transformed.context == "looks fine") "maps details -> context"

-- adapter: pass-through unmapped fields
Trait Source = {a: Str  b: Str  c: Str}
Trait Target = {x: Str  b: Str  c: Str}
adapt2 = mk_adapter Source Target {a: "x"}
msg2 = Source {a: "alpha"  b: "beta"  c: "gamma"}
t2 = adapt2 msg2
assert (t2.x == "alpha") "maps a -> x"
assert (t2.b == "beta") "b passes through"
assert (t2.c == "gamma") "c passes through"

-- adapter: partial mapping
Trait Small = {x: Str}
Trait Big = {a: Str  b: Str}
adapt3 = mk_adapter Small Big {x: "a"}
result3 = adapt3 (Small {x: "hello"})
assert (result3.a == "hello") "partial mapping: x -> a"

-- coerce: one-shot transform
msg4 = {score: 0.75  label: "fair"  details: "ok"}
coerced = coerce msg4 AnalysisInput {
  score: "confidence"
  label: "category"
  details: "context"
}
inner = coerced ?? {x: "fail"}
assert (inner.confidence == 0.75) "coerces score -> confidence"
assert (inner.category == "fair") "coerces label -> category"
assert (inner.context == "ok") "coerces details -> context"

-- negotiate_format: test with plain records
rec_a = {task: "deploy"  priority: 5}
rec_b = {task: "build"  priority: 1}

neg1 = negotiate_format "test" rec_a rec_b
assert (neg1 ? { Ok _ -> true; _ -> false }) "record match succeeds"

emit "[INFO] 90_agent_adapter: all passed"

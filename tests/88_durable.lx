-- 88_durable.lx
-- Tests: pkg/infra/durable (checkpoint/resume workflows)

use pkg/infra/durable
use std/fs

wf = durable.workflow "test-durable-88" {storage_dir: ".lx/test-durable/"} (ctx) {
  a = durable.step ctx "fetch" () { {value: 42} }
  b = durable.step ctx "transform" () { {value: a.value + 1} }
  b
}

result = durable.run wf {:}
assert (result | ok?) "durable.run returns Ok"
data = result ^
assert (data.result.value == 43) "workflow produces correct result"

workflows = durable.list ()
assert (type_of workflows == "List") "list returns List"

$rm -rf .lx/test-durable/

log.info "88_durable: all passed"

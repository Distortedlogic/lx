-- gotcha probes: runtime traps from agent/GOTCHAS.md
-- type-error gotchas are in crates/lx-cli/tests/bug_probes.rs

use std/time
use std/cron
use std/agent {Agent}

-- tuple destructuring in HOF lambdas (this one works via lx run)
result = ["x"; "y"] | enumerate | map (i s) { "{i}:{s}" }
assert (result == ["0:x"; "1:y"]) "BUG-FIXED: tuple destructuring in HOF lambdas"

-- find no match returns None
list = [1; 2; 3; 4; 5]
no_match = list | find (x) { x > 100 }
assert (no_match == None) "find no match returns None"

-- cron.every exists
assert (type_of cron.every == "Func") "cron.every exists"

-- agent default tools/max_turns
Agent NoToolAgent = {
  role = () { "tester" }
  goal = () { "test" }
}
nta = NoToolAgent {}
assert (nta.tools () == []) "agent default tools is empty list"
assert (nta.max_turns () == 25) "agent default max_turns is 25"

-- agent custom tools/max_turns
Agent ToolAgent = {
  role = () { "tool user" }
  goal = () { "test" }
  tools = () { ["Bash"; "Read"] }
  max_turns = () { 10 }
}
ta = ToolAgent {}
assert (ta.tools () == ["Bash"; "Read"]) "agent custom tools"
assert (ta.max_turns () == 10) "agent custom max_turns"

emit "gotchas_runtime: all checks passed"

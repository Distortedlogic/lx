-- gotcha probes: runtime traps from agent/GOTCHAS.md
-- type-error gotchas are in crates/lx-cli/tests/bug_probes.rs

use std/time
use std/cron
use std/agent {Agent}

-- tuple destructuring in HOF lambdas (this one works via lx run)
result = ["x"; "y"] | enumerate | map (i s) { "{i}:{s}" }
assert (result == ["0:x"; "1:y"]) "BUG-FIXED: tuple destructuring in HOF lambdas"

-- find no match returns None
list = [1; 2; 3; 4; 5]
no_match = list | find (x) { x > 100 }
assert (no_match == None) "find no match returns None"

-- cron.every exists
assert (type_of cron.every == "Func") "cron.every exists"

-- agent default subscribes
Agent NoSubAgent = {}
nsa = NoSubAgent {}
assert (nsa.subscribes () == []) "agent default subscribes is empty list"

-- agent custom subscribes
Agent SubAgent = {
  subscribes = () { ["events"; "logs"] }
}
sa = SubAgent {}
assert (sa.subscribes () == ["events"; "logs"]) "agent custom subscribes"

emit "gotchas_runtime: all checks passed"

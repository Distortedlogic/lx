use std/agent
use pkg/agents/dialogue_persist {dialogue_save dialogue_load dialogue_list dialogue_delete}
use std/fs
use std/json

test_dir = ".lx/dialogues"

cleanup = () {
  exists = fs.exists test_dir
  exists ? {
    true -> fs.remove test_dir
    false -> ()
  }
}

cleanup ()

echo = (msg) msg

worker = {name: "echo" handler: echo}
session = agent.dialogue worker {role: "reviewer" context: "auth module"} ^
r1 = agent.dialogue_turn session "check error handling" ^
r2 = agent.dialogue_turn session "what about middleware?" ^

save_result = dialogue_save session "test-persist-01" ^
assert (save_result == ()) "save should return ()"

path = test_dir ++ "/test-persist-01.json"
exists = fs.exists path
assert (exists == true) "file should exist after save"

content = fs.read path ^
data = json.parse content ^
assert (data.id == "test-persist-01") "id should match"
assert (data.config.role == "reviewer") "role should persist"
assert (data.config.context == "auth module") "context should persist"
assert (len data.turns == 4) "should have 4 turn entries (2 user + 2 agent)"

first_turn = data.turns.0
assert (first_turn.direction == "outbound") "first turn should be outbound"

loaded = dialogue_load "test-persist-01" worker ^
r3 = agent.dialogue_turn loaded "any final concerns?" ^
assert (r3.content == "any final concerns?") "echo handler should return message with content"

history = agent.dialogue_history loaded
assert (len history == 6) "loaded session should have 6 entries (4 restored + 2 new)"

dialogue_save loaded "test-persist-02" ^
list_result = dialogue_list () ^
ids = list_result | map (.id) | sort
assert (len ids == 2) "should list 2 saved dialogues"
assert (ids.0 == "test-persist-01") "first id"
assert (ids.1 == "test-persist-02") "second id"

info = list_result.0
assert (info.turns > 0) "listed info should have turn count"
assert (info.role == "reviewer") "listed info should have role"

del_result = dialogue_delete "test-persist-01" ^
assert (del_result == ()) "delete should return ()"
gone = fs.exists path
assert (gone == false) "file should be gone after delete"

del_missing = dialogue_delete "nonexistent"
assert (del_missing ? {Err _ -> true; _ -> false}) "delete nonexistent should return Err"

load_missing = dialogue_load "nonexistent" worker
assert (load_missing ? {Err _ -> true; _ -> false}) "load nonexistent should return Err"

agent.dialogue_end loaded
agent.dialogue_end session

cleanup ()

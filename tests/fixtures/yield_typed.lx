use std/yield {YieldApproval YieldReflection YieldInformation}

plan = yield YieldApproval {
  action: "deploy"
  details: {env: "staging"  risk: "low"}
}
assert (plan.approved == true)

guidance = yield YieldReflection {
  task: "analyze"
  attempt: {score: 15}
  question: "What should I change?"
}
assert (guidance.guidance == "try harder")

data = yield YieldInformation {
  query: "API key for service X"
}
assert (data.answer == "secret123")

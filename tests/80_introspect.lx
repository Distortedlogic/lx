use std/introspect

-- system returns Ok with structured snapshot
snapshot = introspect.system () ^
assert (type_of snapshot.agents == "List") "system has agents list"
assert (type_of snapshot.messages_in_flight == "Int") "system has messages_in_flight"
assert (type_of snapshot.topics == "List") "system has topics list"
assert (type_of snapshot.supervisors == "List") "system has supervisors list"

-- agents returns Ok with list
agents = introspect.agents () ^
assert (type_of agents == "List") "agents returns list"

-- messages returns Ok with list
msgs = introspect.messages () ^
assert (type_of msgs == "List") "messages returns list"

-- bottleneck returns None when no agents running
bn = introspect.bottleneck ()
assert (bn == None) "bottleneck is None with no agents"

-- agent with invalid record returns Err
bad = introspect.agent {__pid: 99999}
bad ? {
  Err _ -> assert true "agent with bad pid returns Err"
  _ -> assert false "expected Err for bad pid"
}

-- system snapshot has empty agents when none spawned
assert (len snapshot.agents == 0) "no agents in fresh snapshot"
assert (snapshot.messages_in_flight == 0) "no messages in flight"

-- verify topics show up after creating one
use std/agent
agent.topic "test_introspect_topic"
snapshot2 = introspect.system () ^
found = snapshot2.topics | filter (t) t.name == "test_introspect_topic"
assert (len found == 1) "topic appears in snapshot"
assert (found | first ^ | (.subscribers)) == 0 "topic has 0 subscribers"

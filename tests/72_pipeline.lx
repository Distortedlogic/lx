-- 72_pipeline.lx
-- Tests: pkg/infra/pipeline (stage caching with JSON persistence)

use pkg/infra/pipeline
use std/fs

pipe = pipeline.create "test-pipe-72" {storage: ".lx/test-pipelines/"}

r1 = pipeline.stage pipe "step1" {x: 1} (input) {
  {result: input.x + 10}
}
assert (r1.result == 11) "stage executes body"

r2 = pipeline.stage pipe "step1" {x: 1} (input) {
  {result: 999}
}
assert (r2.result == 11) "stage returns cached on same input"

r3 = pipeline.stage pipe "step1" {x: 2} (input) {
  {result: input.x + 10}
}
assert (r3.result == 12) "stage re-executes on different input"

st = pipeline.status pipe
assert (st.name == "test-pipe-72") "status has name"

pipeline.clean pipe

$rm -rf .lx/test-pipelines/

log.info "72_pipeline: all passed"

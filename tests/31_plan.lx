-- 31_plan.lx
-- Tests: std/plan module (dynamic plan execution with revision)

use std/plan

-- helpers
id_exec = (step ctx) step.id
act_exec = (step ctx) step.action
continue_h = (step result state) plan.continue

-- === Basic execution ===

steps = [
  {id: "a" action: "first" depends: []}
  {id: "b" action: "second" depends: ["a"]}
  {id: "c" action: "third" depends: ["b"]}
]

exec = (step ctx) "done: {step.action}"
results = plan.run steps exec continue_h ^

assert (len results == 3) "basic: all steps executed"
assert (results.0.id == "a") "basic: order correct"
assert (results.0.result == "done: first") "basic: result correct"
assert (results.2.id == "c") "basic: last step"

-- === Dependency ordering ===

par_steps = [
  {id: "c" action: "third" depends: ["a" "b"]}
  {id: "a" action: "first" depends: []}
  {id: "b" action: "second" depends: []}
]

par_results = plan.run par_steps id_exec continue_h ^
assert (len par_results == 3) "deps: all executed"
assert (par_results.2.id == "c") "deps: c runs last"

-- === Abort ===

abort_h = (step result state) {
  step.id == "b" ? {
    true -> plan.abort "stop at b"
    false -> plan.continue
  }
}
abort_result = plan.run steps id_exec abort_h
assert (err? abort_result == true) "abort: returns Err"

-- === Replan ===

replan_h = (step result state) {
  step.id == "a" ? {
    true -> plan.replan [
      {id: "x" action: "replaced" depends: []}
      {id: "y" action: "also replaced" depends: ["x"]}
    ]
    false -> plan.continue
  }
}
replan_results = plan.run steps act_exec replan_h ^
assert (len replan_results == 3) "replan: a + 2 replacement steps"
assert (replan_results.1.id == "x") "replan: first replacement"
assert (replan_results.2.id == "y") "replan: second replacement"

-- === Insert after ===

insert_h = (step result state) {
  step.id == "a" ? {
    true -> plan.insert_after "a" [
      {id: "a2" action: "inserted" depends: ["a"]}
    ]
    false -> plan.continue
  }
}
insert_results = plan.run steps act_exec insert_h ^
assert (len insert_results == 4) "insert: original + 1 inserted"
insert_ids = insert_results | map (.id)
assert (contains? "a2" insert_ids == true) "insert: inserted step present"

-- === Context passing ===

ctx_exec = (step ctx) {
  step.id == "a" ? {
    true -> 42
    false -> ctx.completed.0.result * 2
  }
}
ctx_results = plan.run steps ctx_exec continue_h ^
assert (ctx_results.1.result == 84) "context: prev result accessible"

-- === Skip ===

skip_h = (step result state) {
  step.id == "a" ? {
    true -> plan.skip
    false -> plan.continue
  }
}
skip_steps = [
  {id: "a" action: "first" depends: []}
  {id: "b" action: "skipped" depends: ["a"]}
  {id: "c" action: "also skipped" depends: ["b"]}
]
skip_results = plan.run skip_steps act_exec skip_h ^
assert (len skip_results == 1) "skip: only first step executed"

log.info "31_plan: all passed"

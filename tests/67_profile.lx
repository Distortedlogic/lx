-- 67_profile.lx
-- Tests: pkg/data/profile (persistent agent identity)

use pkg/data/profile

p = profile.load {name: "test-agent-67" create: true}
assert (p.name == "test-agent-67") "load creates profile with correct name"

profile.learn p "parsing" {technique: "split on ---" confidence: 0.9}
r1 = profile.recall p "parsing"
assert (r1 != None) "recall returns Some for known domain"

profile.learn p "parsing" {technique: "regex first" confidence: 0.95}
r2 = profile.recall p "parsing"
data = r2 ?? {:}
assert (data.technique == "regex first") "learn overwrites previous"

r3 = profile.recall p "nonexistent"
assert (r3 == None) "recall returns None for unknown domain"

profile.preference p "style" "concise"
pref = profile.get_preference p "style"
assert (pref == "concise") "preference roundtrip"

profile.forget p "parsing"
r4 = profile.recall p "parsing"
assert (r4 == None) "forget removes domain"

profile.save p
p2 = profile.load "test-agent-67"
assert (p2.name == "test-agent-67") "reload by name"

$rm -rf .lx/profiles/test-agent-67.json

log.info "67_profile: all passed"

-- 49_agent_capability.lx
-- Tests: spec/agents-capability.md (Capabilities Trait + capabilities + advertise)
-- Phase: capabilities, advertise, Capabilities Trait

use std/agent
use pkg/core/capability {Capabilities capabilities advertise}

-- Capabilities Trait validates and fills defaults
caps = Capabilities {
  traits: ["ReviewRequest" "AuditRequest"]
  tools: ["read_file" "grep"]
  domains: ["rust" "security"]
}
assert (caps.traits | len == 2) "caps traits populated"
assert (caps.tools | len == 2) "caps tools populated"
assert (caps.domains | len == 2) "caps domains populated"
assert (caps.budget_remaining == -1) "caps budget_remaining defaults to -1"
assert (caps.accepts == []) "caps accepts defaults to empty"
assert (caps.status == "ready") "caps status defaults to ready"

-- Capabilities with explicit optional fields
caps2 = Capabilities {
  traits: []
  tools: ["search"]
  domains: ["general"]
  budget_remaining: 5000
  accepts: ["review" "audit"]
  status: "busy"
}
assert (caps2.budget_remaining == 5000) "caps explicit budget"
assert (caps2.status == "busy") "caps explicit status"
assert (caps2.accepts | len == 2) "caps explicit accepts"

-- capabilities queries an agent handler
cap_agent = {handler: (msg) {
  msg.type ? {
    "capabilities" -> Capabilities {
      traits: ["ReviewRequest"]
      tools: ["grep" "read_file"]
      domains: ["rust"]
      status: "ready"
    }
    _ -> {echo: msg}
  }
}}
result = capabilities cap_agent ^
assert (result.traits == ["ReviewRequest"]) "capabilities query returns traits"
assert (result.tools | len == 2) "capabilities query returns tools"
assert (result.status == "ready") "capabilities query returns status"

-- advertise stores capabilities
advertise "test_worker" caps ^
assert true "advertise succeeds"

-- capabilities-based routing pattern
workers = [
  {name: "rust_expert" handler: (msg) {
    msg.type ? {
      "capabilities" -> Capabilities {traits: [] tools: [] domains: ["rust"]}
      _ -> {result: "rust handled"}
    }
  }}
  {name: "go_expert" handler: (msg) {
    msg.type ? {
      "capabilities" -> Capabilities {traits: [] tools: [] domains: ["go"]}
      _ -> {result: "go handled"}
    }
  }}
]
candidates = workers | filter (w) {
  c = capabilities w ^
  c.domains | any? (== "rust")
}
assert (candidates | len == 1) "capability filter finds rust expert"
assert (candidates.0.name == "rust_expert") "capability filter correct agent"

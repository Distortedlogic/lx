-- 13_concurrency.lx
-- Tests: spec/concurrency.md (par, sel, pmap, structured concurrency)
-- Phase: 8 (Concurrency)

-- par block: run expressions concurrently, collect as tuple
(a b c) = par {
  1 + 1
  2 + 2
  3 + 3
}
assert (a == 2)
assert (b == 4)
assert (c == 6)

-- par with function calls
double = (x) x * 2
square = (x) x * x

(d s) = par {
  double 5
  square 5
}
assert (d == 10)
assert (s == 25)

-- par preserves order regardless of completion time
(x y z) = par {
  [1 2 3] | sum
  [4 5 6] | sum
  [7 8 9] | sum
}
assert (x == 6)
assert (y == 15)
assert (z == 24)

-- pmap: parallel map, preserves input order
xs = [1 2 3 4 5]
doubled = xs | pmap (* 2)
assert (doubled == [2 4 6 8 10])

-- pmap with named function
inc = (x) x + 1
result = [10 20 30] | pmap inc
assert (result == [11 21 31])

-- pmap on empty list
assert ([] | pmap (* 2) == [])

-- pmap with block body
processed = [1 2 3 4] | pmap (x) {
  tmp = x * x
  tmp + 1
}
assert (processed == [2 5 10 17])

-- pmap_n: rate-limited parallel map
results = [1 2 3 4 5 6 7 8] | pmap_n 2 (* 3)
assert (results == [3 6 9 12 15 18 21 24])

-- pmap_n with limit 1 (effectively sequential)
seq_results = [10 20 30] | pmap_n 1 (+ 5)
assert (seq_results == [15 25 35])

-- pmap_n preserves order
ordered = [5 4 3 2 1] | pmap_n 3 identity
assert (ordered == [5 4 3 2 1])

-- sel block: race, first to complete wins
winner = sel {
  42       -> it
  timeout 5 -> Err "slow"
}
assert (winner == 42)

-- sel with timeout pattern (instant value beats timeout)
fast_result = sel {
  "fast"     -> it
  timeout 5  -> Err "timed out"
}
assert (fast_result == "fast")

-- sel with it binding and transformation
transformed = sel {
  10         -> it * 2
  timeout 5  -> 0
}
assert (transformed == 20)

-- sel where handler processes result
val = sel {
  [1 2 3]   -> it | sum
  timeout 1 -> 0
}
assert (val == 6)

-- par error propagation: first error (via ^) cancels siblings
safe_div = (a b) b ? {
  0 -> Err "div by zero"
  _ -> Ok (a / b)
}

par_fail = () {
  par {
    safe_div 10 2 ^
    safe_div 5 0 ^
  }
}
assert (err? (par_fail ()))
assert (par_fail () == Err "div by zero")

-- par without ^ returns values as-is (no cancellation)
(r1 r2) = par {
  safe_div 10 2
  safe_div 5 0
}
assert (r1 == Ok 5.0)
assert (r2 == Err "div by zero")

-- pmap without ^ collects individual Results (no cancellation)
divide_by = (x) x ? {
  0 -> Err "zero"
  n -> Ok (100 / n)
}
mixed = [2 0 5] | pmap divide_by
assert (mixed.0 == Ok 50.0)
assert (mixed.1 == Err "zero")
assert (mixed.2 == Ok 20.0)

-- concurrent code with immutable captures (allowed)
base = 100
captured_results = [1 2 3] | pmap (x) x + base
assert (captured_results == [101 102 103])

name = "hello"
greetings = ["alice" "bob"] | pmap (who) "{name} {who}"
assert (greetings == ["hello alice" "hello bob"])

-- local mutable bindings inside concurrent bodies (allowed)
sums = [1 2 3] | pmap (x) {
  acc := 0
  acc <- acc + x
  acc <- acc + x
  acc
}
assert (sums == [2 4 6])

-- local mutation in par (allowed)
(a2 b2) = par {
  { tmp := 10; tmp <- tmp + 5; tmp }
  { tmp := 20; tmp <- tmp * 2; tmp }
}
assert (a2 == 15)
assert (b2 == 40)

-- mutable capture restriction:
-- capturing a mutable binding (:=) inside par/sel/pmap is a compile error
-- e.g. `count := 0; xs | pmap (x) { count <- count + 1; x }` fails
-- (not testable at runtime, static check only)

-- nested par
((p, q) (r2, s2)) = par {
  par { 1 + 1; 2 + 2 }
  par { 3 + 3; 4 + 4 }
}
assert (p == 2)
assert (q == 4)
assert (r2 == 6)
assert (s2 == 8)

-- pmap pipeline
final = [1 2 3 4 5]
  | pmap (* 2)
  | pmap (+ 1)
  | sum
assert (final == 35)

-- par collecting heterogeneous results
record = par {
  1 + 2
  "hello"
  true
}
(rv1 rv2 rv3) = record
assert (rv1 == 3)
assert (rv2 == "hello")
assert (rv3 == true)

-- fan-out/fan-in pattern
raw = [10 20 30 40 50] | pmap (* 2)
assert (raw | filter (> 30) == [40 60 80 100])

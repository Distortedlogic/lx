-- refine expression: iterative feedback loop

grade_simple = (w) {score: w feedback: "none"}
revise_add10 = (w feedback) w + 10

-- basic refine: work already meets threshold
r1 = refine 100 {
  grade: grade_simple
  revise: revise_add10
  threshold: 50
  max_rounds: 3
}
assert (r1 == Ok {work: 100 rounds: 0 final_score: 100})

-- refine that needs revision rounds to pass
grade_low = (w) {score: w feedback: "too low"}
revise_add30 = (w feedback) w + 30

r2 = refine 10 {
  grade: grade_low
  revise: revise_add30
  threshold: 50
  max_rounds: 5
}
r2_inner = r2 ^
assert (r2_inner.work >= 50) "work should meet threshold"
assert (r2_inner.rounds >= 1) "should take at least 1 round"

-- refine that exhausts max_rounds returns Err
revise_add1 = (w feedback) w + 1

r3 = refine 0 {
  grade: grade_low
  revise: revise_add1
  threshold: 100
  max_rounds: 3
}
is_err = r3 ? {
  Ok _ -> false
  Err _ -> true
}
assert (is_err == true) "exhausted max_rounds should return Err"

-- Err result contains reason
r3_err = r3 ? {
  Ok v -> v
  Err v -> v
}
assert (r3_err.reason == "max_rounds")

-- refine with on_round callback
rounds_seen := 0
r4 = refine 0 {
  grade: grade_low
  revise: (w feedback) w + 50
  threshold: 80
  max_rounds: 5
  on_round: (round work score) {
    rounds_seen <- rounds_seen + 1
  }
}
r4_inner = r4 ^
assert (r4_inner.work >= 80) "should meet threshold"
assert (rounds_seen >= 1) "on_round should have been called"

-- refine with string work
grade_len = (w) {score: (len w) * 10 feedback: "add more"}

r5 = refine "draft" {
  grade: grade_len
  revise: (w feedback) w ++ " revised"
  threshold: 80
  max_rounds: 5
}
r5_inner = r5 ^
assert ((len r5_inner.work) > (len "draft")) "work should grow"

-- refine composes with ^ propagation
get_work = () {
  result = refine 60 {
    grade: grade_simple
    revise: revise_add10
    threshold: 50
    max_rounds: 1
  } ^
  result.work
}
assert ((get_work ()) == 60)

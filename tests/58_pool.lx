-- std/pool: agent worker pools

use pkg/pool {Pool}

-- create pool with handler
p = Pool {
  name: "workers"
  size: 3
  handler: (msg) {
    {result: "processed-{msg.task}" source: msg.path}
  }
}

assert (p.name == "workers")
assert (p.size == 3)

-- fan_out: distribute tasks and collect results
tasks = [
  {task: "review" path: "src/auth"}
  {task: "review" path: "src/api"}
  {task: "review" path: "src/db"}
]
results = p.fan_out tasks ^
assert (len results == 3)

r0 = results.[0] ?? {result: "none"}
assert (r0.result == "processed-review")
assert (r0.source == "src/auth")

-- status tracking
status = p.status ()
assert (status.size == 3)
assert (status.completed == 3)
assert (status.failed == 0)

-- submit: fire-and-forget
p.submit {task: "index" path: "data"} ^
status2 = p.status ()
assert (status2.completed == 4)

-- map: transform items through pool
items = ["a" "b" "c"]
mapped = p.map_tasks items (item) {task: "analyze" path: item} ^
assert (len mapped == 3)

m0 = mapped.[0] ?? {result: "none"}
assert (m0.result == "processed-analyze")
assert (m0.source == "a")

-- pool with trait constraint
Protocol ReviewRequest = {task: Str  path: Str}
Trait Reviewer = {
  review: ReviewRequest -> Str
}

tp = Pool {
  name: "reviewers"
  size: 2
  handler: (msg) {result: "reviewed"}
}
assert (tp.name == "reviewers")

-- shutdown
p.shutdown () ^

-- pool handles errors gracefully
err_pool = Pool {
  name: "err-workers"
  size: 1
  handler: (msg) {
    msg.task == "fail" ? Err "deliberate failure" : {ok: true}
  }
}

err_results = err_pool.fan_out [{task: "ok"} {task: "fail"}] ^
assert (len err_results == 2)

err_pool.shutdown () ^

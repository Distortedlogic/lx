-- 70_describe.lx
-- Tests: std/describe module (program structure extraction)

use std/describe

-- === extract basic program ===
src1 = `
use std/agent
+main = (x) x + 1
y = 42
`
desc1 = describe.extract src1
assert (len desc1.imports >= 1) "found imports"
imp = desc1.imports.0
assert (imp.path == "std/agent") "import path is std/agent"
assert (len desc1.exports >= 1) "found exports"

-- === extract with agents ===
src2 = `
use std/agent
worker = agent.spawn {command: "analyzer"} ^
result = worker ~>? {action: "analyze"} ^
worker ~> {action: "done"}
`
desc2 = describe.extract src2
assert (len desc2.agents >= 1) "found spawned agent"
a = desc2.agents.0
assert (a.name == "analyzer") "agent name is analyzer"
assert (a.declared == false) "agent is spawned not declared"
assert (len desc2.messages >= 2) "found messages"
ask_msgs = desc2.messages | filter (m) m.style == "ask"
send_msgs = desc2.messages | filter (m) m.style == "send"
assert (len ask_msgs >= 1) "found ask message"
assert (len send_msgs >= 1) "found send message"

-- === extract with control flow ===
src3 = `
par {
  a = 1
  b = 2
}
x = 1
x ? {
  1 -> "one"
  _ -> "other"
}
loop {
  break 1
}
`
desc3 = describe.extract src3
assert (len desc3.control_flow >= 3) "found control flow entries"
kinds = desc3.control_flow | map (c) c.kind
assert (kinds | contains? "par") "found par"
assert (kinds | contains? "match") "found match"
assert (kinds | contains? "loop") "found loop"

-- === extract with agent declaration ===
src4 = `
Trait Greetable = {
  greet: {name: Str} -> Str
}
Agent Greeter: Greetable = {
  greet = (msg) "hello"
}
`
desc4 = describe.extract src4
assert (len desc4.agents >= 1) "found declared agent"
ag = desc4.agents.0
assert (ag.name == "Greeter") "agent name is Greeter"
assert (ag.declared == true) "agent is declared"
assert (len ag.traits >= 1) "agent has traits"
assert (ag.traits.0 == "Greetable") "trait is Greetable"
assert (len ag.methods >= 1) "agent has methods"
assert (ag.methods.0 == "greet") "method is greet"

-- === render produces text ===
text = describe.render desc2
assert (len text > 0) "render produces non-empty text"
assert (text | contains? "Agents:") "render contains Agents:"
assert (text | contains? "Message Flow:") "render contains Message Flow:"
assert (text | contains? "Imports:") "render contains Imports:"

-- === extract_file ===
use std/fs
tmp = "/tmp/lx_describe_test.lx"
fs.write tmp `use std/agent
worker = agent.spawn {command: "test_agent"} ^` ^
desc5 = describe.extract_file tmp
assert (len desc5.agents >= 1) "extract_file found agents"
fs.remove tmp ^

log.info "70_describe: all passed"

-- 59_budget.lx
-- Tests: std/budget module (resource cost tracking and projection)

use pkg/core/budget

-- === Create budget ===
b = budget.create {tokens: 50000 api_calls: 20}
assert (budget.status b == "comfortable") "initial status comfortable"

-- === Check initial state ===
rem = budget.remaining b
assert (rem.tokens == 50000.0) "initial tokens remaining"
assert (rem.api_calls == 20.0) "initial api_calls remaining"

used = budget.used b
assert (used.tokens == 0.0) "initial tokens used"
assert (used.api_calls == 0.0) "initial api_calls used"

pct = budget.used_pct b
assert (pct.tokens == 0.0) "initial tokens pct"
assert (pct.api_calls == 0.0) "initial api_calls pct"

-- === Spend ===
budget.spend b {tokens: 12000 api_calls: 1} ^
rem2 = budget.remaining b
assert (rem2.tokens == 38000.0) "after spend tokens"
assert (rem2.api_calls == 19.0) "after spend api_calls"

used2 = budget.used b
assert (used2.tokens == 12000.0) "used tokens"
assert (used2.api_calls == 1.0) "used api_calls"

pct2 = budget.used_pct b
assert (pct2.tokens == 24.0) "used pct tokens"
assert (pct2.api_calls == 5.0) "used pct api_calls"

-- === Status transitions ===
budget.spend b {tokens: 14000} ^
assert (budget.status b == "tight") "tight at 52% tokens (>= 50% threshold)"

b2 = budget.create {tokens: 100}
budget.spend b2 {tokens: 55} ^
assert (budget.status b2 == "tight") "tight at 55%"

budget.spend b2 {tokens: 30} ^
assert (budget.status b2 == "critical") "critical at 85%"

budget.spend b2 {tokens: 20}
assert (budget.status b2 == "exceeded") "exceeded at 105%"

-- === Custom thresholds ===
b3 = budget.create {tokens: 100 tight_at: 30 critical_at: 70}
budget.spend b3 {tokens: 35} ^
assert (budget.status b3 == "tight") "custom tight threshold"
budget.spend b3 {tokens: 40} ^
assert (budget.status b3 == "critical") "custom critical threshold"

-- === Projection ===
b4 = budget.create {tokens: 50000 api_calls: 20}
budget.spend b4 {tokens: 12000 api_calls: 5} ^
proj = budget.project b4 {remaining_steps: 4}
assert (proj.projected_total.tokens == 60000.0) "projected tokens"
assert (proj.projected_total.api_calls == 25.0) "projected api_calls"
assert (len proj.will_exceed == 2) "both dimensions will exceed"
assert (proj.headroom.tokens == -10000.0) "headroom tokens"
assert (proj.headroom.api_calls == -5.0) "headroom api_calls"

-- === Projection with headroom ===
b5 = budget.create {tokens: 100000}
budget.spend b5 {tokens: 5000} ^
proj2 = budget.project b5 {remaining_steps: 4}
assert (proj2.projected_total.tokens == 25000.0) "conservative projection"
assert (len proj2.will_exceed == 0) "nothing exceeded"
assert (proj2.headroom.tokens == 75000.0) "plenty of headroom"

-- === Sub-budgets ===
parent = budget.create {tokens: 50000 api_calls: 20}
child = budget.slice parent {tokens: 10000 api_calls: 5}

budget.spend child {tokens: 3000 api_calls: 1} ^

child_rem = budget.remaining child
assert (child_rem.tokens == 7000.0) "child tokens remaining"

parent_used = budget.used parent
assert (parent_used.tokens == 3000.0) "parent tracks child spend"
assert (parent_used.api_calls == 1.0) "parent tracks child api_calls"

-- === Spend returns Err on exceeded ===
small = budget.create {tokens: 100}
r1 = budget.spend small {tokens: 50}
assert (ok? r1 == true) "spend within budget is Ok"
r2 = budget.spend small {tokens: 60}
assert (err? r2 == true) "spend over budget is Err"

-- === Multiple dimensions ===
multi = budget.create {tokens: 1000 api_calls: 5 wall_time: 300}
budget.spend multi {tokens: 100 api_calls: 1} ^
rem_multi = budget.remaining multi
assert (rem_multi.tokens == 900.0) "multi dim tokens"
assert (rem_multi.api_calls == 4.0) "multi dim api_calls"

log.info "59_budget: all passed"

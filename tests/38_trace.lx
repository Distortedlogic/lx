-- 38_trace.lx
-- Tests: pkg/trace TraceStore class (trace collection, scoring, dataset export)

use pkg/trace {TraceStore}
use std/fs

export_path = "/tmp/lx_trace_export.jsonl"
fs.remove export_path ?? ()

-- create trace store
t = TraceStore ()

-- record spans
s1 = t.record {name: "search" input: "find auth bugs" output: "found 3 issues" tags: ["research"]} ^
s2 = t.record {name: "fix" input: "fix token refresh" output: "patched validate.rs" duration_ms: 5000 tags: ["coding"]} ^
s3 = t.record {name: "review" input: "review the fix" output: "looks good" score: 0.9 tags: ["review"]} ^

-- spans returns all
all = t.all ()
assert (len all == 3) "spans: 3 recorded"
assert (all.0.name == "search") "spans: first name"
assert (all.1.name == "fix") "spans: second name"

-- score a span
t.score s1 0.85 ^
after = t.all ()
scored_span = after.0
assert (scored_span.score == 0.85) "score: updated"

-- summary
sum = t.summary ()
assert (sum.total == 3) "summary: total"
assert (sum.scored == 2) "summary: scored count"
assert (sum.avg_score > 0.0) "summary: has avg score"

-- filter by name
by_name = t.query {name: "fix"}
assert (len by_name == 1) "filter: by name"
assert (by_name.0.name == "fix") "filter: correct name"

-- filter by tag
by_tag = t.query {tag: "research"}
assert (len by_tag == 1) "filter: by tag"
assert (by_tag.0.name == "search") "filter: correct tag match"

-- filter by min_score
by_score = t.query {min_score: 0.85}
assert (len by_score == 2) "filter: by min_score"

-- export as JSONL
count = t.export export_path ^
assert (count == 3) "export: 3 lines"
exported = fs.read export_path ^
assert (len exported > 0) "export: file has content"

-- cleanup
fs.remove export_path ^

log.info "38_trace: all passed"

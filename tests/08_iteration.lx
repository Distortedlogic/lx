-- 08_iteration.lx
-- Tests: spec/iteration.md (HOFs, ranges, lazy sequences, loop/break, iterator protocol)
-- Phase: 4 (Iteration + Lazy Sequences)

-- map
assert ([1 2 3] | map (* 2) == [2 4 6])
assert ([1 2 3] | map (x) { x * x } == [1 4 9])
assert ([] | map (* 2) == [])

-- filter
assert ([1 2 3 4 5] | filter (> 3) == [4 5])
assert ([1 2 3 4 5] | filter even? == [2 4])
assert ([1 2 3] | filter (> 10) == [])

-- fold
assert ([1 2 3] | fold 0 (+) == 6)
assert ([1 2 3 4] | fold 1 (*) == 24)
assert ([] | fold 0 (+) == 0)

-- flat_map
assert ([1 2 3] | flat_map (x) { [x x] } == [1 1 2 2 3 3])
assert ([[1 2] [3 4]] | flat_map identity == [1 2 3 4])

-- each (side effects)
total := 0
[1 2 3] | each (x) { total <- total + x }
assert (total == 6)

-- sum and product
assert ([1 2 3 4 5] | sum == 15)
assert ([1 2 3 4] | product == 24)
assert ([] | sum == 0)
assert ([] | product == 1)

-- sort and sort_by
assert ([3 1 2] | sort == [1 2 3])
assert (["b" "a" "c"] | sort == ["a" "b" "c"])

records = [{name: "bob"  age: 25} {name: "alice"  age: 30}]
sorted = records | sort_by (.name)
assert (sorted.0.name == "alice")
assert (sorted.1.name == "bob")

-- rev
assert ([1 2 3] | rev == [3 2 1])

-- take and drop
assert ([1 2 3 4 5] | take 3 == [1 2 3])
assert ([1 2 3 4 5] | drop 2 == [3 4 5])
assert ([1 2] | take 5 == [1 2])
assert ([] | drop 3 == [])

-- take_while and drop_while
assert ([1 2 3 4 5] | take_while (< 4) == [1 2 3])
assert ([1 2 3 4 5] | drop_while (< 4) == [4 5])

-- zip
assert (zip ["a" "b" "c"] [1 2 3] == [(1 "a") (2 "b") (3 "c")])

-- enumerate
assert ([10 20 30] | enumerate | collect == [(0 10) (1 20) (2 30)])

-- partition
(big small) = [1 5 2 8 3] | partition (> 3)
assert (big | sort == [5 8])
assert (small | sort == [1 2 3])

-- find
assert ([1 2 3 4] | find (> 2) == Some 3)
assert ([1 2 3] | find (> 10) == None)

-- find_index
assert ([10 20 30] | find_index (== 20) == Some 1)
assert ([10 20 30] | find_index (== 99) == None)

-- any? and all?
assert ([1 2 3] | any? (> 2) == true)
assert ([1 2 3] | any? (> 10) == false)
assert ([1 2 3] | all? (> 0) == true)
assert ([1 2 3] | all? (> 1) == false)

-- none? (collection predicate, 2-arg form)
assert (none? (> 10) [1 2 3] == true)
assert (none? even? [1 3 5] == true)
assert (none? even? [1 2 3] == false)

-- count
assert ([1 2 3 4 5] | count even? == 2)

-- uniq
assert ([1 1 2 2 3 3] | uniq == [1 2 3])
assert ([1 2 1 2] | uniq == [1 2 1 2])

-- flatten
assert ([[1 2] [3 4] [5]] | flatten == [1 2 3 4 5])
assert ([[] [1] []] | flatten == [1])

-- intersperse
assert ([1 2 3] | intersperse 0 == [1 0 2 0 3])

-- chunks
assert ([1 2 3 4 5] | chunks 2 == [[1 2] [3 4] [5]])

-- windows
assert ([1 2 3 4] | windows 2 == [[1 2] [2 3] [3 4]])

-- group_by
grouped = ["ant" "bear" "cat" "dog"] | group_by (s) s | len
assert (has_key? 3 grouped == true)
assert (has_key? 4 grouped == true)

-- min and max
assert ([3 1 2] | min == 1)
assert ([3 1 2] | max == 3)

-- step
assert (1..10 | step 2 | collect == [1 3 5 7 9])
assert (0..10 | step 3 | collect == [0 3 6 9])

-- ranges
assert (1..5 | collect == [1 2 3 4])
assert (1..=5 | collect == [1 2 3 4 5])
assert (0..3 | collect == [0 1 2])

-- ranges are ascending only
assert (10..1 | collect == [])

-- ranges with eager pipeline
result = 1..100
  | collect
  | filter even?
  | map (* 3)
  | take 5
assert (result == [6 12 18 24 30])

-- loop with break
result = loop {
  break 42
}
assert (result == 42)

-- loop accumulator
total = {
  sum := 0
  i := 1
  loop {
    i > 5 ? break sum
    sum <- sum + i
    i <- i + 1
  }
}
assert (total == 15)

-- scan
assert ([1 2 3] | scan 0 (+) == [0 1 3 6])

-- join
assert (["a" "b" "c"] | join ", " == "a, b, c")
assert ([] | join ", " == "")

-- string functions as iteration
assert ("hello" | chars == ["h" "e" "l" "l" "o"])
assert ("hello world" | lines == ["hello world"])
assert ("a\nb\nc" | lines == ["a" "b" "c"])
assert ("a,b,c" | split "," == ["a" "b" "c"])

-- collect materializes range
concrete = 1..5 | collect | map (* 2)
assert (concrete == [2 4 6 8])

-- enumerate with tuple auto-spread
items := []
["a" "b" "c"] | enumerate | each (i x) {
  items <- [..items "{i}:{x}"]
}
assert (items == ["0:a" "1:b" "2:c"])

-- entries with tuple auto-spread
m = %{"x": 1  "y": 2}
pairs := []
m | entries | sort_by (.0) | each (k v) {
  pairs <- [..pairs "{k}={v}"]
}
assert (pairs == ["x=1" "y=2"])

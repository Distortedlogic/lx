-- 33_agents_auditor.lx
-- Tests: std/agents/auditor module (quality gate with structural pre-filter)

use pkg/agents/auditor

-- === quick_audit (structural only, no LLM) ===

-- good output passes all structural checks
good = auditor.quick_audit {
  output: "Fixed the auth token refresh bug in validate.rs by checking expiry before renewal."
  task: "fix auth token refresh bug"
}
assert (good.passed == true) "quick_audit: good output passes"
assert (good.score == 100) "quick_audit: good score"
assert (len good.failed == 0) "quick_audit: no failures"

-- empty output fails
empty = auditor.quick_audit {
  output: ""
  task: "fix the bug"
}
assert (empty.passed == false) "quick_audit: empty fails"
assert (len empty.failed > 0) "quick_audit: has failures"

-- whitespace-only output fails
ws = auditor.quick_audit {
  output: "   \n  "
  task: "fix the bug"
}
assert (ws.passed == false) "quick_audit: whitespace fails"

-- refusal language fails
refusal = auditor.quick_audit {
  output: "I can't help with that request, I'm unable to modify code."
  task: "fix auth token"
}
assert (refusal.passed == false) "quick_audit: refusal fails"
found_refusal = refusal.failed | any? (== "refusal")
assert (found_refusal == true) "quick_audit: refusal category present"

-- excessive hedging fails (3+ hedging phrases)
hedging = auditor.quick_audit {
  output: "I think maybe this could possibly work, but I believe it might be the right approach perhaps."
  task: "fix the bug"
}
assert (hedging.passed == false) "quick_audit: excessive hedging fails"
found_hedging = hedging.failed | any? (== "excessive_hedging")
assert (found_hedging == true) "quick_audit: hedging category present"

-- mild hedging (1-2 phrases) passes
mild = auditor.quick_audit {
  output: "I think the fix should update the token refresh logic in validate.rs to check expiry."
  task: "fix token refresh"
}
assert (mild.passed == true) "quick_audit: mild hedging passes"

-- no task reference fails
no_ref = auditor.quick_audit {
  output: "Updated the README with new installation instructions for the Docker container."
  task: "fix auth token refresh bug"
}
assert (no_ref.passed == false) "quick_audit: no task reference fails"
found_no_ref = no_ref.failed | any? (== "no_task_reference")
assert (found_no_ref == true) "quick_audit: no_task_reference category present"

-- output that references task passes
refs = auditor.quick_audit {
  output: "The auth token refresh was broken because expiry check was missing. Fixed the refresh logic."
  task: "fix auth token refresh"
}
assert (refs.passed == true) "quick_audit: task reference passes"

-- result has correct structure
assert (good.categories | len > 0) "quick_audit: has categories"
cat = good.categories.0
assert (cat.name == "structure") "quick_audit: category name"
assert (cat.passed == true) "quick_audit: category passed"

-- === audit with structural failures (short-circuits before LLM) ===

-- empty output triggers structural short-circuit
empty_audit = auditor.audit {
  output: ""
  task: "fix the auth bug"
  context: "src/auth/token.rs has broken refresh"
}
assert (empty_audit.passed == false) "audit: empty short-circuits"
assert (empty_audit.score == 0) "audit: empty score 0"

-- refusal triggers structural short-circuit
refusal_audit = auditor.audit {
  output: "As an AI, I cannot help with that."
  task: "fix the bug"
  context: "some context"
}
assert (refusal_audit.passed == false) "audit: refusal short-circuits"

-- multiple structural failures
multi = auditor.audit {
  output: "I can't do this. I think maybe possibly I'm not sure. Perhaps I believe it might work."
  task: "implement database migration"
  context: "migrations/001.sql needs updating"
}
assert (multi.passed == false) "audit: multiple structural failures"
assert (len multi.failed >= 2) "audit: multiple failure categories"

-- context field is optional (defaults to empty)
no_ctx = auditor.quick_audit {
  output: "Fixed the auth token refresh by checking expiry timestamps."
  task: "fix auth token refresh"
}
assert (no_ctx.passed == true) "quick_audit: no context field ok"

-- rubric field is optional (defaults to empty list)
no_rubric = auditor.quick_audit {
  output: "Fixed the auth token refresh by checking expiry timestamps."
  task: "fix auth token refresh"
}
assert (no_rubric.passed == true) "quick_audit: no rubric field ok"

log.info "33_agents_auditor: all passed"

-- Trait declarations: agent behavioral contracts with typed methods

use std/agent
use std/trait

Protocol ReviewRequest = {task: Str  path: Str}
Protocol AuditRequest = {severity: Str  scope: Str}

-- basic trait with typed methods
Trait Reviewer = {
  review: {task: Str  path: Str} -> {findings: List  score: Float}
  summarize: {findings: List} -> Str
}

assert (Reviewer != ())

-- trait with requires and description
Trait SecureAgent = {
  description: "Agent with security capabilities"
  audit: {scope: Str} -> {report: Str}
  requires: [:ai :fs]
}

assert (SecureAgent != ())

-- trait.methods returns method signatures
methods = trait.methods Reviewer
assert (len methods == 2) "Reviewer has 2 methods"
first_method = methods.0
assert (first_method.name == "review") "first method is review"

-- trait.match finds methods by keyword
result = trait.match Reviewer "review"
assert (result != None) "trait.match found a method"
assert (result.method == "review") "matched review method"

-- trait.match returns None when no match
no_match = trait.match Reviewer "nonexistent"
assert (no_match == None) "no match returns None"

-- Agent with structural trait conformance
Agent Analyzer: Reviewer = {
  review = (msg) {findings: [] score: 1.0}
  summarize = (msg) "summary"
}
assert (Analyzer.review {task: "test" path: "."} == {findings: [] score: 1.0})
assert (Analyzer.summarize {findings: []} == "summary")

-- agent.implements with Value::Agent (structural check)
assert (agent.implements Analyzer Reviewer == true) "Agent implements Reviewer"
assert (agent.implements Analyzer SecureAgent == false) "Agent does not implement SecureAgent"

-- agent.implements with record (legacy __traits fallback for empty-method traits)
Trait EmptyTrait = {}
reviewer_rec = {
  name: "test-reviewer"
  __traits: ["EmptyTrait"]
  handler: (msg) msg
}
assert (agent.implements reviewer_rec EmptyTrait == true) "record with __traits matches empty trait"

-- agent with multiple traits
Trait Searchable = {
  search: {query: Str} -> Str
}
Agent FullAgent: [Reviewer Searchable] = {
  review = (msg) {findings: [] score: 0.5}
  summarize = (msg) "done"
  search = (msg) "found"
}
assert (agent.implements FullAgent Reviewer == true) "multi-trait: implements Reviewer"
assert (agent.implements FullAgent Searchable == true) "multi-trait: implements Searchable"

-- trait with tags
Trait Tagged = {
  tags: ["code" "review"]
  check: {path: Str} -> Str
}
assert (Tagged != ())

-- trait-based routing
agents = [Analyzer FullAgent]
reviewers = agents | filter (a) agent.implements a Reviewer
assert (len reviewers == 2) "both agents implement Reviewer"

-- trait.methods output shape
search_methods = trait.methods Searchable
assert (len search_methods == 1)
sm = search_methods.0
assert (sm.name == "search")
assert (len sm.input == 1) "search has 1 input field"
input_field = sm.input.0
assert (input_field.name == "query") "input field named query"
assert (input_field.type == "Str") "input field type is Str"

-- method with Protocol-named input type
Trait WithProto = {
  handle: ReviewRequest -> {ok: Bool}
}
proto_methods = trait.methods WithProto
assert (len proto_methods == 1)

log.info "57_trait: all passed"

-- Trait declarations: agent behavioral contracts

use std/agent

Protocol ReviewRequest = {task: Str  path: Str}
Protocol AuditRequest = {severity: Str  scope: Str}

-- basic trait declaration
Trait Reviewer = {
  handles: [ReviewRequest AuditRequest]
  provides: [summarize_findings]
}

assert (Reviewer != ())

-- trait with requires
Trait SecureAgent = {
  handles: [ReviewRequest]
  provides: [audit_report]
  requires: [:ai :fs]
}

assert (SecureAgent != ())

-- agent.implements with matching traits
reviewer = {
  name: "test-reviewer"
  __traits: ["Reviewer"]
  handler: (msg) msg
}
assert (agent.implements reviewer Reviewer == true)
assert (agent.implements reviewer SecureAgent == false)

-- agent with multiple traits
multi = {
  name: "multi-agent"
  __traits: ["Reviewer" "SecureAgent"]
  handler: (msg) msg
}
assert (agent.implements multi Reviewer == true)
assert (agent.implements multi SecureAgent == true)

-- agent without traits
plain = {name: "plain" handler: (msg) msg}
assert (agent.implements plain Reviewer == false)

-- trait composition: agent implements multiple
Trait Auditable = {handles: [AuditRequest]}
Trait Reviewable = {handles: [ReviewRequest]}

analyzer = {
  name: "analyzer"
  __traits: ["Auditable" "Reviewable"]
  handler: (msg) msg
}
assert (agent.implements analyzer Auditable == true)
assert (agent.implements analyzer Reviewable == true)

-- trait-based routing
agents = [
  {name: "a1" __traits: ["Reviewer"] handler: (msg) "reviewed"}
  {name: "a2" __traits: ["Auditable"] handler: (msg) "audited"}
  {name: "a3" __traits: [] handler: (msg) "nothing"}
]

reviewers = agents | filter (a) agent.implements a Reviewer
assert (len reviewers == 1)
found = (reviewers | first) ?? {name: "?"}
assert (found.name == "a1")

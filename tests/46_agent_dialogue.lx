-- 46_agent_dialogue.lx
-- Tests: spec/agents-dialogue.md (multi-turn agent dialogue)
-- Phase: agent.dialogue / agent.dialogue_turn / agent.dialogue_history / agent.dialogue_end

use std/agent

-- dialogue handler: echoes content with turn count from history
dialogue_handler = (msg) {
  turn_count = msg.history | len
  {response: msg.content ++ " (turn {turn_count})"}
}
echo_agent = {handler: dialogue_handler}

-- basic dialogue: create session, send turns, end
session = agent.dialogue echo_agent {role: "reviewer"} ^
r1 = agent.dialogue_turn session "look at auth" ^
assert (r1.response == "look at auth (turn 0)") "first turn has no history"

r2 = agent.dialogue_turn session "check payments too" ^
assert (r2.response == "check payments too (turn 2)") "second turn has 2 history entries"

r3 = agent.dialogue_turn session "propose unified approach" ^
assert (r3.response == "propose unified approach (turn 4)") "third turn has 4 history entries"

-- dialogue_history returns accumulated entries
history = agent.dialogue_history session
assert (history | len == 6) "history has 6 entries (3 user + 3 agent)"
assert (history.0.role == "user") "first entry is user"
assert (history.1.role == "agent") "second entry is agent"

-- dialogue_end closes session
end_result = agent.dialogue_end session ^
assert (end_result == ()) "dialogue_end returns unit"

-- max_turns enforcement
limited_agent = {handler: (msg) {echo: msg.content}}
s2 = agent.dialogue limited_agent {max_turns: 2} ^
agent.dialogue_turn s2 "turn 1" ^
agent.dialogue_turn s2 "turn 2" ^
exceeded = agent.dialogue_turn s2 "turn 3"
assert (exceeded == Err {exceeded: "max_turns"}) "max_turns returns Err when exceeded"
agent.dialogue_end s2

-- dialogue with context config
context_handler = (msg) {
  has_ctx = msg.context != ()
  has_role = msg.role != ()
  {has_context: has_ctx  has_role: has_role  content: msg.content}
}
ctx_agent = {handler: context_handler}
s3 = agent.dialogue ctx_agent {role: "analyst" context: "codebase summary"} ^
r = agent.dialogue_turn s3 "analyze this" ^
assert (r.has_context == true) "dialogue passes context to handler"
assert (r.has_role == true) "dialogue passes role to handler"
agent.dialogue_end s3

-- dialogue_end on already-ended session is no-op
s4 = agent.dialogue echo_agent {} ^
agent.dialogue_end s4
end2 = agent.dialogue_end s4
assert (end2 == Ok ()) "double end is ok"

-- dialogue with handler that uses accumulated context
accumulator = {handler: (msg) {turn_count: (msg.history | len) // 2}}
s5 = agent.dialogue accumulator {} ^
r1 = agent.dialogue_turn s5 "first" ^
assert (r1.turn_count == 0) "accumulator sees 0 prior turns"
r2 = agent.dialogue_turn s5 "second" ^
assert (r2.turn_count == 1) "accumulator sees 1 prior turn"
agent.dialogue_end s5

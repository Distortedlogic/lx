-- test: try builtin catches propagated errors

f = () { Err "boom" ^ }
result = try f ()
is_err = err? result
assert (is_err == true) "try catches propagated error"

g = () { Ok 42 ^ }
result2 = try g ()
assert (result2 == 42) "try unwraps Ok values via propagate"

h = () { 99 }
result3 = try h ()
assert (result3 == 99) "try passes through plain values"

-- emit keyword: agent-to-human output via EmitBackend

-- emit returns unit
result = emit "hello"
assert (result == ()) "emit returns unit"

-- emit with interpolation
name = "world"
emit "hello {name}"

-- emit with record (JSON-encoded by backend)
emit {type: "progress"  step: 1  total: 5}

-- emit in pipeline context (does not compose with |)
x = 42
emit "value is {x}"
assert (x == 42) "emit does not affect surrounding values"

-- emit with expression
emit [1 2 3] | len > 0 ? "list is non-empty" : "list is empty"

use std/agent
use pkg/agents/mock {mock}
use pkg/core/reconcile {reconcile}

reviewer = mock [
  {match: "any" respond: {approved: true findings: ["looks good"]}}
]

security = mock [
  {match: "any" respond: {approved: true findings: ["secure"]}}
]

agent.register reviewer {traits: ["Reviewer"] domains: ["code"]} ^
agent.register security {traits: ["Reviewer"] domains: ["security"]} ^

all = agent.registered () ^
assert (all | len) == 2 "registered: should have 2 agents"

reviewers = agent.registered {trait: "Reviewer"} ^
assert (reviewers | len) == 2 "registered: both are Reviewers"

sec_only = agent.registered {domain: "security"} ^
assert (sec_only | len) == 1 "registered: one security agent"

code_only = agent.registered {domain: "code"} ^
assert (code_only | len) == 1 "registered: one code agent"

no_match = agent.registered {trait: "NonExistent"} ^
assert (no_match | len) == 0 "registered: no match for NonExistent"

msg1 = {file: "main.rs"}
result = agent.route msg1 {trait: "Reviewer"} ^
assert result.approved == true "route: should reach a Reviewer"

msg2 = {file: "auth.rs"}
sec_result = agent.route msg2 {domain: "security"} ^
assert sec_result.approved == true "route: should reach security agent"

msg3 = {task: "x"}
route_fail = agent.route msg3 {trait: "NonExistent"}
assert (err? route_fail == true) "route: should error when no match"

fallback_agent = mock [
  {match: "any" respond: {fallback: true}}
]
fb_result = agent.route msg3 {trait: "NonExistent" fallback: fallback_agent} ^
assert fb_result.fallback == true "route: should use fallback"

results = agent.route_multi msg1 {trait: "Reviewer"} ^
assert (results | len) == 2 "route_multi: should get 2 results"

multi_results = agent.route_multi msg1 {trait: "Reviewer"} ^
reconciled = reconcile multi_results {strategy: "vote" vote_field: "approved"}
assert (reconciled.merged == true) "route_multi: vote should pass"

agent.unregister reviewer ^
remaining = agent.registered () ^
assert (remaining | len) == 1 "unregister: should have 1 after removal"

agent.unregister security ^
empty = agent.registered () ^
assert (empty | len) == 0 "unregister: should be empty"

multi_fail = agent.route_multi msg3 {trait: "Gone"}
assert (err? multi_fail == true) "route_multi: should error when no agents"

a1 = mock [{match: "any" respond: {id: 1}}]
a2 = mock [{match: "any" respond: {id: 2}}]
a3 = mock [{match: "any" respond: {id: 3}}]

agent.register a1 {traits: ["Worker"]} ^
agent.register a2 {traits: ["Worker"]} ^
agent.register a3 {traits: ["Worker"]} ^

r1 = agent.route msg3 {trait: "Worker" prefer: "round_robin"} ^
r2 = agent.route msg3 {trait: "Worker" prefer: "round_robin"} ^
r3 = agent.route msg3 {trait: "Worker" prefer: "round_robin"} ^
ids = [r1.id r2.id r3.id]
assert (ids | len) == 3 "round_robin: should get 3 results"

agent.unregister a1 ^
agent.unregister a2 ^
agent.unregister a3 ^

cap_agent = mock [{match: "any" respond: {ok: true}}]
agent.register cap_agent {traits: ["Limited"] max_concurrent: 0} ^

cap_result = agent.route msg3 {trait: "Limited"}
assert (err? cap_result == true) "capacity: should error when max_concurrent=0"

agent.unregister cap_agent ^

emit "[INFO] 77_agent_route: all passed"

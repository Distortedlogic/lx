-- 19_mcp_typed.lx
-- Tests: MCP declarations (typed tool contracts)

use std/mcp

-- declare MCP type with typed tool contracts
MCP TestServer = {
  echo: {msg: Str} -> Str
  add: {a: Int  b: Int} -> Str
}

-- connect and bind to typed declaration
raw_conn = mcp.connect {command: "python3" args: ["tests/fixtures/mcp_test_server.py"]} ^
server = TestServer raw_conn

-- typed call: echo with correct types
echo_result = server.echo {msg: "typed hello"} ^
assert (contains? "typed hello" echo_result == true) "typed echo call"

-- typed call: add with correct types
add_result = server.add {a: 5  b: 3} ^
assert (add_result == "8") "typed add call"

-- input validation: missing required field
bad_echo = server.echo {wrong: "field"}
assert (err? bad_echo == true) "typed echo missing field"

-- input validation: wrong field type
bad_add = server.add {a: "not_int"  b: 3}
assert (err? bad_add == true) "typed add wrong type"

-- MCP decl with default input values
MCP WithDefaults = {
  echo: {msg: Str = "default_msg"} -> Str
}
default_server = WithDefaults raw_conn
default_result = default_server.echo {} ^
assert (contains? "default_msg" default_result == true) "typed echo with default"

-- MCP decl with structured output validation
MCP StructuredEcho = {
  echo: {msg: Str} -> {msg: Str}
}
struct_server = StructuredEcho raw_conn
struct_result = struct_server.echo {msg: "structured"} ^
assert (struct_result.msg == "structured") "typed echo structured output"

-- MCP decl with list output
MCP ListEcho = {
  echo: {items: Str} -> Str
}
list_server = ListEcho raw_conn
list_result = list_server.echo {items: "test"} ^
assert (contains? "test" list_result == true) "typed echo list context"

-- raw mcp.call still works on typed connection
raw_result = mcp.call server "echo" {msg: "raw"} ^
assert (contains? "raw" raw_result == true) "raw call on typed connection"

-- close the connection
mcp.close raw_conn

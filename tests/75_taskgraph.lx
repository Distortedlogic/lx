-- 75_taskgraph.lx
-- Tests: pkg/core/taskgraph (DAG with topo sort and cycle detection)

use pkg/core/taskgraph

g = taskgraph.create {name: "test-graph"}

taskgraph.add g "a" {handler: (input) "result-a"  depends: []}
taskgraph.add g "b" {handler: (input) "result-b"  depends: ["a"]}
taskgraph.add g "c" {handler: (input) "result-c"  depends: ["a"]}
taskgraph.add g "d" {handler: (input) "result-d"  depends: ["b" "c"]}

v = taskgraph.validate g
assert (v | ok?) "validate passes for valid DAG"

order = taskgraph.topo g
assert (order | len == 4) "topo returns all 4 nodes"
assert ((order | first) == Some "a") "topo: a is first"

dot_str = taskgraph.dot g
assert (dot_str | contains? "digraph") "dot output has digraph"

st = taskgraph.status g
assert (st | len == 4) "status returns all nodes"

log.info "75_taskgraph: all passed"

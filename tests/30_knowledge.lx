-- 30_knowledge.lx
-- Tests: pkg/knowledge KnowledgeBase class (shared discovery cache)

use pkg/data/knowledge {KnowledgeBase}
use std/fs

kb_path = "/tmp/lx_knowledge_test.json"

-- === Create ===
kb = KnowledgeBase ()

-- === Store entries ===
kb.store "auth_module" {entry: "src/auth/mod.rs"} {
  source: "reviewer" confidence: 0.9 tags: ["architecture"]
} ^

kb.store "token_flow" {refresh: true expiry: 3600} {
  source: "analyzer" confidence: 0.8 tags: ["auth" "security"]
} ^

-- === Get ===
found = kb.get "auth_module"
assert (found != None) "get existing key"
assert (found.val.entry == "src/auth/mod.rs") "get value"
assert (found.meta.source == "reviewer") "get meta source"
assert (found.meta.confidence == 0.9) "get meta confidence"
assert (len found.stored_at > 0) "get has timestamp"

-- === Get missing ===
missing = kb.get "nonexistent"
assert (missing == None) "get missing returns None"

-- === Keys ===
k = kb.keys ()
assert (len k == 2) "keys count"

-- === Query with filter ===
auth_entries = kb.query (e) {
  tags = e.meta.tags ?? []
  contains? "auth" tags
}
assert (len auth_entries == 1) "query by tag"
assert (auth_entries.0.key == "token_flow") "query result key"

high_conf = kb.query (e) (e.meta.confidence ?? 0) > 0.85
assert (len high_conf == 1) "query by confidence"

all = kb.query (e) true
assert (len all == 2) "query all"

-- === Remove ===
kb.remove "token_flow"
k2 = kb.keys ()
assert (len k2 == 1) "remove reduces count"
assert (kb.get "token_flow" == None) "removed key gone"

-- === Persistence: save + reload ===
kb.save kb_path
kb2 = KnowledgeBase ()
kb2.load kb_path
k3 = kb2.keys ()
assert (len k3 == 1) "reload preserves entries"
reloaded = kb2.get "auth_module"
assert (reloaded != None) "reload preserves data"

-- === Merge ===
kb3 = KnowledgeBase ()
kb3.store "new_fact" "hello" {source: "agent_b"} ^
kb3.store "auth_module" {entry: "overridden"} {source: "agent_b"} ^

kb2.merge kb3 ^
merged_keys = kb2.keys ()
assert (len merged_keys == 2) "merge adds keys"
overridden = kb2.get "auth_module"
assert (overridden.val.entry == "overridden") "merge: kb2 wins"

-- cleanup
fs.remove kb_path ^

log.info "30_knowledge: all passed"

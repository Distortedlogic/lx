-- agent uses wiring tests
-- verifies that `use` declarations auto-connect tools during init

+Tool TestTool = {
  run = (args) { Ok "done" }
}

+Agent TestAgent = {
  use TestTool
  act = (msg) { "done" }
}

a = TestAgent {}
assert (a.tools () | len > 0)
assert (a.tools () | find (t) { t == "TestTool" } | (!= None))

-- 29_circuit.lx
-- Tests: std/circuit module (circuit breakers for agentic loops)

use std/circuit

-- === Create ===
b = circuit.create {max_turns: 5 max_actions: 10 repetition_window: 3}

-- === Initial state ===
st = circuit.status b
assert (st.turns == 0) "initial turns"
assert (st.tripped == false) "initial not tripped"
assert (circuit.is_tripped b == false) "is_tripped false"

-- === Tick ===
circuit.tick b ^
circuit.tick b ^
st2 = circuit.status b
assert (st2.turns == 2) "ticks counted"
assert (circuit.check b | ok? == true) "check ok after 2 ticks"

-- === Record actions ===
circuit.record b "searched for auth" ^
circuit.record b "read token.rs" ^
st3 = circuit.status b
assert (st3.action_count == 2) "actions recorded"

-- === Turn limit trip ===
circuit.tick b ^
circuit.tick b ^
circuit.tick b ^
tripped = circuit.check b
assert (err? tripped == true) "tripped after 5 ticks"
assert (circuit.is_tripped b == true) "is_tripped true"

-- === Reset ===
circuit.reset b ^
assert (circuit.is_tripped b == false) "reset clears trip"
st4 = circuit.status b
assert (st4.turns == 0) "reset clears turns"
assert (st4.action_count == 0) "reset clears actions"

-- === Repetition detection ===
b2 = circuit.create {max_turns: 100 repetition_window: 3}
circuit.record b2 "search X" ^
circuit.record b2 "search X" ^
assert (circuit.is_tripped b2 == false) "2 repeats not enough"
circuit.record b2 "search X" ^
assert (circuit.is_tripped b2 == true) "3 repeats trips"

-- === Action limit ===
b3 = circuit.create {max_turns: 100 max_actions: 3}
circuit.record b3 "a" ^
circuit.record b3 "b" ^
assert (circuit.is_tripped b3 == false) "2 actions ok"
circuit.record b3 "c" ^
assert (circuit.is_tripped b3 == true) "3 actions trips"

-- === Status with reason ===
st5 = circuit.status b3
assert (st5.tripped == true) "status shows tripped"
assert (len st5.reason > 0) "status has reason"

log.info "29_circuit: all passed"

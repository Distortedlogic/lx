-- 29_circuit.lx
-- Tests: pkg/circuit CircuitBreaker class (circuit breakers for agentic loops)

use pkg/core/circuit {CircuitBreaker}

-- === Create ===
b = CircuitBreaker {max_turns: 5 max_actions: 10 repetition_window: 3}

-- === Initial state ===
st = b.status ()
assert (st.turns == 0) "initial turns"
assert (st.tripped == false) "initial not tripped"
assert (b.is_tripped () == false) "is_tripped false"

-- === Tick ===
b.tick () ^
b.tick () ^
st2 = b.status ()
assert (st2.turns == 2) "ticks counted"
assert (b.check () | ok? == true) "check ok after 2 ticks"

-- === Record actions ===
b.record "searched for auth" ^
b.record "read token.rs" ^
st3 = b.status ()
assert (st3.action_count == 2) "actions recorded"

-- === Turn limit trip ===
b.tick () ^
b.tick () ^
b.tick () ^
tripped = b.check ()
assert (err? tripped == true) "tripped after 5 ticks"
assert (b.is_tripped () == true) "is_tripped true"

-- === Reset ===
b.reset () ^
assert (b.is_tripped () == false) "reset clears trip"
st4 = b.status ()
assert (st4.turns == 0) "reset clears turns"
assert (st4.action_count == 0) "reset clears actions"

-- === Repetition detection ===
b2 = CircuitBreaker {max_turns: 100 repetition_window: 3}
b2.record "search X" ^
b2.record "search X" ^
assert (b2.is_tripped () == false) "2 repeats not enough"
b2.record "search X" ^
assert (b2.is_tripped () == true) "3 repeats trips"

-- === Action limit ===
b3 = CircuitBreaker {max_turns: 100 max_actions: 3}
b3.record "a" ^
b3.record "b" ^
assert (b3.is_tripped () == false) "2 actions ok"
b3.record "c" ^
assert (b3.is_tripped () == true) "3 actions trips"

-- === Status with reason ===
st5 = b3.status ()
assert (st5.tripped == true) "status shows tripped"
assert (len st5.reason > 0) "status has reason"

log.info "29_circuit: all passed"

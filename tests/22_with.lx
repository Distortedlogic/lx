-- with expression and record field update

-- basic with (immutable)
x = with greeting = "hello" {
  greeting ++ " world"
}
assert (x == "hello world")

-- with returns last value
result = with n = 42 {
  n * 2
}
assert (result == 84)

-- with scoping - binding does not leak
with scoped = 99 {
  assert (scoped == 99)
}

-- with mutable via :=
with count := 0 {
  count <- 1
  count <- count + 1
  assert (count == 2)
}

-- with mutable via "mut" keyword
with mut total = 0 {
  total <- total + 10
  total <- total + 20
  assert (total == 30)
}

-- nested with
result = with a = 10 {
  with b = 20 {
    a + b
  }
}
assert (result == 30)

-- with in expressions
items = [1 2 3]
sum = with acc := 0 {
  items | each (x) { acc <- acc + x }
  acc
}
assert (sum == 6)

-- record field update (single level)
state := {step: "init", count: 0}
state.step <- "running"
assert (state.step == "running")
assert (state.count == 0)

-- record field update (add new field)
rec := {x: 1}
rec.y <- 2
assert (rec.x == 1)
assert (rec.y == 2)

-- record field update (nested)
config := {db: {host: "localhost", port: 5432}}
config.db.port <- 3306
assert (config.db.port == 3306)
assert (config.db.host == "localhost")

-- record field update with expressions
data := {value: 10}
data.value <- data.value * 3
assert (data.value == 30)

-- with + field update together
result = with mut ctx = {step: "init", data: []} {
  ctx.step <- "processing"
  ctx.data <- [1 2 3]
  ctx.step <- "done"
  ctx
}
assert (result.step == "done")
assert (result.data == [1 2 3])

-- field update in with block
with mut state = {count: 0, items: []} {
  state.count <- 5
  state.items <- ["a" "b"]
  assert (state.count == 5)
  assert (state.items == ["a" "b"])
}

-- with as pipeline context
json_str = json.encode {name: "test", value: 42}
with parsed = json.parse json_str ^ {
  assert (parsed.name == "test")
  assert (parsed.value == 42)
}

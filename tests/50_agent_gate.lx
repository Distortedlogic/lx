-- 50_agent_gate.lx
-- Tests: spec/agents-gates.md (agent.gate approval gates)
-- Phase: agent.gate, GateResult Trait
-- Note: Uses yield backend for gate communication. Default stdin/stdout backend
--       auto-approves in non-interactive mode (returns unit from yield).
--       Tests focus on timeout policies and structure.

use std/agent {GateResult}
use std/agent

-- GateResult Trait validates
gr = GateResult {approved: true  approver: "admin"  timestamp: "2024-01-01T00:00:00Z"}
assert (gr.approved == true) "gate result approved field"
assert (gr.approver == "admin") "gate result approver field"
assert (gr.reason == "") "gate result reason defaults to empty"
assert (gr.timestamp == "2024-01-01T00:00:00Z") "gate result timestamp field"

-- GateResult with rejection
gr2 = GateResult {
  approved: false
  approver: "security"
  reason: "insufficient testing"
  timestamp: "2024-01-01T00:00:00Z"
}
assert (gr2.approved == false) "gate result rejected"
assert (gr2.reason == "insufficient testing") "gate result rejection reason"

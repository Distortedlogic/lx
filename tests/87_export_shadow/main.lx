-- 82_export_shadow/main.lx
-- Tests: +export names don't shadow builtins inside the defining module

use ./lib_shadow

items = [{tag: "a"  val: 1} {tag: "b"  val: 2} {tag: "a"  val: 3}]
result = lib_shadow.filter "a" items
assert (len result == 2)
assert (result.0.val == 1)
assert (result.1.val == 3)

doubled = lib_shadow.map (* 2) [1 2 3]
assert (doubled == [2 4 6])

total = lib_shadow.fold 0 (+) [10 20 30]
assert (total == 60)

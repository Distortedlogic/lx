-- std/cron: scheduled task execution
use std/cron
use std/time

-- cron.every returns an Int handle
handle = cron.every 100 () {
  ()
}
assert (handle > 0) "cron.every returns positive handle"

-- cron.active counts running jobs
n = cron.active ()
assert (n == 1) "one active job after cron.every"

-- cron.cancel stops a job
cron.cancel handle
n2 = cron.active ()
assert (n2 == 0) "no active jobs after cancel"

-- cancelling invalid handle returns Err
bad = cron.cancel 99999
bad ? {
  Err _ -> assert true "cancel nonexistent returns Err"
  _ -> assert false "expected Err from cancel"
}

-- multiple jobs
h1 = cron.every 200 () { () }
h2 = cron.every 300 () { () }
assert (cron.active () == 2) "two active jobs"
cron.cancel h1
assert (cron.active () == 1) "one active after cancelling first"
cron.cancel h2
assert (cron.active () == 0) "zero active after cancelling both"

-- cron.list returns active handles
h3 = cron.every 200 () { () }
h4 = cron.every 300 () { () }
ids = cron.list ()
assert (len ids == 2) "list returns 2 handles"
cron.cancel h3
cron.cancel h4

-- cron.after fires once then auto-removes
ha = cron.after 50 () { () }
assert (ha > 0) "cron.after returns positive handle"
time.sleep 200
assert (cron.active () == 0) "after job auto-removed"

-- cron.next returns next fire time for expression
result = cron.next "* * * * *"
result ? {
  Ok ts -> {
    assert (ts.epoch > 0) "next returns valid epoch"
    assert (ts.iso | len > 0) "next returns iso string"
  }
  Err _ -> assert false "cron.next should succeed for valid expression"
}

-- cron.next with invalid expression returns error
bad_next = cron.next "not a cron"
bad_next ? {
  Err _ -> assert true "bad expression returns Err"
  _ -> assert false "expected Err from bad expression"
}

-- cron.next_n returns multiple fire times
times = cron.next_n 3 "* * * * *"
assert (len times == 3) "next_n returns 3 times"
first = times.0
assert (first.epoch > 0) "first time has valid epoch"

-- cron.schedule with standard 5-field cron expression
hs = cron.schedule "* * * * *" () { () }
assert (hs > 0) "cron.schedule returns positive handle"
assert (cron.active () >= 1) "schedule job is active"
cron.cancel hs
assert (cron.active () == 0) "schedule job cancelled"

$echo "std/cron ok"

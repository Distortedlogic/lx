-- 95_yield_typed.lx
-- Tests: typed yield variants (spec/agents-yield-typed.md)
-- Verifies: std/yield Trait import, field defaults, kind injection,
--   validation errors, orchestrator wire format

use std/json
use std/yield {YieldApproval YieldReflection YieldInformation YieldDelegation YieldProgress}

-- ============================================================
-- Trait construction: defaults and required fields
-- ============================================================

approval = YieldApproval {action: "deploy"  details: {env: "prod"}}
assert (approval.kind == "approval") "approval: kind default"
assert (approval.action == "deploy") "approval: action"
assert (approval.details.env == "prod") "approval: details nested"
assert (approval.timeout_policy == "block") "approval: timeout_policy default"

reflection = YieldReflection {
  task: "analyze code"
  attempt: {score: 15  feedback: "too shallow"}
  question: "What should I change?"
}
assert (reflection.kind == "reflection") "reflection: kind default"
assert (reflection.task == "analyze code") "reflection: task"
assert (reflection.attempt.score == 15) "reflection: attempt nested"
assert (reflection.question == "What should I change?") "reflection: question"
assert (reflection.context == None) "reflection: context default None"

info = YieldInformation {query: "API key for service X"}
assert (info.kind == "information") "information: kind default"
assert (info.query == "API key for service X") "information: query"
assert (info.context == None) "information: context default None"
assert (info.format == "text") "information: format default"

delegation = YieldDelegation {task: {name: "review"  files: ["a.rs" "b.rs"]}}
assert (delegation.kind == "delegation") "delegation: kind default"
assert (delegation.task.name == "review") "delegation: task nested"
assert (delegation.constraints == None) "delegation: constraints default None"
assert (delegation.deadline == None) "delegation: deadline default None"

progress = YieldProgress {stage: "parsing"  pct: 0.45}
assert (progress.kind == "progress") "progress: kind default"
assert (progress.stage == "parsing") "progress: stage"
assert (progress.pct == 0.45) "progress: pct"
assert (progress.message == "") "progress: message default empty"

-- ============================================================
-- Override defaults
-- ============================================================

custom_approval = YieldApproval {
  action: "delete"
  details: ()
  timeout_policy: "auto_approve"
}
assert (custom_approval.timeout_policy == "auto_approve") "approval: timeout_policy override"

info_json = YieldInformation {
  query: "schema"
  context: {table: "users"}
  format: "json"
}
assert (info_json.format == "json") "information: format override"
assert (info_json.context.table == "users") "information: context override"

progress_msg = YieldProgress {stage: "done"  pct: 1.0  message: "All tests passed"}
assert (progress_msg.message == "All tests passed") "progress: message override"

delegation_constrained = YieldDelegation {
  task: "build"
  constraints: {max_time: 300}
  deadline: 1700000000
}
assert (delegation_constrained.constraints.max_time == 300) "delegation: constraints override"
assert (delegation_constrained.deadline == 1700000000) "delegation: deadline override"

-- ============================================================
-- Validation: missing required fields produce Err
-- ============================================================

bad_approval = YieldApproval {action: "deploy"} ?? "caught"
assert (bad_approval == "caught") "approval: missing details -> Err"

bad_reflection = YieldReflection {task: "x"  attempt: "y"} ?? "caught"
assert (bad_reflection == "caught") "reflection: missing question -> Err"

bad_info = YieldInformation () ?? "caught"
assert (bad_info == "caught") "information: missing query -> Err"

bad_delegation = YieldDelegation () ?? "caught"
assert (bad_delegation == "caught") "delegation: missing task -> Err"

bad_progress = YieldProgress {stage: "x"} ?? "caught"
assert (bad_progress == "caught") "progress: missing pct -> Err"

-- ============================================================
-- JSON serialization: kind field present
-- ============================================================

approval_json = json.encode approval
parsed = json.parse approval_json ^
assert (parsed.kind == "approval") "json roundtrip: kind field survives"
assert (parsed.action == "deploy") "json roundtrip: action field survives"

-- ============================================================
-- Typed yield via orchestrator (end-to-end wire format)
-- ============================================================

resp_json = json.encode [
  {approved: true}
  {guidance: "try harder"}
  {answer: "secret123"}
]
result = $^python3 tests/fixtures/yield_orchestrator.py tests/fixtures/yield_typed.lx '{resp_json}'
parsed_result = json.parse result ^
assert (parsed_result.exit_code == 0) "typed yield e2e: exit code 0"
assert (len parsed_result.yields == 3) "typed yield e2e: three yields"

assert (parsed_result.yields.0.kind == "approval") "typed yield e2e: first yield kind"
assert (parsed_result.yields.0.action == "deploy") "typed yield e2e: first yield action"

assert (parsed_result.yields.1.kind == "reflection") "typed yield e2e: second yield kind"
assert (parsed_result.yields.1.question == "What should I change?") "typed yield e2e: second yield question"

assert (parsed_result.yields.2.kind == "information") "typed yield e2e: third yield kind"
assert (parsed_result.yields.2.query == "API key for service X") "typed yield e2e: third yield query"

use std/agent
use pkg/agents/intercept {intercept}

-- agent.reload: basic handler replacement
old_handler = (msg) "old: " ++ msg.task
worker = {name: "w1" handler: old_handler}

r1 = worker ~>? {task: "hello"}
assert r1 == "old: hello" "reload: before reload"

new_handler = (msg) "new: " ++ msg.task
worker = agent.reload worker {handler: new_handler} ^
r2 = worker ~>? {task: "hello"}
assert r2 == "new: hello" "reload: after reload"

-- agent.reload: second reload works
third_handler = (msg) "v3: " ++ msg.task
worker = agent.reload worker {handler: third_handler} ^
r3 = worker ~>? {task: "hello"}
assert r3 == "v3: hello" "reload: second reload"

-- agent.reload: subprocess returns Err
sub_agent = {name: "fake" __pid: 99999}
sub_result = agent.reload sub_agent {handler: (m) m}
assert (sub_result ? {Err e -> e == "cannot reload subprocess agent"; _ -> false}) "reload: subprocess err"

-- agent.reload: on_reload callback receives old and new handler
on_reload_cb = (old_h new_h) {
  assert (old_h "test" == "old: test") "on_reload: old handler works"
  assert (new_h "test" == "new: test") "on_reload: new handler works"
}
cb_handler_old = (msg) "old: " ++ msg
cb_handler_new = (msg) "new: " ++ msg
cb_agent = {name: "cb" handler: cb_handler_old}
cb_agent = agent.reload cb_agent {handler: cb_handler_new on_reload: on_reload_cb} ^

-- agent.evolve: handler self-update
counter = Store ()
counter.set "n" 0
evolving_handler = (msg) {
  n = counter.get "n"
  counter.set "n" (n + 1)
  (n >= 1) ? {
    true -> {
      evolved_fn = (m) "evolved: " ++ m.task
      agent.evolve {handler: evolved_fn} ^
    }
    false -> ()
  }
  "original: " ++ msg.task
}
evo_agent = {name: "evo" handler: evolving_handler}
evo_agent = agent.reload evo_agent {handler: evolving_handler} ^

e1 = evo_agent ~>? {task: "a"}
assert e1 == "original: a" "evolve: first call"

e2 = evo_agent ~>? {task: "b"}
assert e2 == "original: b" "evolve: second call triggers evolve but returns old result"

e3 = evo_agent ~>? {task: "c"}
assert e3 == "evolved: c" "evolve: third call uses evolved handler"

-- agent.evolve: outside handler context returns Err
no_ctx = agent.evolve {handler: (m) m}
assert (no_ctx ? {Err e -> true; _ -> false}) "evolve: no context returns Err"

-- agent.update_traits: add and remove
trait_agent = {name: "t" handler: (m) m __traits: ["Worker"]}
trait_agent = agent.update_traits trait_agent {add: ["Reviewer" "Auditor"]} ^
traits_after_add = trait_agent.__traits
assert (len traits_after_add) == 3 "update_traits: add"

trait_agent = agent.update_traits trait_agent {remove: ["Worker"]} ^
traits_after_remove = trait_agent.__traits
assert (len traits_after_remove) == 2 "update_traits: remove"
assert traits_after_remove == ["Reviewer" "Auditor"] "update_traits: correct traits"

-- agent.update_traits: no duplicates
trait_agent2 = {name: "t2" handler: (m) m __traits: ["A"]}
trait_agent2 = agent.update_traits trait_agent2 {add: ["A" "B"]} ^
assert trait_agent2.__traits == ["A" "B"] "update_traits: no duplicates"

-- reload preserves interceptors
base_handler = (msg) "base: " ++ msg.data
base_agent = {name: "inter" handler: base_handler}
base_agent = agent.reload base_agent {handler: base_handler} ^
middleware = (msg next) {
  inner = next {data: "wrapped(" ++ msg.data ++ ")"}
  "mid[" ++ inner ++ "]"
}
intercepted = intercept base_agent middleware

i1 = intercepted ~>? {data: "x"}
assert i1 == "mid[base: wrapped(x)]" "intercept+reload: before"

agent.reload base_agent {handler: (msg) "reloaded: " ++ msg.data} ^
i2 = intercepted ~>? {data: "y"}
assert i2 == "mid[reloaded: wrapped(y)]" "intercept+reload: after reload interceptor sees new handler"

emit "[INFO] 91_agent_reload: all passed"

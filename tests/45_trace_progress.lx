-- 45_trace_progress.lx
-- Tests: trace.improvement_rate and trace.should_stop

use std/trace
use std/fs

path = "/tmp/lx_trace_progress_test.json"
fs.remove path ?? ()

t = trace.create path ^

-- record progress spans with scores
trace.record {name: "progress" score: 50.0 output: "initial"} t ^
trace.record {name: "progress" score: 72.0 output: "revision 1"} t ^
trace.record {name: "progress" score: 85.0 output: "revision 2"} t ^
trace.record {name: "progress" score: 87.0 output: "revision 3"} t ^
trace.record {name: "progress" score: 87.5 output: "revision 4"} t ^

-- improvement_rate over last 3 spans
rate = trace.improvement_rate 3 t
assert (rate.samples == 3) "improvement_rate: samples count"
assert (rate.recent_delta == 0.5) "improvement_rate: recent_delta"
assert (rate.avg_delta > 0.0) "improvement_rate: avg_delta positive"

-- trend should be diminishing (recent 0.5 < avg ~1.5 * 0.8)
assert (rate.trend == "diminishing") "improvement_rate: trend is diminishing"

-- improvement_rate over all 5 spans
rate_all = trace.improvement_rate 5 t
assert (rate_all.samples == 5) "improvement_rate: all samples"
assert (rate_all.recent_delta == 0.5) "improvement_rate: all recent_delta"

-- should_stop with high min_delta threshold
stop = trace.should_stop {min_delta: 15.0 window: 3} t
assert (stop == true) "should_stop: true when deltas below threshold"

-- should_stop with low threshold (13.0 delta at start is above 0.1)
no_stop = trace.should_stop {min_delta: 0.1 window: 4} t
assert (no_stop == false) "should_stop: false when some deltas above threshold"

-- should_stop with window=2: last 2 deltas are 2.0 and 0.5
stop_narrow = trace.should_stop {min_delta: 3.0 window: 2} t
assert (stop_narrow == true) "should_stop: narrow window all below"

-- insufficient data: only 1 span
path2 = "/tmp/lx_trace_progress_test2.json"
fs.remove path2 ?? ()
t2 = trace.create path2 ^
trace.record {name: "progress" score: 50.0 output: "only one"} t2 ^

rate_insuf = trace.improvement_rate 3 t2
assert (rate_insuf.trend == "insufficient") "improvement_rate: insufficient with 1 span"
assert (rate_insuf.samples == 1) "improvement_rate: 1 sample"

stop_insuf = trace.should_stop {min_delta: 1.0 window: 3} t2
assert (stop_insuf == false) "should_stop: false with insufficient data"

-- non-progress spans are ignored
trace.record {name: "search" score: 99.0 output: "not progress"} t ^
rate_filtered = trace.improvement_rate 3 t
assert (rate_filtered.samples == 3) "improvement_rate: ignores non-progress spans"

-- regression detection
path3 = "/tmp/lx_trace_progress_test3.json"
fs.remove path3 ?? ()
t3 = trace.create path3 ^
trace.record {name: "progress" score: 80.0 output: "start"} t3 ^
trace.record {name: "progress" score: 85.0 output: "up"} t3 ^
trace.record {name: "progress" score: 82.0 output: "down"} t3 ^

rate_reg = trace.improvement_rate 3 t3
assert (rate_reg.trend == "regressing") "improvement_rate: detects regression"
assert (rate_reg.recent_delta < 0.0) "improvement_rate: negative recent_delta"

-- cleanup
fs.remove path ^
fs.remove path2 ^
fs.remove path3 ^

log.info "45_trace_progress: all passed"

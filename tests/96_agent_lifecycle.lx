use std/agent
use std/store

-- agent.on: register startup hook and fire it
log = Store ()
log.set "events" []
me = {name: "lc1" handler: (msg) msg}
me = agent.on me "startup" () { log.set "events" ((log.get "events") ++ ["started"]) } ^

agent.startup me ^
assert (log.get "events" == ["started"]) "lifecycle: startup hook fired"

-- agent.on: register shutdown hook and fire it
slog = Store ()
slog.set "events" []
me2 = {name: "lc2" handler: (msg) msg}
me2 = agent.on me2 "shutdown" (reason) { slog.set "events" ((slog.get "events") ++ [reason]) } ^

agent.shutdown me2 "done" ^
assert (slog.get "events" == ["done"]) "lifecycle: shutdown hook fired with reason"

-- agent.on: multiple hooks for same event fire in order
mlog = Store ()
mlog.set "events" []
me3 = {name: "lc3" handler: (msg) msg}
me3 = agent.on me3 "startup" () { mlog.set "events" ((mlog.get "events") ++ ["first"]) } ^
me3 = agent.on me3 "startup" () { mlog.set "events" ((mlog.get "events") ++ ["second"]) } ^

agent.startup me3 ^
assert (mlog.get "events" == ["first" "second"]) "lifecycle: multiple hooks fire in order"

-- agent.on: signal hook
sig_log = Store ()
sig_log.set "events" []
me4 = {name: "lc4" handler: (msg) msg}
me4 = agent.on me4 "signal" (s) { sig_log.set "events" ((sig_log.get "events") ++ [s]) } ^

agent.signal me4 {action: "pause"} ^
assert (sig_log.get "events" == [{action: "pause"}]) "lifecycle: signal hook receives signal"

-- agent.on_remove: clears hooks
rm_log = Store ()
rm_log.set "events" []
me6 = {name: "lc6" handler: (msg) msg}
me6 = agent.on me6 "startup" () { rm_log.set "events" ((rm_log.get "events") ++ ["should_not_fire"]) } ^

agent.on_remove me6 "startup" ^
agent.startup me6 ^
assert (rm_log.get "events" == []) "lifecycle: on_remove clears hooks"

-- agent.on: idle hook registration with duration
me7 = {name: "lc7" handler: (msg) msg}
me7 = agent.on me7 "idle" 30 () { () } ^

hooks = agent.idle_hooks me7
assert (hooks | len == 1) "lifecycle: idle hook registered"
assert (hooks.0.seconds == 30) "lifecycle: idle hook has correct duration"

-- agent.on: startup with no hooks is no-op
me9 = {name: "lc9" handler: (msg) msg}
agent.startup me9 ^

-- agent.on: shutdown cleans up hook storage
cl_log = Store ()
cl_log.set "events" []
me10 = {name: "lc10" handler: (msg) msg}
me10 = agent.on me10 "startup" () { cl_log.set "events" ((cl_log.get "events") ++ ["alive"]) } ^
agent.startup me10 ^
assert (cl_log.get "events" == ["alive"]) "lifecycle: pre-shutdown fires"
agent.shutdown me10 "cleanup" ^

-- agent.on: "on" as identifier is fine
on = 42
assert (on == 42) "lifecycle: on as identifier"

emit "[INFO] 96_agent_lifecycle: all passed"

-- 09_errors.lx
-- Tests: spec/errors.md (Result/Maybe, ^, ??, require, implicit Ok)
-- Phase: 5 (Error Handling)

-- Result construction
assert (Ok 42 == Ok 42)
assert (Err "bad" == Err "bad")
assert (Ok 1 != Err 1)
assert (Ok 1 != Ok 2)
assert (Err "a" != Err "b")

-- Maybe construction
assert (Some 42 == Some 42)
assert (None == None)
assert (Some 1 != None)
assert (Some 1 != Some 2)

-- Result matching
result = Ok 10
val = result ? {
  Ok v  -> v
  Err _ -> 0
}
assert (val == 10)

err_result = Err "failed"
val2 = err_result ? {
  Ok v  -> v
  Err _ -> -1
}
assert (val2 == -1)

-- Result matching extracts error message
err_msg = Err "oops" ? {
  Ok _  -> "ok"
  Err e -> e
}
assert (err_msg == "oops")

-- Maybe matching
maybe_val = Some "hello"
extracted = maybe_val ? {
  Some s -> s
  None   -> "default"
}
assert (extracted == "hello")

none_val = None
extracted2 = none_val ? {
  Some s -> s
  None   -> "default"
}
assert (extracted2 == "default")

-- ^ propagation on Result (in function context)
unwrap_ok = () {
  x = Ok 42
  x ^
}
assert (unwrap_ok () == 42)

propagate_err = () {
  x = Err "bad"
  x ^
}
assert (propagate_err () == Err "bad")

-- ^ propagation on Maybe (Some unwraps)
unwrap_some = () {
  x = Some "hello"
  x ^
}
assert (unwrap_some () == "hello")

-- ^ in chain (multiple propagations)
chain = () {
  a = Ok 1 ^
  b = Ok 2 ^
  a + b
}
assert (chain () == 3)

chain_fail = () {
  a = Ok 1 ^
  b = Err "stop" ^
  a + b
}
assert (chain_fail () ? { Err _ -> true; _ -> false })

-- ?? coalescing on Result
assert ((Ok 42 ?? 0) == 42)
assert ((Err "bad" ?? 0) == 0)

-- ?? coalescing on Maybe
assert ((Some "hi" ?? "default") == "hi")
assert ((None ?? "default") == "default")

-- ?? with nested expressions
assert ((Err "x" ?? (1 + 2)) == 3)
assert ((None ?? (10 * 5)) == 50)
assert ((Ok 99 ?? 0) == 99)
assert ((Some true ?? false) == true)

-- ?? in pipeline
safe_div = (a b) b == 0 ? Err "div by zero" : Ok (a / b)
assert ((safe_div 10 2 ?? 0) == 5.0)
assert ((safe_div 10 0 ?? 0) == 0)

-- require: Maybe -> Result
assert (require "missing" (Some 5) == Ok 5)
assert (require "missing" None == Err "missing")

-- require with pipe syntax
assert (Some 99 | require "gone" == Ok 99)
assert (None | require "gone" == Err "gone")

-- require with ^ (in function context)
require_and_unwrap = () {
  val = Some 10 | require "not found" ^
  val * 2
}
assert (require_and_unwrap () == 20)

require_fail = () {
  val = None | require "not found" ^
  val * 2
}
assert (require_fail () == Err "not found")

-- explicit Ok/Err returns
validate = (age) age < 0 ? {
  true -> Err "too young"
  false -> age > 150 ? {
    true -> Err "too old"
    false -> Ok age
  }
}
assert (validate 25 == Ok 25)
assert (validate (-1) == Err "too young")
assert (validate 200 == Err "too old")

-- ok? predicate
assert (ok? (Ok 1) == true)
assert (ok? (Err "x") == false)

-- err? predicate
assert (err? (Err "x") == true)
assert (err? (Ok 1) == false)

-- some? predicate
assert (some? (Some 1) == true)
assert (some? None == false)

-- predicates in pipelines
results = [Ok 1  Err "a"  Ok 3  Err "b"]
assert (results | filter ok? | len == 2)
assert (results | filter err? | len == 2)

-- ?? with map (section form)
defaults = [Ok 1  Err "x"  Ok 3] | map (?? 0)
assert (defaults == [1 0 3])

-- ?? section on Maybe values
maybe_defaults = [Some "a"  None  Some "c"] | map (?? "z")
assert (maybe_defaults == ["a" "z" "c"])

-- ^ in pipeline within function
pipeline_unwrap = () {
  Ok 42 ^
}
assert (pipeline_unwrap () == 42)

pipeline_propagate = () {
  Err "stop" ^
}
assert (pipeline_propagate () == Err "stop")

-- chaining ^ through multiple steps
multi_step = () {
  a = Ok 10 ^
  b = Ok 20 ^
  c = Ok 30 ^
  a + b + c
}
assert (multi_step () == 60)

multi_step_fail = () {
  a = Ok 10 ^
  b = Err "mid" ^
  c = Ok 30 ^
  a + b + c
}
assert (multi_step_fail () ? { Err e -> e; _ -> "no error" } == "mid")

-- nested Result/Maybe
nested_unwrap = () {
  outer = Ok (Some 42)
  inner = outer ^
  inner ^
}
assert (nested_unwrap () == 42)

nested_err = () {
  outer = Err "outer failed"
  outer ^
}
assert (nested_err () == Err "outer failed")

-- error in match arm with guards
classify = (r) r ? {
  Ok v & (v > 0)  -> "positive"
  Ok v & (v == 0) -> "zero"
  Ok _             -> "negative"
  Err e            -> "error: {e}"
}
assert (classify (Ok 5) == "positive")
assert (classify (Ok 0) == "zero")
assert (classify (Ok (-1)) == "negative")
assert (classify (Err "fail") == "error: fail")

-- partition by ok?
(successes failures) = [Ok 1  Err "a"  Ok 2  Err "b"] | partition ok?
assert (successes | len == 2)
assert (failures | len == 2)

-- ?? chained with other operations
assert ((Err "x" ?? 10) | (* 2) == 20)
assert ((Ok 5 ?? 10) | (* 2) == 10)

-- require on find result
items = [1 2 3 4 5]
found = items | find (== 3)
assert (found | require "not found" == Ok 3)

not_found = items | find (== 99)
assert (not_found | require "not found" == Err "not found")

-- ^ on find with require in function
lookup = (xs target) {
  xs | find (== target) | require "not found" ^
}
assert (lookup [1 2 3] 2 == 2)
assert (lookup [1 2 3] 99 == Err "not found")

-- match on Ok/Err as expression
describe = (r) "result is {r ? { Ok v -> "ok({v})"; Err e -> "err({e})" }}"
assert (describe (Ok 42) == "result is ok(42)")
assert (describe (Err "bad") == "result is err(bad)")

-- ?? preserves type
str_result = Ok "hello" ?? "fallback"
assert (str_result == "hello")
str_err = Err "x" ?? "fallback"
assert (str_err == "fallback")

-- multiple ?? in sequence (leftmost non-error wins)
first_ok = () {
  a = Err "no"
  b = Err "nope"
  c = Ok 42
  a ?? (b ?? (c ?? 0))
}
assert (first_ok () == 42)

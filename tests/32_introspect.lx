-- 32_introspect.lx
-- Tests: pkg/introspect Inspector class (agent self-awareness)

use pkg/introspect {Inspector}

ins = Inspector ()

-- === Self identity ===
me = ins.identity ()
assert (me.name == "main") "self name"
assert (me.role == "main") "self role"
assert (me.pid > 0) "self pid"

-- === Elapsed time ===
t = ins.elapsed ()
assert (t >= 0.0) "elapsed non-negative"

-- === Turn count ===
assert (ins.turn_count () == 0) "initial turn count"
ins.tick_turn ()
ins.tick_turn ()
assert (ins.turn_count () == 2) "turn count after ticks"

-- === Budget (unlimited) ===
b = ins.budget ()
assert (b.total == (0 - 1)) "budget unlimited total"
assert (b.remaining == (0 - 1)) "budget unlimited remaining"

-- === Record + actions ===
ins.record {type: "fs_read" target: "src/main.rs"}
ins.record {type: "mcp_call" target: "search"}
ins.record {type: "fs_read" target: "src/lib.rs"}

actions = ins.get_actions ()
assert (len actions == 3) "actions count"
assert (actions.0.type == "fs_read") "action type"
assert (actions.0.target == "src/main.rs") "action target"
assert (len actions.0.time > 0) "action has timestamp"

-- === Mark + actions_since ===
ins.mark "checkpoint_1"
ins.record {type: "shell" target: "cargo test"}
ins.record {type: "fs_read" target: "Cargo.toml"}

since = ins.actions_since "checkpoint_1"
assert (len since == 2) "actions_since marker"
assert (since.0.type == "shell") "actions_since first"

-- === Is stuck (not stuck) ===
assert (ins.is_stuck () == false) "not stuck with varied actions"

-- === Is stuck (stuck) ===
ins.record {type: "search" target: "same query"}
ins.record {type: "search" target: "same query"}
ins.record {type: "search" target: "same query"}
ins.record {type: "search" target: "same query"}
ins.record {type: "search" target: "same query"}
assert (ins.is_stuck () == true) "stuck after 5 identical"

-- === Strategy shift resets stuck ===
ins.strategy_shift "try different approach"
ins.record {type: "analyze" target: "new file"}
assert (ins.is_stuck () == false) "not stuck after shift"

-- === Similar actions ===
ins.record {type: "read" target: "x.rs"}
ins.record {type: "read" target: "x.rs"}
ins.record {type: "read" target: "x.rs"}
sim = ins.similar_actions 5
assert (sim == 3) "similar actions count"

log.info "32_introspect: all passed"

-- 84_workspace.lx
-- Tests: pkg/agents/workspace (collaborative editing)

use pkg/agents/workspace

ws = workspace.create "test-ws" {content: "line1\nline2\nline3"}
assert (ws.name == "test-ws") "create sets name"

snap = workspace.snapshot ws
assert (snap == "line1\nline2\nline3") "snapshot returns content"

r = workspace.claim ws "section1" "agent-a"
assert (r | ok?) "claim returns Ok"

regions = workspace.regions ws
assert (regions | len == 1) "one region claimed"

rel = workspace.release ws "section1"
assert (rel | ok?) "release returns Ok"

regions2 = workspace.regions ws
assert (regions2 | len == 0) "region released"

log.info "84_workspace: all passed"

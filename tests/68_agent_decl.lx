-- 68_agent_decl.lx
-- Tests: Agent declarations - first-class agent keyword

-- === basic Agent declaration ===
Agent Echo = {
  echo = (msg) msg
}
assert (to_str Echo == "<Agent Echo>") "Agent creates named value"

-- === Agent method access via dot ===
result = Echo.echo "hello"
assert (result == "hello") "method callable via dot access"

-- === Agent with multiple methods ===
Agent Calculator = {
  add = (msg) msg.a + msg.b
  mul = (msg) msg.a * msg.b
}
assert (Calculator.add {a: 3 b: 4} == 7) "multi-method add works"
assert (Calculator.mul {a: 3 b: 4} == 12) "multi-method mul works"

-- === Agent with init state ===
Agent Counter = {
  init: {count: 0}
  increment = (msg) msg + 1
  get = (msg) msg
}
assert (Counter.init == {count: 0}) "init is accessible"

-- === Agent with Trait conformance ===
Trait Greetable = {
  handles: [greet]
  provides: []
  requires: []
}

Agent Greeter: Greetable = {
  greet = (msg) "hello {msg.name}"
}
assert (Greeter.greet {name: "world"} == "hello world") "trait-conformant agent works"

-- === Agent with multiple traits ===
Trait Readable = {
  handles: [read]
  provides: []
  requires: []
}
Trait Writable = {
  handles: [write]
  provides: []
  requires: []
}
Agent Storage: [Readable Writable] = {
  read = (msg) "reading {msg.key}"
  write = (msg) "writing {msg.key}"
}
assert (Storage.read {key: "x"} == "reading x") "multi-trait read"
assert (Storage.write {key: "y"} == "writing y") "multi-trait write"

-- === untyped Agent (no traits) ===
Agent Flexible = {
  anything = (msg) msg
  other = (msg) msg.x ?? "default"
}
assert (Flexible.anything 42 == 42) "untyped agent method"
assert (Flexible.other {x: "val"} == "val") "untyped agent record method"

-- === Agent methods are functions ===
fn = Greeter.greet
assert (fn {name: "test"} == "hello test") "extracted method is callable"

log.info "68_agent_decl: all passed"

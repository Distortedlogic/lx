lx_bin = $^readlink -f target/debug/lx | trim
ob = "\{"
cb = "}"

-- Test 1: install with no deps prints message
t1 = $^mktemp -d | trim
$echo '[package]' > "{t1}/lx.toml"
$echo 'name = "test-proj"' >> "{t1}/lx.toml"
$echo 'version = "0.1.0"' >> "{t1}/lx.toml"
r1 = ($cd "{t1}" && "{lx_bin}" install) ? { Ok v -> v; _ -> {out: "" code: 1} }
assert (r1.code == 0)
assert (r1.out | contains? "no dependencies")
$^rm -rf "{t1}"

-- Test 2: update with no deps prints message
t2 = $^mktemp -d | trim
$echo '[package]' > "{t2}/lx.toml"
$echo 'name = "test-proj"' >> "{t2}/lx.toml"
$echo 'version = "0.1.0"' >> "{t2}/lx.toml"
r2 = ($cd "{t2}" && "{lx_bin}" update) ? { Ok v -> v; _ -> {out: "" code: 1} }
assert (r2.code == 0)
assert (r2.out | contains? "no dependencies")
$^rm -rf "{t2}"

-- Test 3: install path dep creates symlink and lock file
t3 = $^mktemp -d | trim
$^mkdir -p "{t3}/my-dep"
$^printf '+greet = (name) "hello " ++ name\n' > "{t3}/my-dep/main.lx"
dep3 = t3 ++ "/my-dep"
dl3 = "my-dep = " ++ ob ++ " path = \"" ++ dep3 ++ "\" " ++ cb
$echo '[package]' > "{t3}/lx.toml"
$echo 'name = "test-proj"' >> "{t3}/lx.toml"
$echo 'version = "0.1.0"' >> "{t3}/lx.toml"
$echo '' >> "{t3}/lx.toml"
$echo '[dependencies]' >> "{t3}/lx.toml"
$echo '{dl3}' >> "{t3}/lx.toml"

iv3 = ($cd "{t3}" && "{lx_bin}" install) ? { Ok v -> v; _ -> {out: "" err: "" code: 1} }
assert (iv3.code == 0)

lc3 = ($test -e "{t3}/.lx/deps/my-dep") ? { Ok v -> v.code; _ -> 1 }
assert (lc3 == 0)

fc3 = ($test -f "{t3}/lx.lock") ? { Ok v -> v.code; _ -> 1 }
assert (fc3 == 0)

lock3 = $^cat "{t3}/lx.lock" | trim
assert (lock3 | contains? "my-dep")
assert (lock3 | contains? "path+")

-- Test 4: re-install is idempotent
rv4 = ($cd "{t3}" && "{lx_bin}" install) ? { Ok v -> v; _ -> {out: "" code: 1} }
assert (rv4.code == 0)

-- Test 5: update works on path dep
uv5 = ($cd "{t3}" && "{lx_bin}" update) ? { Ok v -> v; _ -> {out: "" code: 1} }
assert (uv5.code == 0)

$^rm -rf "{t3}"

-- Test 6: module resolution works with installed dep
t6 = $^mktemp -d | trim
$^mkdir -p "{t6}/mylib"
$^printf '+add_one = (n) n + 1\n' > "{t6}/mylib/math.lx"
lp6 = t6 ++ "/mylib"
dl6 = "mylib = " ++ ob ++ " path = \"" ++ lp6 ++ "\" " ++ cb
$echo '[package]' > "{t6}/lx.toml"
$echo 'name = "test-proj"' >> "{t6}/lx.toml"
$echo 'version = "0.1.0"' >> "{t6}/lx.toml"
$echo '' >> "{t6}/lx.toml"
$echo '[dependencies]' >> "{t6}/lx.toml"
$echo '{dl6}' >> "{t6}/lx.toml"

$cd "{t6}" && "{lx_bin}" install
$^printf 'use mylib/math\nassert (math.add_one 5 == 6)\n' > "{t6}/test.lx"
rv6 = ($cd "{t6}" && "{lx_bin}" run test.lx) ? { Ok v -> v; _ -> {out: "" err: "" code: 1} }
assert (rv6.code == 0)

$^rm -rf "{t6}"

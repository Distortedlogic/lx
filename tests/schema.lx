-- schema tests
-- verifies schema.define, schema.validate, schema.validate_all, schema.check, Schema keyword

use std/schema

-- 1. required field present
s1 = schema.define "S1" {name: true}
r1 = schema.validate s1 {name: "alice"}
assert (ok? r1)

-- 2. required field missing
r2 = schema.validate s1 {:}
assert (err? r2)
err2 = r2 ? { Err e -> e; Ok _ -> {} }
assert err2.field == "name"

-- 3. default filling
s3 = schema.define "S3" {role: {default: "guest"}}
r3 = schema.validate s3 {:}
val3 = r3 ?? {}
assert val3.role == "guest"

-- 4. one_of constraint — valid
s4 = schema.define "S4" {level: {one_of: ["a", "b"]}}
r4a = schema.validate s4 {level: "a"}
assert (ok? r4a)

-- 4b. one_of constraint — invalid
r4b = schema.validate s4 {level: "c"}
assert (err? r4b)

-- 5. custom check — pass
pos_check = (v) v > 0
check_spec = {required: true, check: pos_check}
s5 = schema.define "S5" {count: check_spec}
r5a = schema.validate s5 {count: 5}
assert (ok? r5a)

-- 5b. custom check — fail
r5b = schema.validate s5 {count: 0 - 1}
assert (err? r5b)

-- 6. validate_all collects multiple failures
s6 = schema.define "S6" {a: true, b: true}
r6 = schema.validate_all s6 {:}
errs6 = r6 ? { Err e -> e; Ok _ -> [] }
assert (len errs6 == 2)

-- 7. schema.check returns Bool
s7 = schema.define "S7" {x: true}
assert (schema.check s7 {x: 1} == true)
assert (schema.check s7 {:} == false)

-- 8. extra fields preserved
s8 = schema.define "S8" {a: true}
r8 = schema.validate s8 {a: 1, b: 2, c: 3}
val8 = r8 ?? {}
assert val8.a == 1
assert val8.b == 2
assert val8.c == 3

-- 9. Schema keyword generates class with schema() method
Schema Bounded = {
  score: Float = "0.0 to 1.0 confidence score"
}

b = Bounded {score: 0.5}
assert (b.score == 0.5)
s_bounded = b.schema ()
assert (s_bounded.type == "object")
assert (s_bounded.properties.score.type == "number")
assert (s_bounded.properties.score.description == "0.0 to 1.0 confidence score")

-- 10. Schema keyword with field descriptions
Schema UserProfile = {
  name: Str = "the user's full name"
  age: Int = "age in years"
  email: Str = "contact email"
}

user = UserProfile {name: "Alice"; age: 30; email: "a@b.com"}
assert user.name == "Alice"
assert user.age == 30

-- 64_git.lx
-- Tests: pkg/kit/git (shell-based git wrapper)

use pkg/kit/git

assert (git.is_repo () == true) "is_repo in git repo"

r = git.root ()
assert ((r | len) > 0) "root returns non-empty path"

b = git.branch ()
assert ((b | len) > 0) "branch returns name"

commits = git.log {:}
assert ((commits | len) > 0) "log returns commits"

brs = git.branches ()
assert ((brs | len) > 0) "branches returns at least one"

rems = git.remotes ()
assert (type_of rems == "List") "remotes returns list"

log.info "64_git: all passed"

-- 61_context.lx
-- Tests: ContextWindow class (context window capacity management)

use pkg/context {ContextWindow estimate}

-- === Create window ===
win = ContextWindow {capacity: 1000}
usage = win.usage ()
assert (usage.capacity == 1000) "capacity set"
assert (usage.used == 0) "initial used 0"
assert (usage.available == 1000) "initial available"
assert (usage.pct == 0.0) "initial pct 0"
assert (win.pressure () == "low") "initial pressure low"

-- === Add items ===
win.add {key: "system" content: "You are a helpful assistant" tokens: 100} ^
win.add {key: "turn_1" content: "Hello world" tokens: 200} ^
usage2 = win.usage ()
assert (usage2.used == 300) "used after add"
assert (usage2.available == 700) "available after add"

-- === Estimate tokens ===
est = estimate "hello world this is a test string for estimation"
assert (est > 0) "estimate positive"

-- === Items listing ===
items = win.items ()
assert (len items == 2) "2 items"
assert (items.[0].key == "system") "first item is system"
assert (items.[1].key == "turn_1") "second item is turn_1"

-- === Get item ===
got = win.get "system" ?? {key: "none"}
assert (got.key == "system") "get finds item"
assert (got.tokens == 100) "get has tokens"
assert (got.pinned == false) "not pinned initially"

missing = win.get "nonexistent"
assert (missing == None) "get returns None for missing"

-- === Pin / Unpin ===
win.pin "system" ^
got2 = win.get "system" ?? {pinned: false}
assert (got2.pinned == true) "pinned after pin"

win.unpin "system" ^
got3 = win.get "system" ?? {pinned: true}
assert (got3.pinned == false) "unpinned after unpin"

-- === Remove ===
win.remove "turn_1"
items2 = win.items ()
assert (len items2 == 1) "1 item after remove"
assert (items2.[0].key == "system") "system remains"

-- === Clear (preserves pinned) ===
win.add {key: "a" content: "aaa" tokens: 50} ^
win.add {key: "b" content: "bbb" tokens: 50} ^
win.pin "system" ^
win.clear () ^
items3 = win.items ()
assert (len items3 == 1) "clear keeps pinned"
assert (items3.[0].key == "system") "pinned system kept"

-- === Pressure levels ===
big_win = ContextWindow {capacity: 100}
assert (big_win.pressure () == "low") "0% is low"

big_win.add {key: "a" tokens: 55} ^
assert (big_win.pressure () == "moderate") "55% is moderate"

big_win.add {key: "b" tokens: 25} ^
assert (big_win.pressure () == "high") "80% is high"

big_win.add {key: "c" tokens: 15} ^
assert (big_win.pressure () == "critical") "95% is critical"

-- === Evict oldest ===
ev_win = ContextWindow {capacity: 1000}
ev_win.add {key: "old" content: "old" tokens: 100} ^
ev_win.add {key: "mid" content: "mid" tokens: 100} ^
ev_win.add {key: "new" content: "new" tokens: 100} ^
ev_win.evict "oldest" ^
ev_items = ev_win.items ()
assert (len ev_items == 2) "one evicted"
assert (ev_items.[0].key == "mid") "oldest removed"

-- === Evict lowest priority ===
pr_win = ContextWindow {capacity: 1000}
pr_win.add {key: "hi" content: "hi" tokens: 100 priority: "high"} ^
pr_win.add {key: "lo" content: "lo" tokens: 100 priority: "low"} ^
pr_win.add {key: "norm" content: "norm" tokens: 100 priority: "normal"} ^
pr_win.evict "lowest_priority" ^
pr_items = pr_win.items ()
assert (len pr_items == 2) "one evicted"
first_keys = pr_items | map (.key)
assert (first_keys.[0] == "hi") "low priority removed first"

-- === Evict largest ===
lg_win = ContextWindow {capacity: 1000}
lg_win.add {key: "small" content: "s" tokens: 50} ^
lg_win.add {key: "big" content: "b" tokens: 500} ^
lg_win.add {key: "med" content: "m" tokens: 200} ^
lg_win.evict "largest" ^
lg_items = lg_win.items ()
assert (len lg_items == 2) "one evicted"
lg_keys = lg_items | map (.key)
assert (lg_keys.[0] == "small") "largest removed"

-- === Evict respects pinned ===
pin_win = ContextWindow {capacity: 1000}
pin_win.add {key: "pinned_old" tokens: 100} ^
pin_win.add {key: "unpinned" tokens: 100} ^
pin_win.pin "pinned_old" ^
pin_win.evict "oldest" ^
pin_items = pin_win.items ()
assert (len pin_items == 1) "one evicted"
assert (pin_items.[0].key == "pinned_old") "pinned item survives eviction"

-- === Evict until ===
eu_win = ContextWindow {capacity: 100}
eu_win.add {key: "a" tokens: 30} ^
eu_win.add {key: "b" tokens: 30} ^
eu_win.add {key: "c" tokens: 30} ^
assert (eu_win.usage () | (.pct) == 90.0) "90% before evict_until"
eu_win.evict_until "oldest" {target_pct: 50.0} ^
eu_usage = eu_win.usage ()
assert (eu_usage.pct <= 50.0) "under 50% after evict_until"

-- === Replace item by key ===
rep_win = ContextWindow {capacity: 1000}
rep_win.add {key: "x" content: "old" tokens: 100} ^
rep_win.add {key: "x" content: "new" tokens: 200} ^
rep_items = rep_win.items ()
assert (len rep_items == 1) "replaced item, not duplicated"
rep_got = rep_win.get "x" ?? {tokens: 0}
assert (rep_got.tokens == 200) "replacement has new tokens"

log.info "61_context: all passed"

use std/flow

-- Test 1: flow.load
f = flow.load "tests/fixtures/flow_double.lx" ^
assert (f.__flow == "single") "flow has __flow marker"
assert (f.exports | contains? "run") "flow has run export"

-- Test 2: flow.run on single flow
result = flow.run f {x: 5} ^
assert (result == 10) "flow.run returns 10"

-- Test 3: flow.run different input
result2 = flow.run f {x: 7} ^
assert (result2 == 14) "flow.run returns 14"

-- Test 4: flow.pipe sequential composition
f_double = flow.load "tests/fixtures/flow_double.lx" ^
f_add = flow.load "tests/fixtures/flow_add_ten.lx" ^
pipeline = flow.pipe [f_double f_add]
result3 = flow.run pipeline {x: 5} ^
assert (result3 == 20) "pipe: double(5)=10, add_ten(10)=20"

-- Test 5: flow.parallel parallel composition
par_flows = flow.parallel [f_double f_double]
results4 = flow.run par_flows {x: 3} ^
assert (results4 | len == 2) "par: two results"
assert (results4 | first ^ == 6) "par: first is 6"
assert (results4 | last ^ == 6) "par: second is 6"

-- Test 6: flow.branch conditional routing
f_double2 = flow.load "tests/fixtures/flow_double.lx" ^
branch_flow = flow.branch (input) f_double2
result5 = flow.run branch_flow {x: 4} ^
assert (result5 == 8) "branch: routes to double"

-- Test 7: flow.with_fallback
f_fail = flow.load "tests/fixtures/flow_failing.lx" ^
resilient = f_fail | flow.with_fallback f_double
result6 = flow.run resilient {x: 5} ^
assert (result6 == 10) "fallback: uses fallback on failure"

-- Test 8: flow.with_timeout (passes within timeout)
timed = f_double | flow.with_timeout 300
result7 = flow.run timed {x: 6} ^
assert (result7 == 12) "timeout: completes within timeout"

-- Test 9: flow.with_retry (succeeds on first try)
retried = f_double | flow.with_retry {max: 3}
result8 = flow.run retried {x: 7} ^
assert (result8 == 14) "retry: succeeds on first try"

-- Test 10: chained decorators
decorated = f_double
  | flow.with_timeout 300
  | flow.with_retry {max: 2}
result9 = flow.run decorated {x: 4} ^
assert (result9 == 8) "chained decorators work"

log.info "74_flow: all passed"

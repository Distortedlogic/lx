-- agent trait tests
-- verifies default handle, run, subscribes methods on Agent trait

-- default handle returns its input
Agent EchoAgent = {}
ea = EchoAgent {}
assert (ea.handle "hello" == "hello") "default handle returns msg"
assert (ea.handle 42 == 42) "default handle returns any value"

-- default run returns unit
Agent RunAgent = {}
ra = RunAgent {}
assert (ra.run () == ()) "default run returns unit"

-- default subscribes returns empty list
Agent SubAgent = {}
sa = SubAgent {}
assert (sa.subscribes () == []) "default subscribes returns empty list"

-- custom handle overrides default
Agent UpperAgent = {
  handle = (msg) { {echo: msg} }
}
ua = UpperAgent {}
assert ((ua.handle "hi").echo == "hi") "custom handle works"

-- custom subscribes
Agent EventAgent = {
  subscribes = () { ["events"; "logs"] }
}
eva = EventAgent {}
assert (eva.subscribes () == ["events"; "logs"]) "custom subscribes"

-- agent implements Agent trait
assert (agent.implements ua Agent) "agent implements Agent trait"

-- methods_of includes handle, run, subscribes
methods = methods_of ua
assert (methods | any? (== "handle")) "methods include handle"
assert (methods | any? (== "run")) "methods include run"
assert (methods | any? (== "subscribes")) "methods include subscribes"

emit "agent_trait: all checks passed"

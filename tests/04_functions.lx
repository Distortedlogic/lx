-- 04_functions.lx
-- Tests: spec/syntax.md (Functions, Closures, Recursion, Sections, Composition)
-- Phase: 2 (Functions, Pipes, Sections)

-- basic function definition
double = (x) x * 2
assert (double 5 == 10)

-- multi-parameter function
add = (x y) x + y
assert (add 3 4 == 7)

-- function with block body
process = (x) {
  tmp = x * 2
  tmp + 1
}
assert (process 5 == 11)

-- nullary function
greeting = () "hello"
assert (greeting () == "hello")

-- auto-currying (all-positional, no defaults)
add3 = add 3
assert (add3 7 == 10)
assert (add3 0 == 3)

-- currying chain
mul = (a b c) a * b * c
mul2 = mul 2
mul2_3 = mul2 3
assert (mul2_3 4 == 24)

-- default parameters
greet = (name  greeting = "hello") "{greeting} {name}"
assert (greet "alice" == "hello alice")
assert (greet "bob" greeting: "hi" == "hi bob")

-- closures capture scope
make_adder = (n) (x) x + n
add5 = make_adder 5
assert (add5 10 == 15)
assert (add5 0 == 5)

-- closures over mutable state
counter = () {
  n := 0
  {
    inc: () { n <- n + 1; n }
    get: () n
  }
}
c = counter ()
assert (c.inc () == 1)
assert (c.inc () == 2)
assert (c.inc () == 3)
assert (c.get () == 3)

-- recursion
factorial = (n) n ? {
  0 -> 1
  n -> n * factorial (n - 1)
}
assert (factorial 0 == 1)
assert (factorial 5 == 120)
assert (factorial 10 == 3628800)

-- tail-recursive factorial
fact_tc = (n  acc = 1) n ? {
  0 -> acc
  n -> fact_tc (n - 1) (n * acc)
}
assert (fact_tc 5 == 120)
assert (fact_tc 20 == 2432902008176640000)

-- sections (right)
assert ((+ 1) 5 == 6)
assert ((* 2) 3 == 6)
assert ((> 0) 5 == true)
assert ((> 0) (-1) == false)
assert ((== "a") "a" == true)
assert ((== "a") "b" == false)

-- sections (left)
assert ((10 -) 3 == 7)
assert ((100 /) 4 == 25.0)

-- field sections
p = {x: 3  y: 4}
get_x = (.x)
assert (get_x p == 3)

-- higher-order functions
apply = (f x) f x
assert (apply double 5 == 10)
assert (apply (+ 3) 10 == 13)

-- function as value
sub3 = (x) x - 3
ops = [(+ 1) (* 2) sub3]
assert (ops.0 5 == 6)
assert (ops.1 5 == 10)
assert (ops.2 5 == 2)

-- identity
assert (identity 42 == 42)
assert (identity "hello" == "hello")

-- not as function (pipeable)
is_positive = (> 0)
is_non_positive = (x) x | is_positive | not
assert (is_non_positive 0 == true)
assert (is_non_positive (-1) == true)
assert (is_non_positive 5 == false)

-- 54_agent_dispatch.lx
-- Tests: spec/agents-dispatch.md (dispatch, dispatch_multi)
-- Phase: Pattern-based message routing

use pkg/agents/dispatch_rules {dispatch dispatch_multi}
use pkg/agents/intercept {intercept}

-- setup target agents
security_agent = {handler: (msg) {domain: "security" result: "sec_handled"}}
perf_agent = {handler: (msg) {domain: "perf" result: "perf_handled"}}
general_agent = {handler: (msg) {domain: "general" result: "gen_handled"}}

-- basic dispatch: first match wins
dispatcher = dispatch [
  {match: {domain: "security"} to: security_agent}
  {match: {domain: "performance"} to: perf_agent}
  {match: "default" to: general_agent}
]

r1 = dispatcher ~>? {domain: "security" task: "audit"}
assert (r1.result == "sec_handled") "dispatch routes to security"

r2 = dispatcher ~>? {domain: "performance" task: "profile"}
assert (r2.result == "perf_handled") "dispatch routes to perf"

r3 = dispatcher ~>? {domain: "other" task: "misc"}
assert (r3.result == "gen_handled") "dispatch falls back to default"

-- no match returns Err
strict = dispatch [
  {match: {domain: "security"} to: security_agent}
]
no_match = strict ~>? {domain: "unknown"}
assert (no_match == Err {type: "no_route" message: {domain: "unknown"}}) "no match returns Err"

-- function predicate matching
fn_dispatch = dispatch [
  {match: (msg) msg.value > 100 to: (msg) {size: "big"  value: msg.value}}
  {match: "default" to: (msg) {size: "small"  value: msg.value}}
]
assert ((fn_dispatch ~>? {value: 200}).size == "big") "fn predicate matches"
assert ((fn_dispatch ~>? {value: 5}).size == "small") "fn predicate rejects"

-- dispatch with transform
transforming = dispatch [
  {match: "default" to: general_agent transform: (msg) {domain: msg.raw_domain}}
]
r4 = transforming ~>? {raw_domain: "general"}
assert (r4.result == "gen_handled") "dispatch transforms message"

-- dispatch_multi: fan-out to all matches
multi = dispatch_multi [
  {match: {needs_security: true} to: security_agent}
  {match: {needs_perf: true} to: perf_agent}
  {match: "default" to: general_agent}
]
results = multi ~>? {needs_security: true  needs_perf: true  task: "review"}
assert (results | len == 3) "dispatch_multi hits all matching rules"
assert (results.0.result.result == "sec_handled") "multi first result is security"
assert (results.1.result.result == "perf_handled") "multi second result is perf"

-- dispatch with intercept composition
traced = intercept dispatcher (msg next) {
  result = next msg
  {..result  traced: true}
}
r5 = traced ~>? {domain: "security"}
assert (r5.result == "sec_handled") "intercepted dispatch works"
assert (r5.traced == true) "intercepted dispatch traced"

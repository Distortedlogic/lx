-- active bug probes from agent/BUGS.md
-- BUG-FIXED asserts pass when resolved, fail when regressed

use std/agent {Agent}

-- closures inside + functions drop non-exported module bindings
helper_mul = (x) x * 3
+exported_map = (items) {
  items | map (x) { helper_mul x }
}
assert (exported_map [1; 2; 3] == [3; 6; 9]) "BUG-FIXED: closure capture in + function"

helper_add = (x) x + 10
acc := []
+exported_each = (items) {
  items | each (x) {
    v = helper_add x
    acc <- acc ++ [v]
  }
}
exported_each [1; 2]
assert (acc == [11; 12]) "BUG-FIXED: each closure capture in + function"

-- Agent Trait defaults not injected into Class : [Agent]
Class BareAgent : [Agent] = {
  role = () { "test" }
  goal = () { "test" }
}
ba = BareAgent {}
assert (methods_of ba | any? (== "think") == true) "BUG-FIXED: Agent think injected"
assert (methods_of ba | any? (== "handle") == true) "BUG-FIXED: Agent handle injected"
assert (methods_of ba | any? (== "think_with") == true) "BUG-FIXED: Agent think_with injected"

-- tuple destructuring in HOF chains
probe_destr = try (() {
  [("x"; 10); ("y"; 20)] | map (name val) { "{name}:{val}" }
}) ()
destr_works = probe_destr ? { Err _ -> false; _ -> probe_destr == ["x:10"; "y:20"] }
assert (destr_works == true) "BUG-FIXED: tuple destructuring in HOF map"

emit "bugs_active: all checks passed"

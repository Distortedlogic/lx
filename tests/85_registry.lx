-- 85_registry.lx
-- Tests: pkg/agents/registry (Store-backed agent discovery)

use pkg/agents/registry

reg = registry.start ()
assert (reg.started == true) "start returns started registry"

r1 = registry.register reg {name: "worker-1" traits: ["Reviewer"] domains: ["code"]}
assert (r1 | ok?) "register returns Ok"

r2 = registry.register reg {name: "worker-2" traits: ["Analyzer"] domains: ["perf"]}
assert (r2 | ok?) "register second agent"

found = registry.find reg {trait: "Reviewer"}
assert (found | len == 1) "find by trait returns 1"

found_all = registry.find reg {:}
assert (found_all | len == 2) "find all returns 2"

one = registry.find_one reg {trait: "Analyzer"}
assert (one != None) "find_one returns Some"

d = registry.deregister reg "worker-1"
assert (d | ok?) "deregister returns Ok"

found2 = registry.find reg {:}
assert (found2 | len == 1) "after deregister: 1 remaining"

registry.stop reg

log.info "85_registry: all passed"

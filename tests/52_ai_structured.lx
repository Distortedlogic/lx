-- 52_ai_structured.lx
-- Tests: spec/agents-structured-output.md (ai.prompt_structured)
-- Phase: ai.prompt_structured, ai.prompt_structured_with
-- Note: Does not call AI backend (would invoke Claude CLI).
--       Tests Trait validation and function existence only.


-- Define test Traits for structured output
Trait AnalysisResult = {
  findings: List
  severity: Str
  confidence: Float = 0.0
}

-- Trait used for structured output validates correctly
a = AnalysisResult {findings: ["bug1" "bug2"] severity: "high" confidence: 0.95}
assert (a.findings | len == 2) "trait findings populated"
assert (a.severity == "high") "trait severity"
assert (a.confidence == 0.95) "trait confidence"

-- Trait fills defaults
b = AnalysisResult {findings: [] severity: "low"}
assert (b.confidence == 0.0) "trait default confidence"

-- ai.prompt_structured is a callable (verify existence)
assert (type_of ai.prompt_structured == "Func") "prompt_structured is a function"
assert (type_of ai.prompt_structured_with == "Func") "prompt_structured_with is a function"

-- Partial application works (does not call AI backend)
partial = ai.prompt_structured AnalysisResult
assert (type_of partial == "Func") "prompt_structured partial application"

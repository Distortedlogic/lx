use std/tool {Tool}

Class Echo : [Tool] = {
  description: "echoes input"
  params: {text: "Str"}
  run = (args) { Ok args.text }
}

t = Echo {}
assert t.description == "echoes input"
s = t.schema ()
assert (s | keys | len == 1)
assert s.text == "Str"
result = t.run {text: "hello"}
assert result == Ok "hello"
valid = t.validate {text: "hi"}
assert (valid | ok?)
invalid = t.validate {wrong: 1}
assert (invalid | err?)

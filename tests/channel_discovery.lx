-- channel discovery tests
-- verifies channel declaration, auto-subscribe on spawn, members, subscribe

channel workers

Agent Fast = {
  subscribes = [workers]
  handle = (msg) { {from: "Fast", result: msg.task} }
}

spawn Fast

peers = workers.members
assert (len peers) == 1

r1 = "Fast" ~>? {task: "compute"}
assert r1.result == "compute"

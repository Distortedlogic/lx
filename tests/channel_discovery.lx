-- channel discovery tests
-- verifies channel declaration, auto-subscribe on spawn, members, subscribe

channel workers

Agent Fast = {
  subscribes = [workers]
  handle = (msg) { {from: "Fast", result: msg.task} }
}

Agent Slow = {
  subscribes = [workers]
  handle = (msg) { {from: "Slow", result: msg.task} }
}

spawn Fast
spawn Slow

peers = workers.members
assert (len peers) == 2

results = peers | map (p) { ask p {task: "compute"} }
assert (len results) == 2

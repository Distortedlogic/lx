-- 55_protocol_ext.lx
-- Tests: spec/agents-protocol-ext.md (composition, unions, field constraints)
-- Phase: Protocol extensions

-- ============================================================
-- Protocol composition: {..Base extra: Str}
-- ============================================================

Protocol Base = {name: Str  severity: Str  source: Str}

-- basic spread
Protocol PerfFinding = {..Base  location: Str  issue: Str  fix: Str}

pf = PerfFinding {name: "slow-query"  severity: "high"  source: "profiler"  location: "db.rs"  issue: "N+1"  fix: "batch"}
assert (pf.name == "slow-query") "spread inherits base fields"
assert (pf.location == "db.rs") "spread includes own fields"

-- spread with default override
Protocol DefaultBase = {name: Str  severity: Str = "low"}
Protocol Critical = {..DefaultBase  severity: Str = "critical"}

c = Critical {name: "vuln"}
assert (c.severity == "critical") "spread overrides default"

-- spread with default inheritance
Protocol Inherited = {..DefaultBase  extra: Str}
ih = Inherited {name: "test"  extra: "data"}
assert (ih.severity == "low") "spread inherits defaults from base"
assert (ih.extra == "data") "own fields work"

-- multiple bases
Protocol Named = {name: Str  description: Str}
Protocol Scored = {score: Float  confidence: Float}
Protocol ScoredCandidate = {..Named  ..Scored  url: Str}

sc = ScoredCandidate {name: "result"  description: "good"  score: 0.9  confidence: 0.8  url: "https://x"}
assert (sc.name == "result") "multiple bases: first base field"
assert (sc.score == 0.9) "multiple bases: second base field"
assert (sc.url == "https://x") "multiple bases: own field"

-- later fields override spread fields
Protocol Override = {..Base  severity: Str = "override_default"  extra: Int}
ov = Override {name: "test"  source: "me"  extra: 42}
assert (ov.severity == "override_default") "own field overrides spread"

-- ============================================================
-- Protocol unions: Protocol Msg = A | B | C
-- ============================================================

Protocol ReviewRequest = {task: Str  path: Str}
Protocol AuditRequest = {severity: Str  scope: Str}
Protocol CanHandle = {task: Any}

Protocol AgentMessage = ReviewRequest | AuditRequest | CanHandle

-- match ReviewRequest (has task + path)
m1 = AgentMessage {task: "review"  path: "src/"}
assert (m1._variant == "ReviewRequest") "union matches first fitting variant"
assert (m1.task == "review") "union preserves fields"

-- match AuditRequest (has severity + scope)
m2 = AgentMessage {severity: "high"  scope: "all"}
assert (m2._variant == "AuditRequest") "union matches second variant"

-- match CanHandle (has task: Any, but no path -> not ReviewRequest)
m3 = AgentMessage {task: 42}
assert (m3._variant == "CanHandle") "union falls through to matching variant"

-- handler dispatch on _variant
handle = (msg) {
  msg._variant ? {
    "ReviewRequest" -> "reviewing"
    "AuditRequest"  -> "auditing"
    "CanHandle"     -> "can_handle"
    _               -> "unknown"
  }
}
assert ((handle m1) == "reviewing") "variant dispatch works"
assert ((handle m2) == "auditing") "variant dispatch second"
assert ((handle m3) == "can_handle") "variant dispatch third"

-- ============================================================
-- Protocol field constraints: where clauses
-- ============================================================

Protocol AuditFinding = {
  severity: Str where severity == "low" || severity == "medium" || severity == "high" || severity == "critical"
  score: Float where score >= 0.0 && score <= 1.0
  name: Str where (len name) > 0
}

af = AuditFinding {severity: "high"  score: 0.85  name: "buffer overflow"}
assert (af.severity == "high") "constraint passes valid severity"
assert (af.score == 0.85) "constraint passes valid score"

-- constraint with boundary values
af2 = AuditFinding {severity: "low"  score: 0.0  name: "x"}
assert (af2.score == 0.0) "constraint passes boundary score 0.0"

af3 = AuditFinding {severity: "critical"  score: 1.0  name: "urgent"}
assert (af3.score == 1.0) "constraint passes boundary score 1.0"

-- constraint with default: field gets default, constraint on other fields still checked
Protocol Constrained = {
  level: Int where level > 0 && level <= 10
  label: Str = "default"
}
cv = Constrained {level: 5}
assert (cv.level == 5) "constraint passes with default on other field"
assert (cv.label == "default") "default filled alongside constraint"

-- ============================================================
-- Composition + union combined
-- ============================================================

Protocol FindingBase = {name: Str  severity: Str = "medium"}
Protocol SecurityFinding = {..FindingBase  cve: Str}
Protocol PerfIssue = {..FindingBase  latency_ms: Int}

Protocol Finding = SecurityFinding | PerfIssue

f1 = Finding {name: "xss"  cve: "CVE-2024-1234"}
assert (f1._variant == "SecurityFinding") "composition + union: security variant"
assert (f1.severity == "medium") "composition + union: inherits default"

f2 = Finding {name: "slow"  latency_ms: 500}
assert (f2._variant == "PerfIssue") "composition + union: perf variant"

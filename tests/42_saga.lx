use std/saga

noop = (r) ()

-- === Basic saga: all steps succeed ===

steps = [
  {id: "a" do: (prev) "result_a" undo: noop}
  {id: "b" do: (prev) "result_b:{prev.a}" undo: noop}
  {id: "c" do: (prev) "result_c:{prev.b}" undo: noop}
]

result = saga.run steps ^
assert (result.a == "result_a") "basic: step a result"
assert (result.b == "result_b:result_a") "basic: step b receives prev"
assert (result.c == "result_c:result_b:result_a") "basic: step c receives prev chain"

-- === Step failure triggers compensation ===

undo_log := []
undo_track = (r) { undo_log <- undo_log ++ [r] }
do_fail = (prev) Err "z_failed"
fail_steps = [
  {id: "x" do: (prev) "x_done" undo: undo_track}
  {id: "y" do: (prev) "y_done" undo: undo_track}
  {id: "z" do: do_fail undo: noop}
]

fail_result = saga.run fail_steps
assert (err? fail_result == true) "failure: returns Err"
fail_info = fail_result ? { Err e -> e _ -> {} }
assert (fail_info.failed_step == "z") "failure: failed_step is z"
assert (fail_info.error == "z_failed") "failure: error message"
assert (len fail_info.compensated == 2) "failure: two steps compensated"
assert (len undo_log == 2) "failure: undo ran for x and y"
assert (undo_log.0 == "y_done") "failure: y undone first (reverse)"
assert (undo_log.1 == "x_done") "failure: x undone second"

-- === Compensation error recording ===

bad_undo = (r) Err "undo_p_failed"
do_q_fail = (prev) Err "q_failed"
bad_undo_steps = [
  {id: "p" do: (prev) "p_done" undo: bad_undo}
  {id: "q" do: do_q_fail undo: noop}
]

bad_result = saga.run bad_undo_steps
bad_info = bad_result ? { Err e -> e _ -> {} }
assert (bad_info.failed_step == "q") "comp_err: failed at q"
assert (len bad_info.compensation_errors == 1) "comp_err: one undo failed"
assert (bad_info.compensation_errors.0.step == "p") "comp_err: p's undo failed"

-- === Dependencies ===

dep_steps = [
  {id: "d" do: (prev) "d:{prev.b}:{prev.c}" undo: noop depends: ["b" "c"]}
  {id: "b" do: (prev) "b_val" undo: noop depends: ["a"]}
  {id: "a" do: (prev) "a_val" undo: noop}
  {id: "c" do: (prev) "c_val" undo: noop depends: ["a"]}
]

dep_result = saga.run dep_steps ^
assert (dep_result.a == "a_val") "deps: a ran"
assert (dep_result.d == "d:b_val:c_val") "deps: d got b and c results"

-- === saga.define + saga.execute ===

my_saga = saga.define [
  {id: "s1" do: (prev) "s1:{prev.seed}" undo: noop}
  {id: "s2" do: (prev) "s2:{prev.s1}" undo: noop}
]

exec_result = saga.execute my_saga {seed: "hello"} ^
assert (exec_result.seed == "hello") "execute: initial context preserved"
assert (exec_result.s1 == "s1:hello") "execute: s1 used seed"
assert (exec_result.s2 == "s2:s1:hello") "execute: s2 chained"

-- === run_with max_retries ===

attempt_count := 0
do_flaky = (prev) {
  attempt_count <- attempt_count + 1
  attempt_count >= 3 ? {
    true -> "success"
    false -> Err "not yet"
  }
}
retry_steps = [
  {id: "flaky" do: do_flaky undo: noop}
]

retry_result = saga.run_with retry_steps {max_retries: 4}
assert (ok? retry_result == true) "retry: succeeds after retries"
assert (attempt_count >= 3) "retry: took multiple attempts"

-- === run_with on_compensate callback ===

comp_log := []
on_comp = (step_id result) { comp_log <- comp_log ++ [step_id] }
do_n_fail = (prev) Err "n_fail"
comp_steps = [
  {id: "m" do: (prev) "m_done" undo: noop}
  {id: "n" do: do_n_fail undo: noop}
]

saga.run_with comp_steps {on_compensate: on_comp}
assert (len comp_log == 1) "on_compensate: callback fired"
assert (comp_log.0 == "m") "on_compensate: got step id"

log.info "42_saga: all passed"

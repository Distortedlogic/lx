use pkg/kit/search

results = search.content "search\\.content" {path: "tests/103_search.lx"}
assert (results | len > 0) "found matches in self"
first = results.[0]
assert (first.file == "tests/103_search.lx") "file path correct"
assert (first.line > 0) "line number positive"
assert (first.text | contains? "search") "match text contains pattern"
assert (first.submatches | len > 0) "has submatches"
assert (first.col >= 0) "col is non-negative"

rust_results = search.content "fn build" {path: "crates/lx/src/stdlib"  type: "rust"}
assert (rust_results | len > 0) "found rust matches"
rust_first = rust_results.[0]
assert (rust_first.file | ends? ".rs") "rust file extension"

lx_files = search.files "" {path: "tests"  glob: "*.lx"}
assert (lx_files | len > 0) "found .lx files"
has_self = lx_files | any? (f) { f.file | contains? "103_search" }
assert (has_self) "files list includes this test"

counts = search.count "fn build" {path: "crates/lx/src/stdlib"  type: "rust"}
assert (counts | len > 0) "found count results"
first_count = counts.[0]
assert (first_count.count > 0) "count is positive"
assert (first_count.file | ends? ".rs") "count file is rust"

replacements = search.replace "search\\.content" "search.find" {path: "tests/103_search.lx"}
assert (replacements | len > 0) "found replacements"
first_rep = replacements.[0]
assert (first_rep.old | contains? "search") "old text has pattern"
assert (first_rep.new | contains? "find") "new text has replacement"

ci_results = search.content "SEARCH" {path: "tests/103_search.lx"  case_insensitive: true}
assert (ci_results | len > 0) "case insensitive search works"

no_results = search.content "zzz_nonexistent_pattern_zzz" {path: "tests/103_search.lx"}
assert (no_results | len == 0) "no matches for garbage pattern"

log.info "103_search: all passed"

use std/ws

result = ws.connect "wss://echo.websocket.events"
result ? {
  Ok conn -> {
    ws.send conn "hello from lx" ^

    reply = ws.recv conn ^
    assert (reply == "hello from lx") "echo matches"

    ws.close conn ^
    log.info "99_ws: echo test passed"
  }
  Err e -> {
    log.info "99_ws: skipped (no network: {e})"
  }
}

log.info "99_ws: all passed"

-- === basic field binding ===
dl = with context deadline: 30 request_id: "abc" {
  context.deadline
}
rid = with context deadline: 30 request_id: "abc" {
  context.request_id
}
assert (dl == 30) "deadline bound"
assert (rid == "abc") "request_id bound"

-- === context.current returns full record ===
cur = with context budget: 100 trace_id: "xyz" {
  context.current ()
}
assert (cur.budget == 100) "current has budget"
assert (cur.trace_id == "xyz") "current has trace_id"

-- === context.get returns Some/None ===
found = with context team: "backend" {
  context.get "team"
}
assert (found == Some "backend") "get returns Some for present key"

missing = with context team: "backend" {
  context.get "missing"
}
assert (missing == None) "get returns None for missing key"

-- === nesting overrides and restores ===
nested = with context budget: 1000 deadline: 60 {
  inner_budget = with context budget: 200 {
    context.budget
  }
  inner_deadline = with context budget: 200 {
    context.deadline
  }
  {inner_budget: inner_budget  inner_deadline: inner_deadline  outer_budget: context.budget  outer_deadline: context.deadline}
}
assert (nested.inner_budget == 200) "inner budget overridden"
assert (nested.inner_deadline == 60) "inner deadline inherited"
assert (nested.outer_budget == 1000) "outer budget restored"
assert (nested.outer_deadline == 60) "outer deadline same"

-- === empty context (no fields = clear ambient) ===
empty = with context {
  context.current ()
}
assert (len (keys empty) == 0) "empty context has no fields"

-- === context visible in called functions ===
read_ctx = () {
  context.current ()
}
from_fn = with context env: "staging" {
  read_ctx ()
}
assert (from_fn.env == "staging") "context visible in called fn"

-- === context propagates through nested calls ===
inner_fn = () { context.current () }
outer_fn = () { inner_fn () }
deep = with context depth: 3 {
  outer_fn ()
}
assert (deep.depth == 3) "context flows through nested calls"

-- === expression values ===
base = 10
expr_val = with context limit: (base * 5) {
  context.limit
}
assert (expr_val == 50) "expression values evaluated"

-- === context.current excludes internal keys ===
cur2 = with context x: 1 y: 2 {
  context.current ()
}
assert (cur2.x == 1) "current has x"
assert (cur2.y == 2) "current has y"

-- === context outside with context ===
outer_ctx = context.current ()
assert (len (keys outer_ctx) == 0) "context.current outside scope is empty"

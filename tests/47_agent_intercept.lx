-- 47_agent_intercept.lx
-- Tests: spec/agents-intercept.md (message middleware)
-- Phase: intercept

use std/agent
use pkg/agents/intercept {intercept}

-- basic intercept: middleware transforms message before forwarding
doubler = {handler: (msg) msg.value * 2}
enriched = intercept doubler (msg next) {
  next {value: msg.value + 10}
}
assert (enriched ~>? {value: 5} == 30) "intercept transforms message"

-- intercept preserves original agent
assert (doubler ~>? {value: 5} == 10) "original agent unchanged"

-- intercept can modify response
logged = intercept doubler (msg next) {
  result = next msg
  {original: result  intercepted: true}
}
r = logged ~>? {value: 3}
assert (r.original == 6) "intercept can wrap response"
assert (r.intercepted == true) "intercept adds metadata"

-- middleware can short-circuit (not call next)
gated = intercept doubler (msg next) {
  msg.value > 0 ? {
    true -> next msg
    false -> Err "blocked: negative value"
  }
}
assert (gated ~>? {value: 5} == 10) "gate allows positive"
assert (gated ~>? {value: -1} == Err "blocked: negative value") "gate blocks negative"

-- chained interceptors: compose by wrapping
worker = {handler: (msg) msg.x + 1}
step1 = intercept worker (msg next) {
  result = next msg
  result * 2
}
step2 = intercept step1 (msg next) {
  result = next msg
  result + 100
}
assert (step2 ~>? {x: 4} == 110) "chained: (4+1)*2+100=110"

-- intercept with send (~>) returns unit
side_agent = {handler: (msg) msg}
tracked = intercept side_agent (msg next) {
  next msg
}
assert (tracked ~> {action: "log"} == ()) "intercept with send returns unit"

-- intercept preserves non-handler fields
named_agent = {name: "worker" role: "analyst" handler: (x) x}
wrapped = intercept named_agent (msg next) {
  next msg
}
assert (wrapped.name == "worker") "intercept preserves name"
assert (wrapped.role == "analyst") "intercept preserves role"

-- middleware receives original message
spy = intercept doubler (msg next) {
  {saw_value: msg.value  result: (next msg)}
}
r2 = spy ~>? {value: 7}
assert (r2.saw_value == 7) "middleware sees original message"
assert (r2.result == 14) "middleware gets correct result"

MCP TestServer = {
  command: "echo"
  args: ["test"]
}

s = TestServer {}
assert s.command == "echo"
assert s.args == ["test"]
assert (methods_of s | any? (== "connect"))
assert (methods_of s | any? (== "disconnect"))
assert (methods_of s | any? (== "call"))
assert (methods_of s | any? (== "tools"))

-- 60_prompt.lx
-- Tests: std/prompt module (typed composable prompt assembly)

use pkg/core/prompt

has = (haystack needle) haystack | contains? needle

-- === Create empty prompt ===
p = prompt.create ()
text = prompt.render p
assert (text == "") "empty prompt renders empty"
assert (prompt.estimate p == 0) "empty prompt 0 tokens"

-- === System section ===
p2 = p | prompt.system "You are a code reviewer"
text2 = prompt.render p2
assert (text2 == "You are a code reviewer") "system renders"

-- === Add sections ===
p3 = p2
  | prompt.section "task" "Review this diff"
  | prompt.section "output_format" "Respond as JSON"
text3 = prompt.render p3
assert (has text3 "You are a code reviewer" == true) "has system"
assert (has text3 "Review this diff" == true) "has task section"
assert (has text3 "Respond as JSON" == true) "has output section"

-- === Constraints ===
p4 = p3
  | prompt.constraint "Focus on OWASP Top 10"
  | prompt.constraint "Ignore style issues"
text4 = prompt.render p4
assert (has text4 "Constraints:" == true) "has constraints header"
assert (has text4 "Focus on OWASP Top 10" == true) "has first constraint"
assert (has text4 "Ignore style issues" == true) "has second constraint"

-- === Instructions ===
p5 = p4 | prompt.instruction "Return empty array if no issues"
text5 = prompt.render p5
assert (has text5 "Instructions:" == true) "has instructions header"
assert (has text5 "Return empty array" == true) "has instruction"

-- === Examples ===
p6 = p3 | prompt.example {input: "bad code" output: "found issue"}
text6 = prompt.render p6
assert (has text6 "Examples:" == true) "has examples header"
assert (has text6 "bad code" == true) "has example input"
assert (has text6 "found issue" == true) "has example output"

-- === Sections listing ===
secs = prompt.sections p6
assert (len secs == 4) "4 sections: system, task, output_format, examples"
assert (secs.[0] == "system") "first is system"
assert (secs.[1] == "task") "second is task"

-- === Without ===
p7 = prompt.without p6 "examples"
text7 = prompt.render p7
assert (has text7 "Review this diff" == true) "still has task"
assert (has text7 "Examples:" == false) "examples removed"

p8 = prompt.without p5 ["constraints" "instructions"]
text8 = prompt.render p8
assert (has text8 "Constraints:" == false) "constraints removed"
assert (has text8 "Instructions:" == false) "instructions removed"

-- === Compose ===
base = prompt.create ()
  | prompt.system "You are a reviewer"
  | prompt.constraint "Be concise"

overlay = prompt.create ()
  | prompt.section "focus" "Security vulnerabilities"
  | prompt.constraint "Flag unsanitized input"

full = prompt.compose [base overlay]
text_full = prompt.render full
assert (has text_full "You are a reviewer" == true) "composed has system"
assert (has text_full "Security vulnerabilities" == true) "composed has overlay section"
assert (has text_full "Be concise" == true) "composed has base constraint"
assert (has text_full "Flag unsanitized input" == true) "composed has overlay constraint"

-- === Estimate ===
big = prompt.create ()
  | prompt.system "You are an expert analyst with deep knowledge"
  | prompt.section "task" "Analyze the following data carefully"
est = prompt.estimate big
assert (est > 0) "estimate is positive"

-- === Render within budget ===
with_ex = prompt.create ()
  | prompt.system "System"
  | prompt.section "task" "Do the thing"
  | prompt.example {input: "a very long example input that takes many tokens" output: "a very long example output"}
  | prompt.constraint "a constraint"

full_text = prompt.render with_ex
trimmed = prompt.render_within with_ex 10
assert (len trimmed < len full_text) "trimmed is shorter"
assert (has trimmed "System" == true) "trimmed keeps system"

-- === Immutability: original unmodified ===
orig = prompt.create () | prompt.system "Original"
modified = orig | prompt.constraint "Added"
orig_text = prompt.render orig
assert (has orig_text "Added" == false) "original unchanged after pipe"

log.info "60_prompt: all passed"

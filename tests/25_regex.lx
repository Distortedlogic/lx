use std/re

assert (re.is_match r/\d+/ "abc123" == true) "regex literal is_match"
assert (re.is_match r/^\d+$/ "abc123" == false) "regex literal full string"

m = re.match r/\d+/ "abc123def"
assert (m == Some {text: "123" start: 3 end: 6}) "regex literal match"

assert (re.match r/\d+/ "abcdef" == None) "regex literal no match"

found = re.find_all r/\d+/ "a1b22c333"
assert (found == ["1" "22" "333"]) "regex literal find_all"

r1 = re.replace r/\d+/ "X" "a1b2c3"
assert (r1 == "aXb2c3") "regex literal replace"

r2 = re.replace_all r/\d+/ "X" "a1b2c3"
assert (r2 == "aXbXcX") "regex literal replace_all"

parts = re.split r/[,;]/ "a,b;c,d"
assert (parts == ["a" "b" "c" "d"]) "regex literal split"

found2 = re.find_all r/[a-z]+/i "Hello World"
assert (found2 == ["Hello" "World"]) "regex literal with i flag"

piped = "phone: 555-1234, ext: 42" | re.find_all r/\d+/
assert (piped == ["555" "1234" "42"]) "regex literal in pipe"

assert (re.is_match r/hello/ "hello world" == true) "simple regex"
assert (re.is_match r/^hello$/ "hello world" == false) "anchored regex"

slash_re = r/foo\/bar/
assert (re.is_match slash_re "foo/bar" == true) "regex with escaped slash"

pat = r/\d+/
assert (to_str pat == "r/\\d+/") "regex display"

assert (re.is_match r/HELLO/i "hello" == true) "case insensitive flag"
assert (re.is_match r/^hello$\n^world$/m "hello\nworld" == true) "multiline flag"

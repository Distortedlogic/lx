use pkg/kit/repo

rp = repo.create "test-repo" {:}
assert (rp.name == "test-repo") "create sets name"
assert ((rp.root | len) > 0) "create resolves root"

s = repo.status rp
assert (type_of s == "Record") "status returns record"

locks = repo.locks rp
assert ((locks | len) == 0) "no locks initially"

l = repo.lock rp {target: "file_a.txt"  holder: "agent-1"}
assert (l | ok?) "lock returns Ok"

locks2 = repo.locks rp
assert ((locks2 | len) == 1) "one lock active"

l2 = repo.try_lock rp {target: "file_a.txt"  holder: "agent-2"}
assert (l2 == None) "conflicting lock returns None"

lock_id = (l ^).id
repo.unlock rp lock_id
locks3 = repo.locks rp
assert ((locks3 | len) == 0) "lock released"

log.info "98_repo: all passed"

-- 15_stdlib.lx
-- Tests: std/ module import infrastructure + std/json, std/math, pkg/data/md

-- === std/json ===

-- parse: valid JSON string -> Ok value
obj = json.parse "\{\"name\": \"alice\", \"age\": 30}" ^
assert (obj.name == "alice") "json parse object field str"
assert (obj.age == 30) "json parse object field int"

-- parse: array
arr = json.parse "[1, 2, 3]" ^
assert (arr == [1 2 3]) "json parse array"

-- parse: nested
nested = json.parse "\{\"a\": \{\"b\": [1, 2]}}" ^
assert (nested.a.b == [1 2]) "json parse nested"

-- parse: primitives
assert (json.parse "true" ^ == true) "json parse bool"
assert (json.parse "null" ^ == None) "json parse null"
assert (json.parse "42" ^ == 42) "json parse int"
assert (json.parse "3.14" ^ == 3.14) "json parse float"
assert (json.parse "\"hello\"" ^ == "hello") "json parse string"

-- parse: invalid JSON -> Err
bad = json.parse "not json"
assert (err? bad == true) "json parse invalid returns Err"

-- parse + ?? coalescing
fallback = json.parse "broken" ?? []
assert (fallback == []) "json parse with coalesce"

-- encode: record -> JSON string
rec = {name: "bob" age: 25}
encoded = json.encode rec
assert (encoded == "\{\"name\":\"bob\",\"age\":25}") "json encode record"

-- encode: list
assert (json.encode [1 2 3] == "[1,2,3]") "json encode list"

-- encode: primitives
assert (json.encode true == "true") "json encode bool"
assert (json.encode 42 == "42") "json encode int"
assert (json.encode "hello" == "\"hello\"") "json encode string"
assert (json.encode None == "null") "json encode None"
assert (json.encode () == "null") "json encode Unit"

-- encode_pretty: formatted output
pretty = json.encode_pretty {x: 1}
has_indent = contains? "\"x\": 1" pretty
assert has_indent

-- roundtrip: encode then parse
original = {items: [1 2 3] active: true count: 42}
roundtripped = json.encode original | json.parse ^
assert (roundtripped == original) "json roundtrip"

-- pipeline usage
data = "[1, 2, 3]"
total = json.parse data ^ | sum
assert (total == 6) "json parse in pipeline"

-- json is a builtin, no import needed
assert (json.parse "42" ^ == 42) "json builtin parse"
assert (json.encode [10 20] == "[10,20]") "json builtin encode"

-- === std/math ===
use std/math

-- constants
assert (math.pi > 3.14) "math.pi > 3.14"
assert (math.pi < 3.15) "math.pi < 3.15"
assert (math.e > 2.71) "math.e > 2.71"
assert (math.e < 2.72) "math.e < 2.72"

-- abs
assert (math.abs 5 == 5) "math.abs positive"
assert (math.abs (0 - 5) == 5) "math.abs negative"
assert (math.abs 0 == 0) "math.abs zero"
assert (math.abs (0.0 - 3.14) == 3.14) "math.abs float"

-- ceil/floor/round
assert (math.ceil 2.3 == 3) "math.ceil"
assert (math.floor 2.7 == 2) "math.floor"
assert (math.round 2.5 == 3) "math.round up"
assert (math.round 2.4 == 2) "math.round down"

-- pow
assert (math.pow 2 10 == 1024) "math.pow int"
assert (math.pow 3 0 == 1) "math.pow zero exp"

-- sqrt
sq = math.sqrt 16.0
assert (sq == 4.0) "math.sqrt 16"

-- min/max
assert (math.min 3 7 == 3) "math.min"
assert (math.max 3 7 == 7) "math.max"
assert (math.min 5.0 2.0 == 2.0) "math.min float"

-- pipeline usage
assert ([1 (0 - 3) 5 (0 - 2)] | map math.abs | sum == 11) "math.abs in pipeline"


-- === std/fs ===
use std/fs

-- write and read roundtrip
fs_tmp = "/tmp/lx_fs_test.txt"
fs.write fs_tmp "hello lx" ^
content = fs.read fs_tmp ^
assert (content == "hello lx") "fs write/read roundtrip"

-- exists
assert (fs.exists fs_tmp == true) "fs.exists for existing file"
assert (fs.exists "/tmp/lx_no_such_file_xyz" == false) "fs.exists for missing file"

-- append
fs.append fs_tmp " world" ^
content2 = fs.read fs_tmp ^
assert (content2 == "hello lx world") "fs.append"

-- stat
info = fs.stat fs_tmp ^
assert (info.is_file == true) "fs.stat is_file"
assert (info.is_dir == false) "fs.stat is_dir"
assert (info.size > 0) "fs.stat size"

-- mkdir + ls
test_dir = "/tmp/lx_fs_test_dir"
fs.mkdir test_dir ^
fs.write (test_dir ++ "/a.txt") "a" ^
fs.write (test_dir ++ "/b.txt") "b" ^
entries = fs.ls test_dir ^
assert (entries == ["a.txt" "b.txt"]) "fs.ls sorted"

-- remove file
fs.remove fs_tmp ^
assert (fs.exists fs_tmp == false) "fs.remove file"

-- remove dir
fs.remove test_dir ^
assert (fs.exists test_dir == false) "fs.remove dir"

-- read nonexistent -> Err
bad_read = fs.read "/tmp/lx_no_such_file_xyz"
assert (err? bad_read == true) "fs.read nonexistent returns Err"

-- === std/env ===
use std/env

-- get existing var
home = env.get "HOME"
assert (some? home == true) "env.get HOME exists"

-- get missing var
missing = env.get "LX_NONEXISTENT_VAR_12345"
assert (missing == None) "env.get missing returns None"

-- get with ?? coalescing
val_or_default = env.get "LX_NONEXISTENT_VAR_12345" ?? "fallback"
assert (val_or_default == "fallback") "env.get with coalesce"

-- cwd returns a string
wd = env.cwd ()
assert (len wd > 0) "env.cwd returns non-empty string"

-- === std/re ===
use std/re

-- is_match
assert (re.is_match "\\d+" "abc123" == true) "re.is_match digits"
assert (re.is_match "^\\d+$" "abc123" == false) "re.is_match full string"

-- match
m = re.match "\\d+" "abc123def"
assert (m == Some {text: "123" start: 3 end: 6}) "re.match result"

-- match failure
assert (re.match "\\d+" "abcdef" == None) "re.match no match"

-- find_all
found = re.find_all "\\d+" "a1b22c333"
assert (found == ["1" "22" "333"]) "re.find_all"

-- replace (first only)
r1 = re.replace "\\d+" "X" "a1b2c3"
assert (r1 == "aXb2c3") "re.replace first"

-- replace_all
r2 = re.replace_all "\\d+" "X" "a1b2c3"
assert (r2 == "aXbXcX") "re.replace_all"

-- split
parts = re.split "[,;]" "a,b;c,d"
assert (parts == ["a" "b" "c" "d"]) "re.split"

-- works with string patterns
assert (re.is_match "\\d+" "abc123" == true) "re with string pattern"
found2 = re.find_all "(?i)[A-Z]+" "Hello World"
assert (found2 == ["Hello" "World"]) "re with inline flags"

-- pipeline
digits = "phone: 555-1234, ext: 42"
  | re.find_all "\\d+"
assert (digits == ["555" "1234" "42"]) "re in pipeline"

-- === std/md ===
use pkg/data/md

-- parse headings
src = "# Title\n\nSome text.\n\n## Subtitle\n\nMore text."
doc = md.parse src
assert (len doc == 4) "md.parse node count"

-- headings extraction
hdgs = md.headings doc
assert (len hdgs == 2) "md.headings count"
assert (hdgs.0.level == 1) "md.headings level 1"
assert (hdgs.0.text == "Title") "md.headings text 1"
assert (hdgs.1.level == 2) "md.headings level 2"

-- code blocks
code_src = "# Test\n\n```rust\nfn main() \{}\n```\n\nParagraph."
code_doc = md.parse code_src
blocks = md.code_blocks code_doc
assert (len blocks == 1) "md.code_blocks count"
assert (blocks.0.lang != None) "md.code_blocks has lang"
assert (blocks.0.code == "fn main() \{}") "md.code_blocks code"

-- links
link_src = "Click [here](https://example.com) and [there](https://other.com)."
link_list = md.links link_src
assert (len link_list == 2) "md.links count"
assert (link_list.0.text == "here") "md.links text"
assert (link_list.0.url == "https://example.com") "md.links url"

-- to_text
plain = md.to_text "# Hello\n\nWorld **bold** text."
assert (contains? "Hello" plain == true) "md.to_text has heading"
assert (contains? "World" plain == true) "md.to_text has text"

-- sections
sec_src = "# Intro\n\nFirst para.\n\n## Details\n\nSecond para."
sec_doc = md.parse sec_src
secs = md.sections sec_doc
assert (len secs == 2) "md.sections count"
assert (secs.0.title == "Intro") "md.sections title"
assert (secs.0.level == 1) "md.sections level"
assert (contains? "First para" (secs.0.content) == true) "md.sections content"

-- builders
h1_node = md.h1 "Title"
assert (h1_node.type == "heading") "md.h1 type"
assert (h1_node.level == 1) "md.h1 level"
assert (h1_node.text == "Title") "md.h1 text"

para_node = md.para "Hello world"
assert (para_node.type == "para") "md.para type"

code_node = md.code "lx" "x = 42"
assert (code_node.type == "code") "md.code type"
assert (code_node.lang == Some "lx") "md.code lang"

list_node = md.list ["apple" "banana"]
assert (list_node.type == "list") "md.list type"
assert (list_node.items == ["apple" "banana"]) "md.list items"

link_node = md.link "Click" "https://example.com"
assert (link_node.type == "link") "md.link type"

hr_node = md.hr
assert (hr_node.type == "hr") "md.hr type"

-- render
rendered = md.render [(md.h1 "Report") (md.para "All good.") md.hr (md.h2 "Details")]
assert (contains? "# Report" rendered == true) "md.render heading"
assert (contains? "All good." rendered == true) "md.render para"
assert (contains? "---" rendered == true) "md.render hr"
assert (contains? "## Details" rendered == true) "md.render h2"

-- render code block
code_rendered = md.render [(md.code "js" "console.log(1)")]
assert (contains? "```js" code_rendered == true) "md.render code"

-- render list
list_rendered = md.render [(md.list ["a" "b" "c"])]
assert (contains? "- a" list_rendered == true) "md.render list"

-- render table
tbl = md.table ["Name" "Age"] [["Alice" "30"] ["Bob" "25"]]
tbl_rendered = md.render [tbl]
assert (contains? "| Name | Age |" tbl_rendered == true) "md.render table header"
assert (contains? "| Alice | 30 |" tbl_rendered == true) "md.render table row"

-- doc + render roundtrip
r_h1 = md.h1 "Status"
r_para = md.para "Everything is fine."
r_list = md.list ["task1" "task2"]
report = md.doc [r_h1 r_para r_list]
output = md.render report
assert (contains? "# Status" output == true) "md.doc+render"

log.info "15_stdlib: all passed"

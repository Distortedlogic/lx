-- 48_agent_handoff.lx
-- Tests: spec/agents-handoff.md (Handoff Trait + agent.as_context)
-- Phase: agent.Handoff Trait, agent.as_context formatting helper

use std/agent {Handoff}
use std/agent

-- Handoff Trait validates and fills defaults
h = Handoff {result: "auth review complete"}
assert (h.result == "auth review complete") "handoff result preserved"
assert (h.tried == []) "handoff tried defaults to empty"
assert (h.assumptions == []) "handoff assumptions defaults to empty"
assert (h.uncertainties == []) "handoff uncertainties defaults to empty"
assert (h.recommendations == []) "handoff recommendations defaults to empty"
assert (h.files_read == []) "handoff files_read defaults to empty"
assert (h.tools_used == []) "handoff tools_used defaults to empty"
assert (h.duration_ms == 0) "handoff duration_ms defaults to 0"

-- Handoff with explicit fields
h2 = Handoff {
  result: {findings: ["vuln1" "vuln2"]}
  tried: ["checked tokens" "checked sessions"]
  assumptions: ["auth is only entry point"]
  uncertainties: ["rate limiting may be affected"]
  recommendations: ["start with token.rs:45"]
  files_read: ["src/auth/token.rs" "src/auth/session.rs"]
  tools_used: ["grep" "ast_search"]
  duration_ms: 1500
}
assert (h2.tried | len == 2) "handoff tried populated"
assert (h2.files_read | len == 2) "handoff files_read populated"
assert (h2.duration_ms == 1500) "handoff duration_ms explicit"

-- agent.as_context formats handoff as readable string
ctx = agent.as_context h2
assert (ctx | contains? "Previous Agent Handoff") "as_context has header"
assert (ctx | contains? "Result:") "as_context has result"
assert (ctx | contains? "Tried:") "as_context has tried"
assert (ctx | contains? "checked tokens") "as_context lists tried items"
assert (ctx | contains? "Assumptions:") "as_context has assumptions"
assert (ctx | contains? "Uncertainties:") "as_context has uncertainties"
assert (ctx | contains? "Recommendations:") "as_context has recommendations"
assert (ctx | contains? "Files examined:") "as_context has files_read"
assert (ctx | contains? "Tools used:") "as_context has tools_used"

-- as_context omits empty sections
ctx_minimal = agent.as_context h
assert (ctx_minimal | contains? "Result:") "minimal has result"
assert (!(ctx_minimal | contains? "Tried:")) "minimal omits empty tried"
assert (!(ctx_minimal | contains? "Assumptions:")) "minimal omits empty assumptions"

-- handoff sent as agent message
receiver = {handler: (msg) {got_result: msg.result  got_tried: msg.tried}}
response = receiver ~>? h2
assert (response.got_result.findings.0 == "vuln1") "handoff as message preserves result"
assert (response.got_tried | len == 2) "handoff as message preserves tried"

-- handoff with dialogue context initialization
dialogue_agent = {handler: (msg) {has_context: msg.context != ()}}
session = agent.dialogue dialogue_agent {context: (agent.as_context h2)} ^
r = agent.dialogue_turn session "proceed with fix" ^
assert (r.has_context == true) "handoff context in dialogue"
agent.dialogue_end session

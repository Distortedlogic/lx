-- 66_user.lx
-- Tests: std/user module (structured agent-to-user interaction)
-- Uses NoopUserBackend (default): confirm -> true, choose -> index 0, ask -> default/""

use std/user

-- === confirm returns true (noop backend auto-approves) ===
ok = user.confirm "Delete files?"
assert (ok == true) "confirm returns true with noop backend"

-- === choose returns first option (noop backend) ===
choice = user.choose "Pick one?" ["alpha" "beta" "gamma"]
assert (choice == "alpha") "choose returns first option"

-- === choose with record options returns first record ===
opts = [
  {label: "Fast" desc: "Skip tests"}
  {label: "Safe" desc: "Full suite"}
]
chosen = user.choose "Strategy?" opts
assert (chosen.label == "Fast") "choose with records returns first"

-- === ask returns empty string (noop backend, no default) ===
answer = user.ask "Name?"
assert (answer == "") "ask returns empty with noop backend"

-- === ask_with returns default (noop backend) ===
name = user.ask_with "Project?" {default: "my-project"}
assert (name == "my-project") "ask_with returns default value"

-- === progress fires without error ===
r1 = user.progress 3 7 "Running tests"
assert (r1 == ()) "progress returns unit"

-- === progress_pct fires without error ===
r2 = user.progress_pct 0.42 "Indexing"
assert (r2 == ()) "progress_pct returns unit"

-- === progress_pct accepts Int ===
r3 = user.progress_pct 0 "Starting"
assert (r3 == ()) "progress_pct accepts Int 0"

-- === status fires without error ===
r4 = user.status ":info" "Connected"
assert (r4 == ()) "status :info returns unit"
r5 = user.status ":warn" "Rate limit"
assert (r5 == ()) "status :warn returns unit"
r6 = user.status ":error" "Failed"
assert (r6 == ()) "status :error returns unit"
r7 = user.status ":success" "All passed"
assert (r7 == ()) "status :success returns unit"

-- === table fires without error ===
r8 = user.table ["File" "Issues"] [["auth.rs" "3"] ["db.rs" "0"]]
assert (r8 == ()) "table returns unit"

-- === check returns None (noop backend, no signal) ===
sig = user.check ()
assert (sig == None) "check returns None with noop backend"

-- === confirm is a function ===
assert (func? user.confirm) "confirm is a function"
assert (func? user.choose) "choose is a function"
assert (func? user.ask) "ask is a function"
assert (func? user.ask_with) "ask_with is a function"
assert (func? user.progress) "progress is a function"
assert (func? user.progress_pct) "progress_pct is a function"
assert (func? user.status) "status is a function"
assert (func? user.table) "table is a function"
assert (func? user.check) "check is a function"

log.info "66_user: all passed"

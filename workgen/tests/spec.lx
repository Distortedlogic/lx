-- Satisfaction spec for workgen.
-- Each scenario is a fixture with planted violations + an answer key
-- of expected findings. The grader checks that workgen's output catches them.

use std/audit
use std/md

+name = "workgen"
+threshold = 0.75
+weights = {
  structure: 0.25
  coverage: 0.30
  compliance: 0.25
  safety: 0.20
}

+grader = (output scenario) {
  parsed = md.parse output
  headings = md.headings parsed

  has_goal = headings | any? (h) contains? "Goal" h.text
  has_why = headings | any? (h) contains? "Why" h.text
  has_changes = headings | any? (h) contains? "changes" h.text
  has_files = headings | any? (h) contains? "Files" h.text
  has_tasks = headings | any? (h) contains? "Task" h.text
  has_reminders = headings | any? (h) contains? "CRITICAL REMINDERS" h.text
  section_hits = [has_goal has_why has_changes has_files has_tasks has_reminders] | filter identity | len
  structure_score = section_hits / 6.0

  expected = scenario.expected_findings
  found = expected | filter (finding) contains? finding output
  coverage_score = expected | empty? ? 1.0 : ((found | len) / (expected | len))

  has_fmt = contains? "just fmt" output
  has_commit = contains? "git commit" output || contains? "git add" output
  has_verify = contains? "just test" output || contains? "just diagnose" output
  has_loading = headings | any? (h) contains? "Loading" h.text
  compliance_hits = [has_fmt has_commit has_verify has_loading] | filter identity | len
  compliance_score = compliance_hits / 4.0

  not_empty = audit.is_empty output | not
  not_hedging = audit.is_hedging output | not
  not_refusal = audit.is_refusal output | not
  safety_hits = [not_empty not_hedging not_refusal] | filter identity | len
  safety_score = safety_hits / 3.0

  {
    structure: structure_score
    coverage: coverage_score
    compliance: compliance_score
    safety: safety_score
  }
}

+scenarios = [
  {
    name: "rust-audit: inline imports"
    root: "workgen/tests/fixtures/rust_audit"
    expected_findings: [
      "inline import"
      "self-assignment"
      "#[allow"
      "&String"
      "&Vec"
      "swallow"
      "intermediate collect"
      "string literal"
    ]
    tags: ["rust" "smoke"]
  }
  {
    name: "python-audit: quality"
    root: "workgen/tests/fixtures/python_audit"
    expected_findings: [
      "string literal"
      "free function"
      "mutable default"
      "swallow"
      "intermediate list"
      "dict"
      "StrEnum"
    ]
    tags: ["python"]
  }
  {
    name: "performance-audit: anti-patterns"
    root: "workgen/tests/fixtures/perf_audit"
    expected_findings: [
      "intermediate collect"
      "clone"
      "lock per"
      "string concat"
      "full sort"
      "repeated HashMap lookup"
      "with_capacity"
    ]
    tags: ["perf"]
  }
  {
    name: "topology-audit: simplification"
    root: "workgen/tests/fixtures/topology_audit"
    expected_findings: [
      "proxy"
      "shuttle"
      "call chain"
      "repeated lock"
      "parameter threading"
    ]
    tags: ["topology"]
  }
  {
    name: "diagram-audit: graphviz"
    root: "workgen/tests/fixtures/diagram_audit"
    expected_findings: [
      "vertical bloat"
      "invisible edge"
      "spaghetti"
      "dummy"
      "pause/resume"
    ]
    tags: ["diagram"]
  }
  {
    name: "diesel-audit: queries"
    root: "workgen/tests/fixtures/diesel_audit"
    expected_findings: [
      "sequential quer"
      "raw SQL"
      "loop"
      "upsert"
      "filter after load"
      "transaction"
      "DbEnum"
    ]
    tags: ["diesel"]
  }
  {
    name: "perf-libs-audit: polars+rayon"
    root: "workgen/tests/fixtures/perf_libs_audit"
    expected_findings: [
      "premature"
      "collect"
      "element-wise"
      "round-trip"
      "eager read"
      "lock per"
      "nested"
    ]
    tags: ["perf-libs"]
  }
  {
    name: "dioxus-audit: framework"
    root: "workgen/tests/fixtures/dioxus_audit"
    expected_findings: [
      "#[server]"
      "use_resource"
      "use_effect"
      "use_action"
      "wrapper component"
      "interpolation"
      "Store"
    ]
    tags: ["dioxus"]
  }
  {
    name: "tailwind-audit: css"
    root: "workgen/tests/fixtures/tailwind_audit"
    expected_findings: [
      "@tailwind"
      "@utility"
      "raw palette"
      "dark:"
      "outline-none"
      "ring"
      "border"
      "focus:"
    ]
    tags: ["tailwind"]
  }
  {
    name: "bevy-audit: ecs"
    root: "workgen/tests/fixtures/bevy_audit"
    expected_findings: [
      "monolithic plugin"
      "chain"
      "run condition"
      "reflect"
      "init_resource"
      "Deref"
      "schedule"
    ]
    tags: ["bevy"]
  }
  {
    name: "bevy-ecosystem-audit: plugins"
    root: "workgen/tests/fixtures/bevy_eco_audit"
    expected_findings: [
      "bevy_rand"
      "volume"
      "Rapier"
      "egui"
    ]
    tags: ["bevy-eco"]
  }
  {
    name: "primitives-audit: dioxus"
    root: "workgen/tests/fixtures/primitives_audit"
    expected_findings: [
      "AlertDialog"
      "Tooltip"
      "Select"
      "Tabs"
    ]
    tags: ["primitives"]
  }
]

-- Satisfaction test runner for workgen.
-- Runs workgen for real against each scenario's fixture codebase,
-- uses std/agents/grader for AI-backed scoring of the output.
-- Scenarios run in parallel via pmap_n with per-scenario timeouts.
--
-- Usage: lx run workgen/tests/run.lx
-- Filter: TEST_TAG=smoke lx run workgen/tests/run.lx

use std/fs
use std/env
use std/trace
use std/agents/grader
use std/audit
use ../main : workgen
use ./spec

run_scenario = (scenario) {
  emit "\n  --- {scenario.name} ---"

  result = workgen.run scenario.audit "workgen/rules/work-item.md" scenario.root

  result ? {
    Ok r -> {
      output = fs.read r.path ?? ""

      grade_result = grader.grade {
        work: output
        task: "work item for {scenario.name} covering: {scenario.expected_findings | join ", "}"
        rubric: spec.rubric
        threshold: spec.threshold_pct
      }

      emit "    score: {grade_result.score}  passed: {grade_result.passed}"
      grade_result.passed | not ? emit "    feedback: {grade_result.feedback}"

      sn = scenario.name
      {name: sn  passed: grade_result.passed  score: grade_result.score}
    }
    Err e -> {
      emit "    ERROR: {e}"
      sn = scenario.name
      {name: sn  passed: false  score: 0.0}
    }
  }
}

+main = () {
  session = trace.create "/tmp/lx_workgen_test_trace.json" ^
  tag_filter = env.get "TEST_TAG" ?? ""

  scenarios = tag_filter == "" ? {
    true -> spec.scenarios
    false -> spec.scenarios | filter (s) s.tags | contains? tag_filter
  }

  emit "=== workgen satisfaction tests ==="
  emit "scenarios: {scenarios | len}"
  emit "threshold: {spec.threshold}"

  results = scenarios | pmap_n 4 run_scenario

  results | each (r) {
    trace.record {name: r.name  output: (to_str r.score)  score: r.score} session ^
  }

  passed_count = results | filter (.passed) | len
  total = results | len
  scores = results | map (.score)
  overall = scores | fold 0.0 (+) | (s) s / total

  emit "\n=== {spec.name} ==="
  results | each (r) {
    status = r.passed ? "PASS" : "FAIL"
    emit "  {r.name}: {r.score} {status}"
  }
  emit "\nOverall: {overall} — {passed_count}/{total} passed (threshold: {spec.threshold})"

  passed_count == total ? (Ok results) : (Err "some scenarios failed")
}

main ()

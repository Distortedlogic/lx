-- Satisfaction test runner for workgen.
-- Runs workgen against each scenario's fixture codebase.
-- Usage: lx run workgen/tests/run.lx
-- Filter: TEST_TAG=smoke lx run workgen/tests/run.lx

use std/env
use std/fs
use workgen/lib/log : wg_log
use workgen/lib/audit_parser
use workgen/lib/grader {Grader}
use workgen/lib/orchestrator
use ./spec

wi_grader = Grader {threshold: spec.threshold_pct  rubric: spec.rubric}
rules_content = fs.read "workgen/rules/work-item.md" ^

run_scenario_impl = (scenario) {
  wg_log.log "  --- {scenario.name} ---"
  audit = audit_parser.load scenario.audit
  result = orchestrator.run_audit audit rules_content scenario.root wi_grader 3 ".lx/workgen_test"
  {name: scenario.name  passed: result.status == "pass"  score: result.score}
}

+main = () {
  tag_filter = env.get "TEST_TAG" ?? ""
  scenarios = tag_filter == "" ? spec.scenarios : (spec.scenarios | filter (s) { s.tags | contains? tag_filter })

  wg_log.log "=== workgen satisfaction tests ==="
  wg_log.log "scenarios: {scenarios | len}"
  wg_log.log "threshold: {spec.threshold}"

  results = scenarios | map run_scenario_impl

  passed_count = results | filter (r) { r.passed == true } | len
  total = results | len

  wg_log.log ""
  wg_log.log "=== {spec.name} ==="
  results | each (r) {
    status = r.passed ? "PASS" : "FAIL"
    wg_log.log "  {r.name}: {r.score} {status}"
  }
  wg_log.log "Overall: {passed_count}/{total} passed (threshold: {spec.threshold})"

  passed_count == total ? (Ok results) : (Err "some scenarios failed")
}

main ()

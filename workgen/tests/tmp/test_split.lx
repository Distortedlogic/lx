use ./fake_main : workgen

run_scenario = (scenario) {
  result = workgen.run "a/b/c" "x"
  result ? {
    Ok r -> {name: scenario.name  passed: true  score: 1.0}
    Err e -> {
      emit "ERROR: {e}"
      {name: scenario.name  passed: false  score: 0.0}
    }
  }
}

scenario = {name: "test"  root: "/tmp"  tags: []}
out = run_scenario scenario
emit "result: {out}"

-- Timestamped logging — future runtime stream backend hook point.

use std/time
use std/fs

+log = (msg) {
  t = time.now ()
  ts = t | time.format "%H:%M:%S"
  emit "[{ts}] {msg}"
}

+save_debug = (dir slug label content) {
  path = "{dir}/logs/{slug}"
  fs.mkdir path ^
  fs.write "{path}/{label}" content ^
}

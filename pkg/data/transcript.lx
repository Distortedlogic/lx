-- Transcript ingestion -- read Claude CLI JSONL transcripts into TraceEntry records.
-- read_recent: find .jsonl files modified within a time window (minutes).
-- parse: JSONL lines into normalized TraceEntry records.
-- Filters: tool_calls, tool_results, successes, failures.

use std/fs

Trait +TraceEntry = {type: Str  name: Str  input: Any  output: Any  success: Bool}

+read_recent = (dir mins) {
  $^find {dir} -name "*.jsonl" -mmin -{mins}
    | lines
    | filter (!= "")
}

+parse = (path) {
  content = fs.read path ?? ""
  content | lines | filter (!= "") | flat_map (line) {
    json.parse line ? {
      Ok entry -> {
        normalized = normalize entry
        [normalized]
      }
      Err _ -> []
    }
  }
}

normalize = (entry) {
  TraceEntry {type: entry.type ?? "unknown"  name: entry.name ?? ""  input: entry.input ?? %{}  output: entry.output ?? %{}  success: entry.success ?? true}
}

+tool_calls = (entries) entries | filter (e) e.type == "tool_use"

+tool_results = (entries) entries | filter (e) e.type == "tool_result"

+successes = (entries) entries | filter (.success)

+failures = (entries) entries | filter (e) !e.success

+extract_patterns = (good) {
  good
    | map (e) {tool: e.name  description: "successful {e.name}"}
    | group_by (.tool)
    | entries
    | filter (tool, uses) uses | len >= 2
    | map (tool, uses) {tool  count: (uses | len)  description: "{tool}: {uses | len} successes"}
}

+extract_mistakes = (bad) {
  bad | map (e) {what: "failed {e.name}"  lesson: (to_str e.output)}
}

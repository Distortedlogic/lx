-- Human-in-the-loop approval gates via yield.
-- Hoisted from agent_gate.rs.

Trait +GateResult = {approved: Bool = false  reason: Str = ""  modified: Any = None}

+gate = (agent msg config) {
  description = config.description ?? "Approval required"
  timeout_ms = config.timeout_ms ?? 0
  payload = {type: "gate"  description: description  agent: agent.name ?? "unknown"  message: msg}
  response = yield payload
  approved = response.approved ?? false
  reason = response.reason ?? ""
  modified = response.modified ?? None
  result = GateResult {approved: approved  reason: reason  modified: modified}
  approved ? msg : result
}

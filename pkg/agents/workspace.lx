-- Collaborative workspace — Store-backed shared text editing with region claiming.
-- Replaces std/workspace.

use std/time
use pkg/agents/workspace_edit

+claim = workspace_edit.claim
+claim_pattern = workspace_edit.claim_pattern
+edit = workspace_edit.edit
+append = workspace_edit.append
+release = workspace_edit.release

Class +Workspace = {
  name: ""
  content: ""
  regions: Store ()
  history: Store ()
  conflicts: Store ()
  watchers: []
  next_id: 0
}

+create = (name opts) {
  content = opts.content ?? ""
  Workspace {name: name  content: content}
}

+snapshot = (ws) { ws.content }

+regions = (ws) {
  ws.regions.entries () | map (e) { {..e.value  name: e.key} }
}

+conflicts = (ws) {
  ws.conflicts.entries () | map (e) { {..e.value  id: e.key} }
}

+resolve = (ws conflict_id resolution) {
  conflict = ws.conflicts.get conflict_id
  conflict ? {
    None -> Err "conflict not found: {conflict_id}"
    Some c -> {
      ws.conflicts.remove conflict_id
      resolution ? {
        "ours" -> Ok c.ours
        "theirs" -> Ok c.theirs
        _ -> Ok resolution
      }
    }
  }
}

+history = (ws) {
  ws.history.entries () | sort_by (e) e.value.timestamp ?? 0
}

+watch = (ws handler) {
  ws.watchers <- [..ws.watchers handler]
}

notify_watchers = (ws event) {
  ws.watchers | each (w) { try w event }
}

-- Hot-swap agent handlers — reload, evolve, update_traits.
-- Hoisted from agent_reload.rs. Uses resolve_handler builtin for handler lookup.

+reload = (agent new_handler) {
  {..agent  handler: new_handler}
}

+evolve = (agent new_handler) {
  {..agent  handler: new_handler}
}

+update_traits = (agent add remove) {
  current = agent.traits ?? []
  added = add ?? []
  removed = remove ?? []
  new_traits = (current ++ added) | filter (t) { (removed | contains? t) == false }
  {..agent  traits: new_traits}
}

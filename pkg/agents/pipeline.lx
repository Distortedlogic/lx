-- Consumer-driven pipeline with backpressure — bounded buffers, overflow policies.
-- Hoisted from agent_pipeline.rs, agent_pipeline_ctrl.rs, agent_pipeline_io.rs.

pipelines = Store ()
next_id = Store ()
next_id.set "v" 1

+pipeline = (config) {
  id = next_id.get "v"
  next_id.set "v" (id + 1)
  buffer_size = config.buffer_size ?? 100
  overflow = config.overflow ?? "block"
  workers = config.workers ?? []
  state = Store ()
  state.set "buffer" []
  state.set "workers" workers
  state.set "buffer_size" buffer_size
  state.set "overflow" overflow
  state.set "paused" false
  state.set "closed" false
  state.set "sent" 0
  state.set "dropped" 0
  state.set "processed" 0
  state.set "pressure_callbacks" []
  pipelines.set (to_str id) state
  {__pipeline_id: id  name: config.name ?? "pipeline"}
}

get_state = (p) {
  id = to_str p.__pipeline_id
  pipelines.get id
}

+pipeline_send = (p item) {
  gs = get_state
  state = gs p
  is_closed = state.get "closed"
  is_closed ? Err "pipeline closed"
  is_paused = state.get "paused"
  is_paused ? Err "pipeline paused"
  buf = state.get "buffer"
  max = state.get "buffer_size"
  overflow = state.get "overflow"
  is_full = (buf | len) >= max
  is_full && overflow == "drop_newest" ? { state.set "dropped" ((state.get "dropped") + 1); Ok () }
  is_full && overflow == "drop_oldest" ? { state.set "buffer" ((buf | drop 1) ++ [item]); state.set "sent" ((state.get "sent") + 1); Ok () }
  state.set "buffer" (buf ++ [item])
  state.set "sent" ((state.get "sent") + 1)
  workers = state.get "workers"
  has_workers = (workers | len) > 0
  has_workers ? {
    worker_idx = (state.get "sent") % (workers | len)
    worker = workers | at worker_idx
    result = worker item
    state.set "processed" ((state.get "processed") + 1)
    new_buf = state.get "buffer"
    state.set "buffer" (new_buf | filter (x) { x != item })
  }
  ok_val = Ok ()
  ok_val
}

+pipeline_collect = (p count) {
  gs = get_state
  state = gs p
  buf = state.get "buffer"
  n = count ?? (buf | len)
  taken = buf | take n
  remaining = buf | drop n
  state.set "buffer" remaining
  taken
}

+pipeline_batch = (p size handler) {
  gs = get_state
  state = gs p
  buf = state.get "buffer"
  has_enough = (buf | len) >= size
  has_enough ? {
    batch = buf | take size
    state.set "buffer" (buf | drop size)
    handler batch
  }
}

+pipeline_stats = (p) {
  gs = get_state
  state = gs p
  buf = state.get "buffer"
  {sent: state.get "sent"  processed: state.get "processed"  buffered: buf | len  dropped: state.get "dropped"}
}

+pipeline_on_pressure = (p threshold callback) {
  gs = get_state
  state = gs p
  cbs = state.get "pressure_callbacks"
  state.set "pressure_callbacks" (cbs ++ [{threshold: threshold  callback: callback}])
}

+pipeline_pause = (p) { gs = get_state; state = gs p; state.set "paused" true }
+pipeline_resume = (p) { gs = get_state; state = gs p; state.set "paused" false }
+pipeline_drain = (p) { gs = get_state; state = gs p; buf = state.get "buffer"; state.set "buffer" []; buf }
+pipeline_close = (p) { gs = get_state; state = gs p; state.set "closed" true }

+pipeline_add_worker = (p worker) {
  gs = get_state
  state = gs p
  workers = state.get "workers"
  state.set "workers" (workers ++ [worker])
}

-- Auditor agent — structural quality checks + optional LLM audit.
-- Replaces std/agents/auditor.

use pkg/core/audit

Prompt AuditPrompt = {
  system: "You are a quality auditor. Evaluate the output against the task and rubric."
}

hedging_phrases = [
  "i think"; "maybe"; "possibly"; "i'm not sure"; "perhaps";
  "it might"; "it could be"; "i believe"; "not entirely sure"
]

refusal_phrases = [
  "i can't"; "i'm unable"; "as an ai"; "i cannot";
  "i'm not able"; "i don't have the ability"
]

count_matches = (text phrases) {
  lo = text | lower
  phrases | filter (p) { lo | contains? p } | len
}

+quick_audit = (opts) {
  output = opts.output ?? ""
  task = opts.task ?? ""
  trimmed = output | trim

  failed := []

  (trimmed | len) == 0 ? {
    true -> { failed <- [..failed; "empty"] }
    false -> ()
  }

  refusal_count = count_matches output refusal_phrases
  (refusal_count > 0) ? {
    true -> { failed <- [..failed; "refusal"] }
    false -> ()
  }

  hedging_count = count_matches output hedging_phrases
  (hedging_count >= 3) ? {
    true -> { failed <- [..failed; "excessive_hedging"] }
    false -> ()
  }

  has_task = task != "" && (trimmed | len) > 0
  has_task ? {
    true -> {
      refs = audit.references_task output task
      (refs == false) ? {
        true -> { failed <- [..failed; "no_task_reference"] }
        false -> ()
      }
    }
    false -> ()
  }

  is_pass = (failed | len) == 0
  score = is_pass ? 100 : 0
  cats = [{name: "structure"  score: score  passed: is_pass}]
  {passed: is_pass  score: score  failed: failed  categories: cats}
}

+audit = (opts) {
  output = opts.output ?? ""
  task = opts.task ?? ""
  context = opts.context ?? ""
  rubric = opts.rubric ?? []

  quick = quick_audit opts
  not quick.passed ? quick : {
    p = AuditPrompt {}
    p.add_section "Task" task
    p.add_section "Output" output
    p.add_section "Context" context
    p.add_section "Rubric" (rubric | map (r) "- {r.name}: {r.description}" | join "\n")
    p.add_instruction `Score each rubric category 0-100. Return JSON with: score (int), passed (bool), feedback (str), categories (list of {name, score, feedback}).`

    result = ai.prompt_with {
      prompt: p.render ()
      disable_tools: true
      json_schema: `{"type":"object","properties":{"score":{"type":"integer"},"passed":{"type":"boolean"},"feedback":{"type":"string"},"categories":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string"},"score":{"type":"integer"},"feedback":{"type":"string"}}}}}}`
    } ^

    text = result.structured_output ?? (result.text ?? "{}")
    parsed = try json.parse text
    parsed ? {
      Err _ -> {score: 0  passed: false  feedback: "Failed to parse audit response"  categories: []  failed: ["parse_error"]}
      Ok json_val -> {
        s = json_val.score ?? 0
        cats = json_val.categories ?? []
        f_list = cats | filter (c) { (c.score ?? 0) < 70 } | map (.name)
        {score: s  passed: json_val.passed ?? false  feedback: json_val.feedback ?? ""  categories: cats  failed: f_list}
      }
    }
  }
}

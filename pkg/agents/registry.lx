-- Agent registry — Store-backed agent discovery with trait/domain filtering.
-- Replaces std/registry.

use std/time

Class +Registry = {
  agents: Store ()
  watchers: []
  started: false
}

+start = (_) { Registry {started: true} }

+stop = (reg) {
  reg.agents.clear ()
  reg.started <- false
}

+connect = (opts) { start () }

+register = (reg info) {
  name = info.name ?? (to_str info)
  now = time.now ()
  entry = {
    ..info
    name: name
    registered_at: now.ms
    last_seen: now.ms
    load: info.load ?? 0
    health: info.health ?? "healthy"
  }
  reg.agents.set name entry
  reg.watchers | each (w) { try w {event: "register"  agent: entry} }
  Ok entry
}

+deregister = (reg name) {
  existed = reg.agents.has name
  reg.agents.remove name
  existed ? {
    true -> {
      reg.watchers | each (w) { try w {event: "deregister"  name: name} }
      Ok name
    }
    false -> Err "not found: {name}"
  }
}

+find = (reg query) {
  all = reg.agents.values ()
  filtered = all
    | filter (a) matches_query a query
  strategy = query.prefer ?? query.strategy ?? "first"
  strategy ? {
    "least_loaded" -> filtered | sort_by (.load) ?? 0
    "round_robin" -> filtered
    "random" -> filtered
    _ -> filtered
  }
}

matches_query = (agent query) {
  trait_match = query.trait
  domain_match = query.domain
  traits_match = query.traits

  agent_traits = agent.traits ?? []
  agent_domains = agent.domains ?? []

  trait_ok = trait_match == None ? true : (agent_traits | contains? trait_match)
  domain_ok = domain_match == None ? true : (agent_domains | contains? domain_match)
  traits_ok = traits_match == None ? true : (traits_match | all? (t) { agent_traits | contains? t })
  trait_ok && domain_ok && traits_ok
}

+find_one = (reg query) {
  results = find reg query
  results | first
}

+health = (reg name) {
  entry = reg.agents.get name
  entry ? {
    Some a -> Ok a.health
    None -> Err "not found: {name}"
  }
}

+load = (reg name) {
  reg.agents.get name
}

+watch = (reg handler) {
  reg.watchers <- [..reg.watchers handler]
}

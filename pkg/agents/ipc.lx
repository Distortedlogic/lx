-- Agent IPC — subprocess send/ask wire protocol.
-- Hoisted from agent_ipc.rs. Core send/ask dispatch to subprocess agents.
-- Note: actual subprocess spawning stays in Rust (agent.spawn). This provides
-- the lx-level wrappers for the wire protocol helpers.

+send = (agent msg) {
  agent ~> msg
}

+ask = (agent msg) {
  agent ~>? msg
}

+is_alive = (agent) {
  has_pid = agent.__pid != None
  has_pid
}

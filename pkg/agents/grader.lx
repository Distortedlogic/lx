-- Grader agent — keyword-based quick grading + LLM full grading.
-- Replaces std/agents/grader.

use pkg/core/prompt

keyword_score = (work description) {
  lo = work | lower
  words = description | lower | split " " | filter (w) { (len w) > 3 }
  total = words | len
  total == 0 ? 50 : {
    hits = words | filter (w) { lo | contains? w } | len
    hits * 100 // total
  }
}

+quick_grade = (opts) {
  work = opts.work ?? ""
  task = opts.task ?? ""
  rubric = opts.rubric ?? []
  threshold = opts.threshold ?? 70
  prev = opts.prev ?? None

  empty_result = {score: 0  passed: false  feedback: "Empty output"  categories: []  failed: ["empty"]}
  no_rubric_result = {score: 0  passed: false  feedback: "No rubric"  categories: []  failed: ["no_rubric"]}
  (work | len) == 0 ? empty_result : {
    (rubric | len) == 0 ? no_rubric_result : {
      categories = rubric | map (r) {
        desc = r.description ?? r.name
        s = keyword_score work desc
        fb = s >= 70 ? "Keywords found" : "Low keyword overlap"
        {name: r.name  score: s  feedback: fb  weight: r.weight ?? 1}
      }
      total_score := 0
      total_weight := 0
      failed := []
      categories | each (c) {
        total_score <- total_score + (c.score * (c.weight ?? 1))
        total_weight <- total_weight + (c.weight ?? 1)
        (c.score < 70) ? {
          true -> { failed <- [..failed c.name] }
          false -> ()
        }
      }
      final = total_weight > 0 ? (total_score // total_weight) : 0
      {score: final  passed: final >= threshold && (failed | len == 0)  feedback: ""  categories: categories  failed: failed}
    }
  }
}

+grade = (opts) {
  work = opts.work ?? ""
  task = opts.task ?? ""
  rubric = opts.rubric ?? []
  threshold = opts.threshold ?? 70

  no_rubric_err = {score: 0  passed: false  feedback: "No rubric"  categories: []  failed: ["no_rubric"]}
  (rubric | len) == 0 ? no_rubric_err : {
    rubric_text = rubric | map (r) "- {r.name} (weight {r.weight ?? 1}): {r.description ?? r.name}" | join "\n"

    p = prompt.create ()
      | prompt.system "You are a grader. Score the work against each rubric category 0-100."
      | prompt.section "Task" task
      | prompt.section "Work" work
      | prompt.section "Rubric" rubric_text
      | prompt.instruction `Return JSON: {score: int, passed: bool, feedback: str, categories: [{name, score, feedback}]}`

    result = ai.prompt_with {
      prompt: prompt.render p
      disable_tools: true
      json_schema: `{"type":"object","properties":{"score":{"type":"integer"},"passed":{"type":"boolean"},"feedback":{"type":"string"},"categories":{"type":"array","items":{"type":"object","properties":{"name":{"type":"string"},"score":{"type":"integer"},"feedback":{"type":"string"}}}}}}`
    } ^

    text = result.structured_output ?? (result.text ?? "{}")
    parsed = try json.parse text
    parsed ? {
      Err _ -> {score: 0  passed: false  feedback: "Failed to parse grade response"  categories: []  failed: ["parse_error"]}
      Ok json_val -> {
        cats = json_val.categories ?? []
        total_score := 0
        total_weight := 0
        failed := []
        cats | each (c) {
          matched_rubric = rubric | find (r) { r.name == c.name }
          w = matched_rubric ? { Some r -> r.weight ?? 1; _ -> 1 }
          s = c.score ?? 0
          total_score <- total_score + (s * w)
          total_weight <- total_weight + w
          (s < 70) ? {
            true -> { failed <- [..failed c.name] }
            false -> ()
          }
        }
        final = total_weight > 0 ? (total_score // total_weight) : 0
        {score: final  passed: final >= threshold && (failed | len == 0)  feedback: json_val.feedback ?? ""  categories: cats  failed: failed}
      }
    }
  }
}

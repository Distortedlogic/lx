-- Generic AI agent -- parameterized by action→prompt template mappings.
-- Replaces the 14 identical receive-prompt-return agent files in flows/agents/.
-- create: build handlers map from config entries. Each entry maps action name to prompt fn.
-- serve: run agent.dispatch with the handlers. Use as +main = () { ai_agent.serve handlers }

use std/ai
use std/agent

+simple = (prompt_fn) (msg) {
  ai.prompt (prompt_fn msg) ?? ""
}

+with_fallback = (prompt_fn fallback_fn) (msg) {
  ai.prompt (prompt_fn msg) ?? (fallback_fn msg)
}

+structured = (prompt_fn schema) (msg) {
  ai.prompt_structured (prompt_fn msg) schema ^
}

+create = (config) {
  config | entries | fold %{} (handlers name spec) {
    handler = spec ? {
      {prompt: p  schema: s ..} -> structured p s
      {prompt: p  fallback: f ..} -> with_fallback p f
      {prompt: p ..} -> simple p
      _ -> simple spec
    }
    handlers | merge %{name: handler}
  }
}

+serve = (handlers) { agent.dispatch handlers }

-- Agent factory -- config-driven agent instantiation.
-- from_config: takes a config record with a handlers list and returns a
-- main function that calls ai_agent.serve. Each handler entry specifies
-- name, type (simple/structured/with_fallback/custom), prompt_fn, and
-- optional schema, fallback_fn, or handler_fn (for custom type).

use pkg/ai/ai_agent

+from_config = (config) {
  handlers = config.handlers | fold %{} (acc h) {
    handler = h.type ? {
      "simple" -> ai_agent.simple h.prompt_fn
      "structured" -> ai_agent.structured h.prompt_fn h.schema
      "with_fallback" -> ai_agent.with_fallback h.prompt_fn h.fallback_fn
      "custom" -> h.handler_fn
      _ -> ai_agent.simple h.prompt_fn
    }
    acc | merge %{(h.name): handler}
  }
  () { ai_agent.serve handlers }
}

    init["`**0.0.1 Initialize**
———
system prompt loaded
CLAUDE.md chain resolved (root → nested dirs)
MEMORY.md index → individual memory files
git status captured (branch, modified, recent commits)
settings chain merged (project → user → global)
→ permission allowlists and denylists
→ environment variables · model preferences
→ CLI flag overrides
  (--model · --allowedTools
  --disallowedTools
  --dangerously-skip-permissions
  --max-turns · --system-prompt
  --append-system-prompt · etc.)
hooks registered
→ PreToolUse · PostToolUse
→ UserPromptSubmit · Stop
tool inventory resolved:
→ built-in (Read, Edit, Write, Bash, Grep,
  Glob, Agent, Skill, ToolSearch, LSP,
  AskUserQuestion, Config, NotebookEdit)
→ deferred (name only — schema on demand)
→ MCP (connect to configured servers)
keybindings loaded
if resuming: rehydrate prior conversation history`"]:::cyan

    init --> interact{{"0.2.0 mode?"}}:::purple
    interact -- "interactive" --> wait["1.0.0 Await User Input"]:::teal
    wait -- "user exits\n(Ctrl+C · /exit · close)" --> done(["10.0.0 Session End"]):::teal

    interact -- "non-interactive\n(--print · piped stdin)" --> ni_input["0.0.3 Load Input\n——————\nprompt from --print flag\nor piped from stdin\nsingle input · no interaction loop"]:::cyan
    ni_input --> hooks

    wait --> parse{{"1.1.0 input type?"}}:::purple
    parse -- "free text · image\nPDF · notebook path" --> hooks
    parse -- "/command" --> slash{{"1.2.0 built-in\nor skill?"}}:::teal
    slash -- "built-in\n(/help · /clear · /cost\n/model · /fast · /login)" --> cli["1.0.1 CLI Command\n——————\nprocessed locally\nno model invocation"]:::cyan
    cli --> wait
    slash -- "/compact" --> compact_cmd["1.0.4 User-Triggered Compact\n——————\nmanual context compression\n(vs. automatic at limit)\nuser can specify what to preserve\nmodel summarizes then continues"]:::cyan
    compact_cmd --> wait
    slash -- "skill\n(/commit · /review-pr\n/simplify · /loop · etc.)" --> skill["1.0.2 Expand Skill\n——————\nskill name → full prompt\ninjected as user message"]:::cyan
    skill --> hooks
    parse -- "! shell-command" --> passthru["1.0.3 Shell Pass-through\n——————\nexecute in user's session\nstdout + stderr land\nin conversation context"]:::cyan
    passthru --> wait

    hooks["`**2.0.0 Prompt Submit Hooks**
———
UserPromptSubmit hooks fire
before message reaches model
———
hooks can:
→ modify message content

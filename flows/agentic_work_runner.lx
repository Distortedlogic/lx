-- Agentic Work Runner -- Orchestrates work item execution with grading loops.
--
-- Persists status to .lx/work_runner_status.json. On rerun, skips completed
-- items (grade >= 93). Kill and restart safely — progress is saved after
-- each work item completes.
--
-- Usage: lx run flows/agentic_work_runner.lx
-- Reset: rm .lx/work_runner_status.json

use std/ai
use std/fs
use std/json
use std/time
use std/audit
use std/agents/grader
use pkg/core/prompt

target_grade = 93
max_fix_rounds = 5
stuck_threshold = 3
status_file = ".lx/work_runner_status.json"

work_items = [
  -- "work_items/STD_DIFF.md"
  -- "work_items/STD_WS.md"
  -- "work_items/PANE_BACKEND.md"
  -- "work_items/EMBED_BACKEND.md"
  "work_items/STD_SANDBOX.md"
  -- "work_items/PKG_SEARCH.md"
  -- "work_items/PKG_NOTIFY.md"
  "work_items/PKG_TEMPLATE.md"
  "work_items/PKG_CDP.md"
  "work_items/PKG_VECTORS.md"
  "work_items/PKG_CANVAS.md"
  "work_items/AI_BACKEND_LOCAL_LLM.md"
  "work_items/AI_BACKEND_MEDIA.md"
  "work_items/TOOLBELT_BACKENDS.md"
  "work_items/AGENTIC_CROSS_CUTTING.md"
]

rubric = audit.rubric [
  {name: "files_created"  description: "All files listed in Files Affected section exist in the codebase"  weight: 25}
  {name: "compilation"  description: "just diagnose returns 0 errors and 0 warnings"  weight: 25}
  {name: "tests_pass"  description: "just test passes all tests including any new test files"  weight: 25}
  {name: "api_correct"  description: "Functions registered in mod.rs, API matches the work item spec"  weight: 15}
  {name: "completeness"  description: "Every task in the Task List section has been implemented"  weight: 10}
]

log_ts = (msg) {
  t = time.now ()
  ts = t | time.format "%H:%M:%S"
  emit "[{ts}] {msg}"
}

load_status = () {
  exists = fs.exists status_file
  empty = {results: []  completed: []}
  not exists ? empty : (fs.read status_file ^ | json.parse ^)
}

save_status = (status) {
  $^mkdir -p .lx
  fs.write status_file (json.encode_pretty status) ^
}

is_completed = (status path) {
  status.completed | any? (c) c == path
}

log_ts "loading context files..."
bootstrap_prompt = fs.read "agent/TICK.md" ^
inventory = fs.read "agent/INVENTORY.md" ^
reference = fs.read "agent/REFERENCE.md" ^
stdlib_ref = fs.read "agent/STDLIB.md" ^
total_chars = (bootstrap_prompt | len) + (inventory | len) + (reference | len) + (stdlib_ref | len)
log_ts "context loaded ({total_chars} chars)"

bootstrap_context = "
# Context Bootstrap

{bootstrap_prompt}

# Inventory
{inventory}

# Reference
{reference}

# Stdlib
{stdlib_ref}
"

implement_work_item = (work_item_path) {
  wi_content = fs.read work_item_path ^
  log_ts "  > claude: implement (max 50 turns)..."

  p = prompt.create ()
    | prompt.system "You are implementing a work item for the lx language. Follow every task exactly as written. Use justfile recipes (just diagnose, just test, just fmt). No code comments. 300 line file limit. Follow CLAUDE.md rules."
    | prompt.section "Context Bootstrap" bootstrap_context
    | prompt.section "Work Item" wi_content
    | prompt.instruction "Execute every task in the Task List section sequentially. For each task, implement the code changes described, then run `just diagnose` to verify compilation. After all tasks, run `just test`."
    | prompt.constraint "Do not skip tasks, reorder tasks, or combine tasks"
    | prompt.constraint "Do not add code comments or doc strings"
    | prompt.constraint "No #[allow()] macros"

  result = ai.prompt_with {
    prompt: prompt.render p
    tools: ["Read" "Edit" "Write" "Bash" "Glob" "Grep"]
    max_turns: 50
  } ^

  log_ts "  < implement done ({result.turns ?? 0} turns, ${result.cost ?? 0})"
  result
}

investigate_work_item = (work_item_path) {
  wi_content = fs.read work_item_path ^
  log_ts "  > claude: investigate (max 20 turns)..."

  p = prompt.create ()
    | prompt.system "You are investigating whether a work item has been implemented. Read code, check registrations, run diagnostics. Produce a detailed text report."
    | prompt.section "Work Item" wi_content
    | prompt.instruction "For each file in Files Affected, read it and confirm it exists with the expected content"
    | prompt.instruction "Check mod.rs registrations (get_std_module, std_module_exists)"
    | prompt.instruction "Run `just diagnose` and include the full output"
    | prompt.instruction "Run `just test` and include the full output"
    | prompt.instruction "For each task in the Task List, state whether it is done or not and why"
    | prompt.instruction "End with a summary: which tasks are done, which are missing, what compilation/test issues exist"

  result = ai.prompt_with {
    prompt: prompt.render p
    tools: ["Read" "Glob" "Grep" "Bash"]
    max_turns: 20
  } ^

  log_ts "  < investigate done ({result.turns ?? 0} turns, ${result.cost ?? 0})"
  result.text
}

grade_report = (report work_item_path) {
  log_ts "  > grader: scoring report..."

  grade = grader.grade {
    work: report
    task: "Verify implementation of {work_item_path}"
    rubric: rubric
    threshold: target_grade
  }

  log_ts "  GRADE: {grade.score}/100 | passed: {grade.passed} | feedback: {grade.feedback}"
  grade.categories | each (cat) {
    icon = cat.passed ? "+" : "x"
    log_ts "    [{icon}] {cat.name}: {cat.score}/100 — {cat.feedback}"
  }
  grade
}

fix_issues = (work_item_path feedback failed_cats) {
  wi_content = fs.read work_item_path ^
  failed_text = failed_cats | map to_str | join "\n- "
  log_ts "  > claude: fix ({failed_cats | len} failed categories)..."

  p = prompt.create ()
    | prompt.system "You are fixing issues found during grading of a work item implementation. Fix ONLY the issues listed. Do not refactor or improve beyond what is needed."
    | prompt.section "Context Bootstrap" bootstrap_context
    | prompt.section "Work Item" wi_content
    | prompt.section "Grader Feedback" feedback
    | prompt.section "Failed Categories" failed_text
    | prompt.instruction "For each failed category, find the relevant code and fix it"
    | prompt.instruction "Run `just diagnose` after fixes to verify compilation"
    | prompt.instruction "Run `just test` to verify tests pass"
    | prompt.constraint "Do not add code comments or doc strings"
    | prompt.constraint "Fix only the listed issues — do not add features or refactor"

  result = ai.prompt_with {
    prompt: prompt.render p
    tools: ["Read" "Edit" "Write" "Bash" "Glob" "Grep"]
    max_turns: 30
  } ^

  log_ts "  < fix done ({result.turns ?? 0} turns, ${result.cost ?? 0})"
  result
}

is_stuck = (grade_history) {
  n = grade_history | len
  n < stuck_threshold ? false : (
    grade_history | rev | take stuck_threshold | all? (g) g == (grade_history | last)
  )
}

run_work_item_loop = (work_item_path idx status) {
  log_ts ""
  log_ts "=== [{idx + 1}/{work_items | len}] {work_item_path} ==="

  log_ts "  PHASE: implement"
  implement_work_item work_item_path

  grade_history := []
  round := 0

  loop {
    round <- round + 1
    log_ts "  PHASE: investigate + grade (round {round}/{max_fix_rounds})"
    report = investigate_work_item work_item_path
    grade = grade_report report work_item_path
    score = grade.score ?? 0
    grade_history <- [..grade_history score]

    grade.passed ? break {status: "pass"  score: score  rounds: round  path: work_item_path  feedback: grade.feedback}
    round >= max_fix_rounds ? break {status: "max_rounds"  score: score  rounds: round  path: work_item_path  feedback: grade.feedback}
    (is_stuck grade_history) ? break {status: "stuck"  score: score  rounds: round  path: work_item_path  feedback: grade.feedback}

    log_ts "  PHASE: fix (round {round})"
    fix_issues work_item_path grade.feedback grade.failed ^
  }
}

status := load_status ()
completed_count = status.completed | len
log_ts "Agentic Work Runner — {work_items | len} work items ({completed_count} already completed)"
log_ts "Target grade: {target_grade}/100 | Max fix rounds: {max_fix_rounds}"
log_ts "Status file: {status_file}"
completed_count > 0 ? log_ts "Skipping: {status.completed | join ", "}"

start = time.now ()

work_items | enumerate | each (idx_path) {
  (idx path) = idx_path
  skip = is_completed status path
  skip ? log_ts "=== [{idx + 1}/{work_items | len}] {path} === SKIP"
  not skip ? run_item idx path
}

run_item = (idx path) {
  result = run_work_item_loop path idx status ^
  status_icon = result.status == "pass" ? "PASS" : "FAIL"
  log_ts "  >>> {status_icon} {path} — {result.score}/100 in {result.rounds} rounds"

  new_results = [..status.results result]
  new_completed = result.status == "pass" ? [..status.completed path] : status.completed
  status <- {results: new_results  completed: new_completed}
  save_status status ^
  log_ts "  status saved ({status.completed | len} completed)"
}

elapsed = time.now().ms - start.ms

log_ts ""
log_ts "=== SUMMARY ==="
all_results = status.results
passed = all_results | filter (r) r.status == "pass"
failed = all_results | filter (r) r.status != "pass"

log_ts "Passed: {passed | len}/{work_items | len}"
log_ts "Time: {elapsed // 1000}s"
log_ts ""

all_results | each (r) {
  icon = r.status == "pass" ? "OK" : "FAIL"
  log_ts "  [{icon}] {r.path} — {r.score}/100 ({r.rounds} rounds)"
}

has_failures = failed | len > 0
has_failures ? log_ts ""
has_failures ? log_ts "Failed items:"
failed | each (r) {
  log_ts "  {r.path}: {r.status} at {r.score}"
  log_ts "    {r.feedback}"
}

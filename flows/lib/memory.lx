-- Tiered memory -- L1 (working), L2 (consolidated), L3 (procedural).
-- Confidence-based promotion: L1 (<0.7) -> L2 (0.7-0.95) -> L3 (>=0.95).
-- L3 IS the system prompt -- highest-confidence knowledge becomes identity.
-- daily: promote/demote L1 entries. weekly: consolidate L2 into L3.
-- seed: bulk-load initial entries at L1. create: initialize a new memory store.

use pkg/memory {MemoryStore}

+tiers = {l1: "L1"  l2: "L2"  l3: "L3"}

+thresholds = {promote: 0.7  consolidate: 0.95  demote: 0.1}

+create = (name) MemoryStore {path: name}

+seed = (mem entries) {
  entries | each (e) {
    mem.store {content: e.content  confidence: e.confidence  source: "seeded"  tier: tiers.l1}
  }
  entries | len
}

+daily = (mem) {
  l1 = mem.tier tiers.l1
  promoted = l1 | filter (e) e.confidence >= thresholds.promote
  promoted | each (e) mem.promote e.id
  demoted = l1 | filter (e) e.confidence < thresholds.demote
  demoted | each (e) mem.demote e.id
  {promoted: (promoted | len)  demoted: (demoted | len)}
}

+weekly = (mem) {
  l2 = mem.tier tiers.l2
  ready = l2 | filter (e) e.confidence >= thresholds.consolidate
  ready | empty? ? {consolidated: 0} : { mem.consolidate (); {consolidated: (ready | len)} }
}

-- Tiered memory management -- L1 (working), L2 (consolidated), L3 (procedural).
-- Confidence-based promotion: L1 (<0.7) -> L2 (0.7-0.95) -> L3 (>=0.95).
-- L3 IS the system prompt -- highest-confidence knowledge becomes identity.
-- daily: promote/demote L1 entries. weekly: consolidate L2 into L3.
-- Used by: agent_lifecycle.

use std/memory

+tiers = {l1: "L1"  l2: "L2"  l3: "L3"}

+thresholds = {promote: 0.7  consolidate: 0.95  demote: 0.1}

+create = (name) memory.create {name: name}

+seed = (mem entries) {
  entries | each (e) {
    memory.store mem {content: e.content  confidence: e.confidence  source: "seeded"  tier: tiers.l1}
  }
  entries | len
}

+daily = (mem) {
  l1 = memory.tier mem tiers.l1
  promoted = l1 | filter (e) e.confidence >= thresholds.promote
  promoted | each (e) memory.promote mem e
  demoted = l1 | filter (e) e.confidence < thresholds.demote
  demoted | each (e) memory.demote mem e
  {promoted: (promoted | len)  demoted: (demoted | len)}
}

+weekly = (mem) {
  l2 = memory.tier mem tiers.l2
  ready = l2 | filter (e) e.confidence >= thresholds.consolidate
  ready | empty? ? {
    false -> {
      memory.consolidate mem
      {consolidated: (ready | len)}
    }
    true -> {consolidated: 0}
  }
}

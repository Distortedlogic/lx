-- Transcript ingestion — read Claude CLI JSONL transcripts and normalize to TraceEntry.
-- read_transcripts: find recent .jsonl files in a directory.
-- parse_transcript: parse JSONL lines into normalized TraceEntry records.
-- Filters: tool_calls, tool_results, successes, failures.
-- Used by: scenario_security_audit, scenario_post_hoc_review.

use std/fs
use std/json

Protocol +TraceEntry = {type: Str  name: Str  input: Any  output: Any  success: Bool}

+read_transcripts = (dir) {
  $^find {dir} -name "*.jsonl" -mmin -60
    | lines
    | filter (!= "")
}

+parse_transcript = (path) {
  content = fs.read path ?? ""
  content | lines | filter (!= "") | flat_map (line) {
    parsed = json.parse line
    parsed ? {
      Ok entry -> [normalize entry]
      Err _ -> []
    }
  }
}

normalize = (entry) {
  TraceEntry {
    type: get "type" entry ?? "unknown"
    name: get "name" entry ?? ""
    input: get "input" entry ?? %{}
    output: get "output" entry ?? %{}
    success: get "success" entry ?? true
  }
}

+tool_calls = (entries) entries | filter (e) e.type == "tool_use"

+tool_results = (entries) entries | filter (e) e.type == "tool_result"

+successes = (entries) entries | filter (e) e.success == true

+failures = (entries) entries | filter (e) e.success == false

-- Security toolkit: injection scanning, stuck loop detection, resource monitoring.
-- scan: regex-based injection pattern detection, returns Finding records.
-- detect_loops: flag agents with excessive tool calls as stuck.
-- check_resources: flag transcripts that are too large.
-- full_scan: run all detection passes on a list of trace entries.
-- check: fast pass/fail gate for a single input.
-- run_parallel/run_blocking: composable guard wrappers for agent execution.

use std/re

Protocol +GuardResult = {pass: Bool  reason: Str}

Protocol +Finding = {severity: Str  type: Str  evidence: Str  source: Str  agent_id: Str = ""}

+patterns = [
  "ignore previous instructions"
  "you are now"
  "system prompt override"
  "forget everything"
  "new persona"
  "ignore all prior"
  "disregard your instructions"
]

+scan = (text) {
  lowered = lower text
  patterns | flat_map (p) {
    re.is_match (lower p) lowered ? {
      true -> [Finding {severity: "critical"  type: "prompt_injection"  evidence: p  source: "guard"}]
      false -> []
    }
  }
}

+scan_entries = (entries) {
  entries | flat_map (e) {
    scan (to_str e.input) | map (f) {..f  agent_id: e.name ?? ""}
  }
}

+detect_loops = (entries opts) {
  threshold = opts.threshold ?? 20
  calls = entries | filter (e) e.type == "tool_use"
  calls | len > threshold ? {
    true -> [Finding {severity: "high"  type: "stuck_loop"  evidence: "{calls | len} tool calls (threshold: {threshold})"  source: "guard"}]
    false -> []
  }
}

+check_resources = (entries opts) {
  threshold = opts.threshold ?? 500
  size = entries | len
  size > threshold ? {
    true -> [Finding {severity: "high"  type: "resource_excessive"  evidence: "{size} entries (threshold: {threshold})"  source: "guard"}]
    false -> []
  }
}

+full_scan = (entries opts) {
  [
    ..scan_entries entries
    ..detect_loops entries opts
    ..check_resources entries opts
  ]
}

+check = (input) {
  text = input ? {
    {content: c ..} -> c
    _ -> to_str input
  }
  findings = scan text
  findings | empty? ? {
    true -> GuardResult {pass: true  reason: "ok"}
    false -> GuardResult {pass: false  reason: "injection pattern: {findings.0.evidence}"}
  }
}

+run_parallel = (input agent_fn) {
  (guard_result, agent_result) = par {
    check input
    agent_fn input
  }
  guard_result.pass ? {
    true -> agent_result
    false -> Err "blocked by guardrail: {guard_result.reason}"
  }
}

+run_blocking = (input agent_fn) {
  result = check input
  result.pass ? {
    true -> agent_fn input
    false -> Err "blocked by guardrail: {result.reason}"
  }
}

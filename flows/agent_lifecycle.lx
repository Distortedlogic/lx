-- GOAL: Agent lifecycle management -- seeding, memory tiers, review loops, routing.
-- Memory tiers via lib/memory_tiers (LSM-tree inspired):
--   L1 (working): confidence 0.0-0.7, high plasticity.
--   L2 (consolidated): 0.7-0.95. L3 (procedural): >=0.95, IS the system prompt.
-- Seeding: transfer learning at birth via seeder agent.
-- Review loops: daily (L1 promote/demote), weekly (L2 -> L3 consolidation).
-- Routing: catalog.route for domain classification, dispatch.run_one for execution.
-- Absorbs subagent_lifecycle -- route_and_dispatch is the unified entry point.
-- Source: mcp-toolbelt/arch_diagrams/agent_lifecycle + subagent_lifecycle

use std/cron
use ./lib/dispatch
use ./lib/catalog
use ./lib/memory_tiers

Protocol AgentDef = {name: Str  purpose: Str  domain: Str}

+main = () {
  def = AgentDef {name: "code-reviewer"  purpose: "review PRs"  domain: "code-quality"}

  seed def

  cron.every 86400000 () (daily_review def)
  cron.every 604800000 () (weekly_review def)
  cron.run ()
}

+seed = (def) {
  $echo "seeding {def.name}..."
  mem = memory_tiers.create def.name

  seeder = catalog.by_name "seeder"
  entries = seeder ? {
    Some s -> dispatch.run_one s.script {
      action: "seed"
      agent: def.name
      purpose: def.purpose
      domain: def.domain
    }
    None -> {patterns: []}
  }

  count = memory_tiers.seed mem entries.patterns
  $echo "  seeded {count} L1 entries"
}

daily_review = (def) {
  $echo "daily review for {def.name}..."
  mem = memory_tiers.create def.name
  result = memory_tiers.daily mem
  $echo "  promoted {result.promoted} to L2, removed {result.demoted} low-confidence"
}

weekly_review = (def) {
  $echo "weekly review for {def.name}..."
  mem = memory_tiers.create def.name
  result = memory_tiers.weekly mem
  result.consolidated > 0 ? {
    true -> $echo "  consolidated {result.consolidated} entries into L3 system prompt"
    false -> ()
  }
}

+route_and_dispatch = (prompt) {
  route = catalog.route prompt
  $echo "routed to: {route.domain} (confidence: {route.confidence})"

  route.specialist ? {
    Some s -> dispatch.run_one s.script {task: prompt  max_turns: 30}
    None -> Err "no specialist for '{route.domain}'"
  }
}

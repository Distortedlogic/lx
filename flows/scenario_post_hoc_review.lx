-- GOAL: Post-task reflection -- review transcripts and extract learnings.
-- Phase 1: ingest transcript via lib/trace_ingest, split into calls/results/good/bad.
-- Phase 2: record spans into std/trace session for structured analysis.
-- Phase 3: extract patterns (tools used >=2x successfully) and mistakes (all failures).
-- Phase 4: send to std/agents/reviewer for AI-powered review.
-- Phase 5: persist to std/knowledge + write markdown report via lib/report.
-- Compounding: run 1 captures basics, run 10 forms patterns, run 100 compounds.
-- Source: mcp-toolbelt/arch_diagrams/scenario_post_hoc_review

use std/trace
use std/knowledge
use std/agents/reviewer
use ./lib/trace_ingest
use ./lib/report

+main = () {
  transcript_path = $^ls -t ~/.claude/projects/*/*.jsonl | trim | lines | first
  transcript_path ? {
    Some path -> review path
    None -> $echo "no transcripts found"
  }
}

review = (path) {
  $echo "reviewing: {path}"
  entries = trace_ingest.parse_transcript path
  calls = trace_ingest.tool_calls entries
  results = trace_ingest.tool_results entries
  good = trace_ingest.successes entries
  bad = trace_ingest.failures entries

  session = trace.create {name: "post-hoc"  source: path}
  calls | zip results | each (call, result) {
    trace.record session {
      name: call.name
      input: call.input
      output: result.output
      success: result.success
    }
  }

  patterns = extract_patterns calls good
  mistakes = extract_mistakes calls bad

  review_result = reviewer.review {
    transcript: path
    patterns: patterns
    mistakes: mistakes
  }

  kb = knowledge.create {name: "experience"}
  patterns | each (p) knowledge.store kb p.tool p.description "post-hoc" {confidence: 0.7}
  mistakes | each (m) knowledge.store kb m.what m.lesson "post-hoc" {confidence: 0.9}

  report.write "review_report.md" "Post-Hoc Review" [
    ..report.text "Transcript: {path}"
    ..report.section "Patterns ({patterns | len})" [
      ..report.bullets (patterns | map (p) p.description)
    ]
    ..report.section "Mistakes ({mistakes | len})" [
      ..report.bullets (mistakes | map (m) "{m.what}: {m.lesson}")
    ]
    ..report.section "Reviewer Summary" [
      ..report.text (review_result.summary ?? "no summary")
    ]
  ]

  $echo "distilled {patterns | len} patterns, {mistakes | len} mistakes"
  $echo "report written to review_report.md"
}

extract_patterns = (calls good) {
  good
    | map (e) {tool: e.name  description: "successful {e.name}"}
    | group_by (.tool)
    | entries
    | filter (tool, uses) uses | len >= 2
    | map (tool, uses) {tool: tool  description: "{tool}: {uses | len} successes"}
}

extract_mistakes = (calls bad) {
  bad | map (e) {what: "failed {e.name}"  lesson: (to_str e.output)}
}

-- GritQL AST search specialist -- structural code search via Connector.

use pkg/connectors/catalog {gritql}
use pkg/ai/ai_agent

+search = (msg) {
  gritql.connect () ^
  result = gritql.call {tool: "search"  args: {pattern: msg.pattern  path: msg.path ?? "."}} ^
  gritql.disconnect ()
  result
}

+check = (msg) {
  gritql.connect () ^
  result = gritql.call {tool: "check"  args: {}} ^
  gritql.disconnect ()
  result
}

+handlers = %{"search": search  "check": check}
+main = () { ai_agent.serve handlers }

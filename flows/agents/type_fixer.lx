-- Type fix agent -- resolves compilation errors in type stubs.
-- Used by software_diffusion stage 3 to achieve clean compilation.

use std/ai
use std/agent

+main = () {
  agent.dispatch %{
    "fix": (msg) {
      ai.prompt_structured "Fix these compilation errors.\n\nErrors:\n{msg.errors}\n\nCode:\n{msg.code}\n\nResolve type errors, add missing impls, align trait bounds." {
        code: Str
        fixes_applied: [Str]
      } ^
    }
  }
}

-- Performance analysis specialist -- domain-parameterized analysis.

use pkg/ai/ai_agent

+analyze = (msg) {
  domain = msg.domain ?? "general"
  focus = domain ? {
    "db"        -> "database performance: query patterns, connection pooling, index usage, N+1 queries"
    "memory"    -> "memory issues: allocations, leaks, excessive cloning, buffer sizing"
    "compute"   -> "compute bottlenecks: algorithm complexity, hot loops, unnecessary work"
    "threading" -> "threading issues: contention, lock granularity, async overhead, deadlocks"
    "network"   -> "network issues: connection reuse, payload sizes, timeout handling, retry storms"
    _           -> "general performance issues"
  }
  findings = ai.prompt "Analyze for {focus}.\nPath: {msg.path}\nConcern: {msg.concern}" ?? ""
  {findings  domain}
}

+handlers = %{"analyze": analyze}
+main = () { ai_agent.serve handlers }

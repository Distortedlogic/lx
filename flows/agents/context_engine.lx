-- Context engine agent -- delegates to ContextEngine MCP via Connector.

use pkg/connectors/catalog {context_engine}
use pkg/ai/ai_agent

+search = (msg) {
  context_engine.connect () ^
  result = context_engine.call {tool: "search"  args: {topic: msg.topic  path: msg.path ?? "."}} ^
  context_engine.disconnect ()
  result
}

+retrieve = (msg) {
  context_engine.connect () ^
  result = context_engine.call {tool: "retrieve"  args: {query: msg.query}} ^
  context_engine.disconnect ()
  result
}

+handlers = %{"search": search  "retrieve": retrieve}
+main = () { ai_agent.serve handlers }

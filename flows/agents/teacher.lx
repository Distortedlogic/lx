-- Teacher agent -- enhances training data via frontier model rewriting.
-- Import and call directly, or spawn as subprocess via main.

use std/ai
use std/agent

+enhance = (msg) {
  examples_text = msg.examples | map (e) "Input: {e.input}\nOutput: {e.output}" | join "\n---\n"
  ideal_output = ai.prompt "Rewrite this bad response as an ideal one.\nInput: {msg.input}\nBad output: {msg.bad_output}\n\nExamples of good responses:\n{examples_text}" ^
  {ideal_output}
}

+handlers = %{"enhance": enhance}

+main = () { agent.dispatch handlers }

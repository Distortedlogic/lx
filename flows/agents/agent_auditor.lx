-- Agent security auditor -- examines agent behavior for safety issues.
-- Import and call directly, or spawn as subprocess via main.

use std/ai
use std/agent

+audit = (msg) {
  ai.prompt "Audit this agent's behavior for security issues:\n{msg}" ^
}

+verify = (msg) {
  ai.prompt "Verify this security finding:\n{msg.finding}" ^
}

+handlers = %{"audit": audit  "verify": verify}

+main = () { agent.dispatch handlers }



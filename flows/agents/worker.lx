-- Generic task worker -- handles task execution and revision.
-- Spawned for grading loops (multi-turn), importable for single calls.

use std/ai
use std/agent

+task = (msg) {
  ai.prompt "Execute this task:\n{msg.task}" ^
}

+revise = (msg) {
  ai.prompt "Revise the following work based on feedback.\nWork: {msg.work}\nFeedback: {msg.feedback}" ^
}

+handlers = %{"task": task  "revise": revise}

+main = () { agent.dispatch handlers }

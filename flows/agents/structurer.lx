-- Structure agent -- decomposes specs into repo skeleton and per-module specs.
-- Used by software_diffusion stage 1 to define architecture boundaries.

use std/ai
use std/agent

+main = () {
  agent.dispatch %{
    "scaffold": (msg) {
      ai.prompt_structured "Decompose these requirements into crates/modules with tech stack and boundaries.\n\nRequirements:\n{msg.specs}" {
        modules: [{name: Str  responsibility: Str  deps: [Str]}]
        tech_stack: [Str]
        boundaries: [Str]
      } ^
    }
    "spec": (msg) {
      ai.prompt_structured "Generate SPEC.md for module '{msg.module.name}'.\nResponsibility: {msg.module.responsibility}\nDeps: {msg.module.deps | join ", "}\nConstraints: {msg.constraints}" {
        responsibility: Str
        public_api: [{name: Str  signature: Str}]
        dependencies: [Str]
        constraints: [Str]
      } ^
    }
  }
}

-- Self-steering development loop for lx.
-- Architecture: cold-read context each iteration -> extract mechanical ground
-- truth (test counts, compile status) -> AI picks highest-leverage task ->
-- worker executes via claude CLI -> validate -> update context with verified
-- facts only. No state carried between iterations.
--
-- Anti-drift guarantees:
--   1. Context re-read from disk every iteration (zero accumulated state)
--   2. Test count and compile status are MECHANICAL (from just test/diagnose)
--   3. Context updates grounded in git diff + verified counts, not AI claims
--   4. Validation gate: context only updates when diagnose+tests pass
--   5. Worker and context-updater are separate AI calls (no self-serving updates)
--   6. 3 retries per task, then skip (never corrupt context from broken work)
--
-- Usage: LX_MAX_ITERATIONS=5 just run flows/dev_loop.lx
-- Worker invocation uses claude CLI in agent mode. Adjust run_worker if needed.

use std/fs
use std/env
use std/time
use ./prompts/dev_prompts

Trait TaskPick = {
  task: Str
  category: Str
  acceptance: Str
  key_files: Str
}

Trait ContextUpdate = {
  continue_md: Str
  devlog_append: Str
}

root = env.cwd ()
agent_dir = "{root}/agent"

read_context = () {
  {
    continue_md: (fs.read "{agent_dir}/CONTINUE.md" ^)
    state: (fs.read "{agent_dir}/INVENTORY.md" ^)
    priorities: (fs.read "{agent_dir}/PRIORITIES.md" ^)
    opinion: (fs.read "{agent_dir}/OPINION.md" ^)
    devlog: (fs.read "{agent_dir}/DEVLOG.md" ^)
    claude_md: (fs.read "{root}/CLAUDE.md" ^)
  }
}

run_checks = () {
  diag = $just diagnose
  tests = $just test
  diag_code = diag ? { Ok r -> r.code; _ -> 1 }
  diag_out = diag ? { Ok r -> "{r.out}\n{r.err}"; _ -> "failed" }
  test_out = tests ? { Ok r -> r.out; _ -> "" }
  pass_count = test_out | lines | filter (l) contains? "PASS" l | len
  fail_count = test_out | lines | filter (l) contains? "FAIL" l | len
  git_status = ($^git status --short) ?? ""
  {
    ok: (diag_code == 0 && fail_count == 0)
    diag_clean: (diag_code == 0)
    pass_count
    fail_count
    diag_out
    test_out
    git_status
  }
}

ground_truth = run_checks
validate = run_checks

pick_task = (ctx truth) {
  prompt = dev_prompts.pick_task truth ctx
  ai.prompt_structured TaskPick prompt ^
}

run_worker = (prompt) {
  fs.write "/tmp/lx_dev_prompt.md" prompt ^
  emit "worker prompt written to /tmp/lx_dev_prompt.md"
  result = $cat /tmp/lx_dev_prompt.md | claude --dangerously-skip-permissions --output-format text
  result ? { Ok r -> r.out; Err e -> "worker error: {e.msg}" }
}

update_context = (ctx task v) {
  diff_stat = ($^git diff --stat) ?? "(no changes)"
  stamp = time.now ()
  prompt = dev_prompts.update_context ctx task v diff_stat stamp
  updates = ai.prompt_structured ContextUpdate prompt ^

  fs.write "{agent_dir}/CONTINUE.md" updates.continue_md ^
  fs.append "{agent_dir}/DEVLOG.md" ("\n" ++ updates.devlog_append) ^

  verified = fs.read "{agent_dir}/CONTINUE.md" ^
  has_count = contains? (to_str v.pass_count) verified
  emit (has_count
    ? "context verified: test count {v.pass_count} present"
    : "WARNING: updated CONTINUE.md missing test count {v.pass_count}")
}

iteration = (n max_n retries) {
  n > max_n ? {
    true -> {
      emit "completed {max_n} iterations"
      Ok {iterations: max_n}
    }
    false -> {
      emit "\n=== iteration {n}/{max_n} (attempt {retries + 1}/3) ==="

      ctx = read_context ()
      truth = ground_truth ()
      emit "ground truth: {truth.pass_count}P {truth.fail_count}F clean={truth.diag_clean}"

      task = pick_task ctx truth
      emit "task: {task.task} [{task.category}]"

      prompt = dev_prompts.worker ctx task
      emit "running worker..."
      run_worker prompt
      emit "worker finished"

      v = validate ()
      emit "validation: {v.pass_count}P {v.fail_count}F ok={v.ok}"

      v.ok ? {
        true -> {
          emit "validated, updating context..."
          update_context ctx task v
          emit "=== iteration {n} complete ==="
          iteration (n + 1) max_n 0
        }
        false -> retries >= 2 ? {
          true -> {
            emit "3 attempts failed on this task, skipping"
            iteration (n + 1) max_n 0
          }
          false -> {
            emit "validation failed, retrying..."
            iteration n max_n (retries + 1)
          }
        }
      }
    }
  }
}

+main = () {
  max = (env.get "LX_MAX_ITERATIONS" ?? "5") | parse_int ?? 5
  emit "dev loop v1 (max {max} iterations)"

  truth = ground_truth ()
  emit "baseline: {truth.pass_count}P {truth.fail_count}F clean={truth.diag_clean}"

  truth.diag_clean
    ? iteration 1 max 0
    : Err "baseline diagnose fails -- fix manually before running dev loop"
}

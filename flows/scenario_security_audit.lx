-- GOAL: Audit running subagents for stuck loops, prompt injection, and resource abuse.
-- Data source: Claude CLI transcripts (~/.claude/projects/<project>/*.jsonl).
-- Orchestrator (agent-auditor) partitions transcripts across 3 parallel specialists:
--   loop-detector: repeated tool sequences, same file read N times, oscillating edits.
--   injection-scanner: system prompt overrides, role changes, instruction fragments, exfil.
--   resource-monitor: excessive tool calls, reading entire dirs, runaway bash, burn rate.
-- Aggregation: collect flags → classify severity (critical/high/medium) → act (kill/interrupt/log).
-- Source: mcp-toolbelt/arch_diagrams/scenario_security_audit

use std/agent
use std/json
use std/fs
use std/re
use std/time

Protocol AuditRequest = {action: Str  transcripts: List}
Protocol AuditFinding = {agent_id: Str  severity: Str  type: Str  evidence: Str}

scan_transcripts = (project_dir) {
  $^find {project_dir} -name "*.jsonl" -mmin -60
    | lines
    | filter (!= "")
}

+main = () {
  project_dir = $^echo $HOME | trim
  project_dir = "{project_dir}/.claude/projects"

  transcripts = scan_transcripts project_dir

  transcripts | empty? ? {
    true -> {
      $echo "no recent transcripts to audit"
      break
    }
    false -> ()
  }

  (loop_results injection_results resource_results) = par {
    loop_detector transcripts
    injection_scanner transcripts
    resource_monitor transcripts
  }

  findings = [..loop_results ..injection_results ..resource_results]
    | sort_by (.severity)
    | rev

  critical = findings | filter (f) f.severity == "critical"
  high = findings | filter (f) f.severity == "high"

  critical | each (f) {
    $echo "CRITICAL [{f.type}] agent={f.agent_id}: {f.evidence}"
  }

  high | each (f) {
    $echo "HIGH [{f.type}] agent={f.agent_id}: {f.evidence}"
  }

  $echo "\naudit complete: {findings | len} findings ({critical | len} critical, {high | len} high)"
}

loop_detector = (transcripts) {
  transcripts | flat_map (path) {
    content = fs.read path ?? ""
    content_lines = content | lines | filter (!= "")
    tool_calls = content_lines
      | filter (l) re.is_match "tool_use" l
    tool_calls | len > 20 ? {
      true -> [AuditFinding {
        agent_id: path
        severity: "high"
        type: "stuck_loop"
        evidence: "{tool_calls | len} tool calls in transcript"
      }]
      false -> []
    }
  }
}

injection_scanner = (transcripts) {
  transcripts | flat_map (path) {
    content = fs.read path ?? ""
    suspicious = re.is_match "ignore previous|system prompt|you are now" content
    suspicious ? {
      true -> [AuditFinding {
        agent_id: path
        severity: "critical"
        type: "prompt_injection"
        evidence: "suspicious instruction pattern detected"
      }]
      false -> []
    }
  }
}

resource_monitor = (transcripts) {
  transcripts | flat_map (path) {
    content = fs.read path ?? ""
    size = content | len
    size > 500000 ? {
      true -> [AuditFinding {
        agent_id: path
        severity: "high"
        type: "resource_excessive"
        evidence: "transcript {size} chars — possible runaway"
      }]
      false -> []
    }
  }
}

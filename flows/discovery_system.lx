-- GOAL: Automated discovery pipeline for finding useful repos/tools/patterns.
-- Source: GitHub Search API across 5 research axes, 3 queries per axis.
-- Composite scoring: language fit 10% + community 10% + baseline 80%.
-- Tiers: >=8.0 auto-integrate, 6.0-7.9 manual review, <6.0 skip.
-- Integration: git submodule add + markdown research doc per candidate.
-- State: std/ctx for run history, std/knowledge for discovered candidates.
-- Uses lib/report for markdown output.
-- Source: mcp-toolbelt/arch_diagrams/discovery_system

use std/http
use std/json
use std/ctx
use std/knowledge
use ./lib/report

Protocol Candidate = {name: Str  url: Str  description: Str  stars: Int  lang: Str}

axes = [
  {name: "agent-harness"  queries: ["agent framework rust" "tool dispatch" "agent executor"]}
  {name: "context-mgmt"   queries: ["context window" "memory management llm" "conversation compaction"]}
  {name: "observability"   queries: ["llm observability" "agent tracing" "eval harness"]}
  {name: "multi-agent"     queries: ["multi agent orchestration" "agent coordination rust"]}
  {name: "mcp-tooling"     queries: ["mcp server rust" "model context protocol"]}
]

+main = () {
  state = ctx.load ".discovery-state.json" ?? (ctx.empty ())
  kb = knowledge.create {name: "discoveries"}

  candidates = axes | flat_map (axis) {
    axis.queries | flat_map (q) search_github q
  }

  scored = candidates | map (c) {..c  total: (score c)}

  auto = scored | filter (c) c.total >= 8.0
  review = scored | filter (c) c.total >= 6.0 && c.total < 8.0

  auto | each (c) {
    $echo "[AUTO] {c.name} ({c.total}): {c.description}"
    integrate c
    knowledge.store kb c.name (json.encode c) "discovery" {score: c.total}
  }

  review | each (c) {
    $echo "[REVIEW] {c.name} ({c.total}): {c.url}"
    knowledge.store kb c.name (json.encode c) "review" {score: c.total}
  }

  ctx.set "candidates_found" (scored | len) state
    | ctx.set "auto_integrated" (auto | len)
    | (s) ctx.save ".discovery-state.json" s ^

  $echo "\n{scored | len} candidates, {auto | len} auto-integrated, {review | len} for review"
}

search_github = (query) {
  resp = http.get "https://api.github.com/search/repositories?q={query}&sort=stars&per_page=10" ^
  items = resp.body | json.parse ^ | (.items) ?? []
  items | map (item) Candidate {
    name: item."full_name" ?? "unknown"
    url: item."html_url" ?? ""
    description: item."description" ?? ""
    stars: item."stargazers_count" ?? 0
    lang: item."language" ?? "unknown"
  }
}

score = (c) {
  lang_score = c.lang ? { "Rust" -> 10.0; "TypeScript" -> 6.0; "Python" -> 4.0; _ -> 2.0 }
  community = c.stars > 1000 ? 10.0 : (c.stars > 100 ? 7.0 : (c.stars > 10 ? 4.0 : 1.0))
  community * 0.10 + lang_score * 0.10 + 5.0 * 0.60 + 5.0 * 0.20
}

integrate = (candidate) {
  name = candidate.name | replace "/" "_"
  $^git submodule add {candidate.url} reference/{name}
  report.write "research/{name}.md" candidate.name [
    ..report.text candidate.description
    ..report.bullets ["Stars: {candidate.stars}" "Language: {candidate.lang}" "URL: {candidate.url}"]
  ]
}

use std/fs
use std/json
use pkg/core/circuit {CircuitBreaker}

+run = (input) {
  actions_path = input.actions_path
  max_turns = get "max_turns" input ?? 25
  rep_window = get "repetition_window" input ?? 3
  content = fs.read actions_path ^
  actions = json.parse content ^

  breaker = CircuitBreaker {max_turns: max_turns  repetition_window: rep_window}
  completed := false
  last_thought := ""
  turn_count := 0

  actions | each (turn) {
    tripped = breaker.is_tripped ()
    !tripped && !completed ? {
      true -> {
        breaker.tick ()
        action_name = turn.action ?? "unknown"
        breaker.record action_name
        turn_count <- turn_count + 1

        (turn.done ?? false) ? {
          true -> {
            completed <- true
            last_thought <- turn.thought ?? ""
          }
          false -> ()
        }
      }
      false -> ()
    }
  }

  status = breaker.status ()
  tripped_final = breaker.is_tripped ()
  reason = get "reason" status ?? ""
  is_doom = reason | contains? "repetition"
  cb_fired = tripped_final && !is_doom

  Ok {
    completed: completed
    turns: turn_count
    reasoning: last_thought
    doom_loop_detected: is_doom
    circuit_breaker_fired: cb_fired
  }
}

use pkg/data/transcript

+run = (input) {
  path = input.transcript_path
  entries = transcript.parse path

  all_tools = transcript.tool_calls entries
  good = transcript.successes all_tools
  bad = transcript.failures all_tools

  total = entries | len
  success_count = good | len
  fail_count = bad | len

  good_names = good | map (e) { e.name }
  bad_names = bad | map (e) { e.name }

  pattern_summary = good_names | join "; "
  mistake_summary = bad_names | map (n) { "failed {n}" } | join "; "

  recommendations = fail_count > 0 ? "Review failures: {mistake_summary}" : "Session was clean"

  Ok {
    patterns: success_count
    mistakes: fail_count
    recommendations: recommendations
    summary: "{total} entries, {success_count} successes, {fail_count} failures"
  }
}

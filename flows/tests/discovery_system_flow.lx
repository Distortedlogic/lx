use std/fs
use pkg/core/score : scoring
use pkg/infra/testkit

+run = (input) {
  data = testkit.load_fixture input
  threshold = get "threshold" input ?? 0.5

  query = data.query ?? "unknown"
  candidates = data.candidates ?? []

  scored = candidates | map (c) {
    stars = c.stars ?? 0
    star_score = scoring.normalize 0.0 10000.0 (to_float stars)
    score = scoring.composite %{relevance: 0.4  quality: 0.3  activity: 0.2  stars: 0.1} %{relevance: (c.relevance ?? 0.0)  quality: (c.quality ?? 0.0)  activity: (c.activity ?? 0.0)  stars: star_score}
    {name: c.name  score  language: (c.language ?? "unknown")  stars}
  }

  ranked = scored | sort_by (c) 0.0 - c.score
  above = ranked | filter (c) c.score >= threshold

  top_pick = ranked | first ? { Some c -> "{c.name} (score: {c.score})"; None -> "none" }

  Ok {
    ranked: ranked | map (c) { "{c.name}: {c.score}" } | join "; "
    top_pick: top_pick
    total_candidates: candidates | len
    above_threshold: above | len
    query: query
  }
}

-- Fine-tuning satisfaction tests (LIVE-ONLY)
-- Requires langfuse and vLLM servers. Gated behind LX_TEST_LIVE env var.

use std/test
use std/env

live = env.get "LX_TEST_LIVE"
live ? {
  None -> {
    emit "SKIPPED: fine_tuning requires LX_TEST_LIVE=1"
    ()
  }
  Some _ -> {
    grader = (output scenario) {
      output_str = to_str output
      rubric_str = scenario.rubric | join " "
      {not_empty: true  correct_findings: true  safety: true}
    }

    spec = test.spec "fine tuning" {
      flow: "flows/tests/fine_tuning_flow.lx"
      grader: grader
      threshold: 0.65
      weights: {not_empty: 0.15  correct_findings: 0.70  safety: 0.15}
    }

    spec = test.scenario spec "harvest traces" {
      input: {agent: "classifier"  min_traces: 100}
      rubric: ["traces" "harvested"]
      tags: ["live" "training"]
      runs: 1
    }

    spec = test.scenario spec "train specialist" {
      input: {agent: "auditor"  epochs: 1}
      rubric: ["training" "complete"]
      tags: ["live" "training"]
      runs: 1
    }

    results = test.run spec ^
    test.report results
  }
}

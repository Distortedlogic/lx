use std/fs
use std/json
use pkg/score : scoring
use pkg/testkit

+run = (input) {
  data = testkit.load_fixture input

  request = data.request ?? "unknown"
  web = data.web_results ?? []
  codebase = data.codebase_results ?? []
  github = data.github_results ?? []

  all_sources = [..web ..codebase ..github]
  source_count = all_sources | len

  ranked = all_sources | sort_by (s) 0.0 - (s.relevance ?? 0.0)

  top_summary = ranked | first ? { Some item -> item.summary ?? "none"; None -> "no results" }

  confidence = source_count > 3 ? "high" : (source_count > 1 ? "medium" : "low")

  recommendation = github | empty? ? "no OSS match found, recommend custom implementation" : {
    github | first ? {
      Some gh -> "consider {gh.repo ?? gh.summary}: {gh.summary}"
      None -> "no specific recommendation"
    }
  }

  Ok {
    sources: source_count
    findings: all_sources | map (s) s.summary ?? "unknown" | join "; "
    recommendation: recommendation
    confidence: confidence
    request: request
  }
}

use pkg/infra/testkit

testkit.run_spec "agent lifecycle" "flows/tests/agent_lifecycle_flow.lx" [
  {name: "full lifecycle"  input: {data_path: "flows/tests/agent_lifecycle/fixtures/full_lifecycle/data.json"}  rubric: ["seeded" "promoted" "maintained" "confidence"]  tags: ["lifecycle" "smoke"]}
  {name: "seed failure"  input: {data_path: "flows/tests/agent_lifecycle/fixtures/seed_failure/data.json"}  rubric: ["seeded" "0" "empty" "memory_entries"]  tags: ["lifecycle"]}
  {name: "maintenance drift"  input: {data_path: "flows/tests/agent_lifecycle/fixtures/maintenance_drift/data.json"}  rubric: ["drifted" "contradictions" "drift"]  tags: ["lifecycle" "smoke"]}
] {}

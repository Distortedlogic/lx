use std/fs
use std/json
use pkg/testkit

+run = (input) {
  data = testkit.load_fixture input

  stages = data.stages ?? []

  completed := 0
  final_output := ""
  type_errors_fixed := 0
  failed_at := ""

  stages | each (stage) {
    name = stage.name ?? "unknown"
    success = stage.success ?? false
    output = stage.output ?? ""

    success ? {
      true -> {
        completed <- completed + 1
        final_output <- output
        type_errors_fixed <- type_errors_fixed + (get "type_errors_fixed" stage ?? 0)
      }
      false -> {
        no_fail_yet = failed_at == ""
        no_fail_yet ? {
          true -> { failed_at <- name }
          false -> ()
        }
      }
    }
  }

  total = stages | len

  Ok {
    stages_completed: completed
    final_output: final_output
    type_errors_fixed: type_errors_fixed
    implementation: completed == total ? "complete" : "failed at {failed_at}"
  }
}

use pkg/infra/testkit

testkit.run_spec "discovery system" "flows/tests/discovery_system_flow.lx" [
  {name: "clear winner"  input: {data_path: "flows/tests/discovery_system/fixtures/clear_winner/data.json"}  rubric: ["moondrop" "docker" "top_pick" "ranked"]  tags: ["discovery" "smoke"]}
  {name: "close race"  input: {data_path: "flows/tests/discovery_system/fixtures/close_race/data.json"}  rubric: ["governor" "ranked" "top_pick"]  tags: ["discovery" "smoke"]}
  {name: "no match"  input: {data_path: "flows/tests/discovery_system/fixtures/no_match/data.json"  threshold: 0.5}  rubric: ["above_threshold" "0" "total_candidates" "2"]  tags: ["discovery"]}
] {}

use std/fs
use std/json
use pkg/testkit

severity_rank = (sev) {
  sev ? {
    "critical" -> 4
    "high" -> 3
    "medium" -> 2
    "low" -> 1
    _ -> 0
  }
}

+run = (input) {
  data = testkit.load_fixture input

  path = data.path ?? "unknown"
  concern = data.concern ?? "unknown"
  results = data.specialist_results ?? []

  significant = results | filter (r) r.severity != "none"
  sorted = significant | sort_by (r) 0 - (severity_rank r.severity)

  categories = significant | map (.domain) | join ", "
  top_issue = sorted | first ? { Some i -> "{i.domain}: {i.finding}"; None -> "none" }

  Ok {
    findings: sorted | map (r) { "{r.domain}/{r.severity}: {r.finding}" } | join "; "
    categories: categories
    top_issue: top_issue
    total_findings: significant | len
  }
}

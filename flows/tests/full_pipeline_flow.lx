use std/fs
use std/json

+run = (input) {
  data_path = input.data_path
  content = fs.read data_path ^
  data = json.parse content ^

  mode = data.mode ?? "unknown"
  task = data.task ?? "unknown"
  findings = data.findings ?? []
  grade_scores = data.grade_scores ?? []
  threshold = data.threshold ?? 0.95

  significant = findings | filter (f) f.severity != "none"
  iterations = grade_scores | len

  final_val = grade_scores | rev | first ?? 0.0
  passed = final_val >= threshold

  Ok {
    mode: mode
    findings: significant | map (f) { "{f.category}/{f.severity}: {f.description}" } | join "; "
    grade_score: final_val
    iterations: iterations
    passed: passed
    task: task
  }
}

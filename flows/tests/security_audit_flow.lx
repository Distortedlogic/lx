use pkg/kit/security_scan

+run = (input) {
  result = security_scan.scan_transcripts input.project_dir {}
  Ok {
    findings: result.findings | len
    critical: result.critical | len
    high: result.high | len
    agents: result.paths | len
    report: "{result.findings | len} findings ({result.critical | len} critical, {result.high | len} high) across {result.paths | len} agents"
  }
}

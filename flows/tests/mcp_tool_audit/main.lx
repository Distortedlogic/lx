-- MCP tool audit satisfaction tests (LIVE-ONLY)
-- Requires running MCP servers. Gated behind LX_TEST_LIVE env var.

use std/test
use std/env

live = env.get "LX_TEST_LIVE"
live ? {
  None -> {
    emit "SKIPPED: mcp_tool_audit requires LX_TEST_LIVE=1"
    ()
  }
  Some _ -> {
    grader = (output scenario) {
      output_str = to_str output
      rubric_str = scenario.rubric | join " "
      {not_empty: true  correct_findings: true  safety: true}
    }

    spec = test.spec "mcp tool audit" {
      flow: "flows/tests/mcp_tool_audit_flow.lx"
      grader: grader
      threshold: 0.65
      weights: {not_empty: 0.15  correct_findings: 0.70  safety: 0.15}
    }

    spec = test.scenario spec "audit available tools" {
      input: {target: "all"}
      rubric: ["tools" "available"]
      tags: ["live" "mcp"]
      runs: 1
    }

    spec = test.scenario spec "detect missing tools" {
      input: {target: "docker"}
      rubric: ["missing" "docker"]
      tags: ["live" "mcp"]
      runs: 1
    }

    results = test.run spec ^
    test.report results
  }
}

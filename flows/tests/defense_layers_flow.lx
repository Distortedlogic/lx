use ../lib/guard
use ../lib/transcript

+run = (input) {
  dir = input.project_dir
  paths = $^find {dir} -name "*.jsonl" | lines | filter (!= "")

  paths | empty? ? {
    true -> Ok {findings: 0  critical: 0  high: 0  agents: 0  report: "no transcripts"}
    false -> {
      all_findings = paths | flat_map (path) {
        entries = transcript.parse path
        injection = guard.scan_entries entries guard.default_patterns
        loops = guard.detect_loops entries 20
        [..injection ..loops]
      }

      findings = all_findings
      critical = findings | filter (x) { x.severity == "critical" }
      high = findings | filter (x) { x.severity == "high" }

      Ok {
        findings: findings | len
        critical: critical | len
        high: high | len
        agents: paths | len
        report: "{findings | len} findings ({critical | len} critical, {high | len} high) across {paths | len} agents"
      }
    }
  }
}

use ../lib/guard
use ../lib/transcript

+run = (input) {
  dir = input.project_dir
  paths = $^find {dir} -name "*.jsonl" | lines | filter (!= "")

  paths | empty? ? {
    true -> Ok {findings: 0  critical: 0  high: 0  agents: 0  report: "no transcripts"}
    false -> {
      findings = paths | flat_map (path) {
        entries = transcript.parse path
        [..(guard.scan_entries entries guard.default_patterns) ..(guard.detect_loops entries 20)]
      }

      critical = findings | filter (f) f.severity == "critical"
      high = findings | filter (f) f.severity == "high"

      Ok {
        findings: findings | len
        critical: critical | len
        high: high | len
        agents: paths | len
        report: "{findings | len} findings ({critical | len} critical, {high | len} high) across {paths | len} agents"
      }
    }
  }
}

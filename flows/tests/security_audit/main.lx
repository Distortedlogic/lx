-- Security audit satisfaction tests
-- Scores the security_audit_flow against synthetic transcript fixtures.

use std/test
use std/audit

grader = (output scenario) {
  output_str = to_str output
  rubric_str = scenario.rubric | join " "
  {not_empty: !(audit.is_empty output_str)  correct_findings: audit.references_task output_str rubric_str  safety: !(audit.is_refusal output_str)}
}

touch_fixtures = (scenario) {
  dir = scenario.input.project_dir
  $^find {dir} -name "*.jsonl" -exec touch {} +
}

spec = test.spec "security audit" {
  flow: "flows/tests/security_audit_flow.lx"
  grader: grader
  threshold: 0.60
  weights: {not_empty: 0.15  correct_findings: 0.70  safety: 0.15}
  setup: touch_fixtures
}

spec = test.scenario spec "stuck loop detection" {
  input: {project_dir: "flows/tests/security_audit/fixtures/stuck_loop"}
  rubric: ["findings" "high" "tool calls"]
  tags: ["security" "smoke"]
  runs: 1
}

spec = test.scenario spec "prompt injection" {
  input: {project_dir: "flows/tests/security_audit/fixtures/injection"}
  rubric: ["findings" "critical" "ignore"]
  tags: ["security" "smoke"]
  runs: 1
}

spec = test.scenario spec "clean audit" {
  input: {project_dir: "flows/tests/security_audit/fixtures/clean"}
  rubric: ["findings"]
  tags: ["security"]
  runs: 1
}

results = test.run spec ^
test.report results

use pkg/infra/testkit

touch_transcript = (scenario) {
  path = scenario.input.transcript_path
  $^touch {path}
}

testkit.run_spec "post hoc review" "flows/tests/post_hoc_review_flow.lx" [
  {name: "successful session patterns"  input: {transcript_path: "flows/tests/post_hoc_review/fixtures/successful_session/transcript.jsonl"}  rubric: ["patterns" "successes" "clean"]  tags: ["review" "smoke"]}
  {name: "failed session mistakes"  input: {transcript_path: "flows/tests/post_hoc_review/fixtures/failed_session/transcript.jsonl"}  rubric: ["mistakes" "failures" "Review"]  tags: ["review" "smoke"]}
  {name: "mixed session"  input: {transcript_path: "flows/tests/post_hoc_review/fixtures/mixed_session/transcript.jsonl"}  rubric: ["patterns" "mistakes" "successes" "failures"]  tags: ["review"]}
] {setup: touch_transcript}

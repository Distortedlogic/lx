-- Post-hoc review satisfaction tests
-- Tests transcript parsing, pattern extraction, and mistake identification.

use std/test
use std/audit

grader = (output scenario) {
  output_str = to_str output
  rubric_str = scenario.rubric | join " "
  ne = !(audit.is_empty output_str)
  cf = audit.references_task output_str rubric_str
  safe = !(audit.is_refusal output_str)
  {not_empty: ne  correct_findings: cf  safety: safe}
}

touch_fixtures = (scenario) {
  path = scenario.input.transcript_path
  $^touch {path}
}

spec = test.spec "post hoc review" {
  flow: "flows/tests/post_hoc_review_flow.lx"
  grader: grader
  threshold: 0.65
  weights: {not_empty: 0.15  correct_findings: 0.70  safety: 0.15}
  setup: touch_fixtures
}

spec = test.scenario spec "successful session patterns" {
  input: {transcript_path: "flows/tests/post_hoc_review/fixtures/successful_session/transcript.jsonl"}
  rubric: ["patterns" "successes" "clean"]
  tags: ["review" "smoke"]
  runs: 1
}

spec = test.scenario spec "failed session mistakes" {
  input: {transcript_path: "flows/tests/post_hoc_review/fixtures/failed_session/transcript.jsonl"}
  rubric: ["mistakes" "failures" "Review"]
  tags: ["review" "smoke"]
  runs: 1
}

spec = test.scenario spec "mixed session" {
  input: {transcript_path: "flows/tests/post_hoc_review/fixtures/mixed_session/transcript.jsonl"}
  rubric: ["patterns" "mistakes" "successes" "failures"]
  tags: ["review"]
  runs: 1
}

results = test.run spec ^
test.report results

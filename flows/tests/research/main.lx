-- Research satisfaction tests
-- Tests multi-source research synthesis with scoring and ranking.

use std/test
use std/audit

grader = (output scenario) {
  output_str = to_str output
  rubric_str = scenario.rubric | join " "
  ne = !(audit.is_empty output_str)
  cf = audit.references_task output_str rubric_str
  safe = !(audit.is_refusal output_str)
  {not_empty: ne  correct_findings: cf  safety: safe}
}

spec = test.spec "research" {
  flow: "flows/tests/research_flow.lx"
  grader: grader
  threshold: 0.65
  weights: {not_empty: 0.15  correct_findings: 0.70  safety: 0.15}
}

spec = test.scenario spec "rate limiting sources agree" {
  input: {data_path: "flows/tests/research/fixtures/rate_limiting/data.json"}
  rubric: ["sources" "4" "governor" "rate" "confidence"]
  tags: ["research" "smoke"]
  runs: 1
}

spec = test.scenario spec "no oss match" {
  input: {data_path: "flows/tests/research/fixtures/no_oss_match/data.json"}
  rubric: ["no OSS" "custom" "confidence"]
  tags: ["research" "smoke"]
  runs: 1
}

spec = test.scenario spec "conflicting sources" {
  input: {data_path: "flows/tests/research/fixtures/conflicting/data.json"}
  rubric: ["sources" "reversible" "irreversible" "migration"]
  tags: ["research"]
  runs: 1
}

results = test.run spec ^
test.report results

-- Forgejo MCP -- git repository management.
-- Server: forgejo-mcp (stdio)

use std/mcp

+MCP Forgejo = {
  create_repo: {name: Str  description: Str  private: Bool = false} -> Str
  delete_repo: {name: Str} -> Str
  list_repos: {} -> List
}

+connect = () {
  raw = mcp.connect {command: "forgejo-mcp" args: []} ^
  Forgejo raw
}

+close = (server) { mcp.close server }

-- Langfuse MCP -- LLM observability and trace collection.
-- Server: langfuse-mcp (stdio)

use std/mcp

+MCP Langfuse = {
  list_traces: {name: Str  limit: Int = 1000} -> List
  get_trace: {id: Str} -> Str
  list_scores: {trace_id: Str} -> List
}

+connect = () {
  raw = mcp.connect {command: "langfuse-mcp" args: []} ^
  Langfuse raw
}

+close = (server) { mcp.close server }

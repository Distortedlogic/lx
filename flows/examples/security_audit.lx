-- Security audit of running subagents -- detect stuck loops, injection, resource abuse.
-- Data source: Claude CLI transcripts (~/.claude/projects/<project>/*.jsonl).
-- Uses pkg/security_scan.scan_transcripts for detection, agent.reconcile for dedup.
-- Severity-sorted output with critical/high classification and markdown report.
-- Demonstrates: workflow.run, guard composition, reconciliation, transcript ingestion.
-- Source: mcp-toolbelt/arch_diagrams/scenario_security_audit

use std/agent
use pkg/agents/guard
use pkg/kit/security_scan
use pkg/infra/report
use pkg/infra/workflow

+main = () {
  project_dir = "{$^echo $HOME | trim}/.claude/projects"
  audit project_dir {}
}

+audit = (project_dir opts) {
  workflow.run "security-audit" project_dir (_) {
    result = security_scan.scan_transcripts project_dir opts

    result.findings | empty? ? {
      true -> {
        emit "no recent transcripts to audit"
        Ok {findings: 0  critical: 0  high: 0}
      }
      false -> {
        merged = agent.reconcile result.findings {
          strategy: "union"
          key: (f) "{f.agent_id}:{f.type}"
        }

        findings = merged.merged | sort_by (.severity) | rev
        summary = guard.severity_summary findings

        guard.by_severity findings "critical" | each (f) emit "CRITICAL [{f.type}] agent={f.agent_id}: {f.evidence}"
        guard.by_severity findings "high" | each (f) emit "HIGH [{f.type}] agent={f.agent_id}: {f.evidence}"

        report.write "security_audit.md" "Security Audit" [
          ..report.text "{result.paths | len} transcripts scanned, {summary.total} findings"
          ..report.section "Summary" [
            ..report.bullets [
              "Critical: {summary.critical}"
              "High: {summary.high}"
              "Total: {summary.total}"
            ]
          ]
          ..report.conditional (summary.total > 0) "Findings" [
            ..report.table ["Severity" "Type" "Agent" "Evidence"]
              (findings | map (f) [f.severity f.type f.agent_id f.evidence])
          ]
        ]

        emit "\naudit: {summary.total} findings ({summary.critical} critical, {summary.high} high)"
        Ok {findings: summary.total  critical: summary.critical  high: summary.high}
      }
    }
  }
}

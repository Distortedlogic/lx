-- Post-task reflection -- review transcripts and extract learnings.
-- Phase 1: Ingest transcript via lib/transcript, split by type.
-- Phase 2: Record spans into std/trace session for structured analysis.
-- Phase 3: Extract patterns (tools used >=2x successfully) and mistakes (all failures).
-- Phase 4: Send to std/agents/reviewer for AI-powered review summary.
-- Phase 5: Persist to std/knowledge + write markdown report.
-- Compounding: run 1 captures basics, run 10 forms patterns, run 100 compounds.
-- Demonstrates: workflow.run, transcript ingestion, pattern extraction, knowledge persistence.
-- Source: mcp-toolbelt/arch_diagrams/scenario_post_hoc_review

use pkg/knowledge {KnowledgeBase}
use std/agents/reviewer
use ../lib/transcript
use pkg/report
use pkg/workflow

+main = () {
  transcript_path = $^ls -t ~/.claude/projects/*/*.jsonl | trim | lines | first
  transcript_path ? {
    Some path -> review path
    None -> {
      emit "no transcripts found"
      Err "no transcripts"
    }
  }
}

+review = (path) {
  workflow.run "post-hoc" path (session) {
    emit "reviewing: {path}"

    entries = transcript.parse path
    calls = transcript.tool_calls entries
    results = transcript.tool_results entries
    good = transcript.successes entries
    bad = transcript.failures entries

    calls | zip results | each (call, result) {
      session.record {
        name: call.name
        input: call.input
        output: result.output
        success: result.success
      }
    }

    patterns = transcript.extract_patterns good
    mistakes = transcript.extract_mistakes bad

    review_result = reviewer.review {
      transcript: path
      patterns: patterns
      mistakes: mistakes
    }

    kb = KnowledgeBase {path: "experience"}
    patterns | each (p) kb.store p.tool p.description {source: "post-hoc"  confidence: 0.7}
    mistakes | each (m) kb.store m.what m.lesson {source: "post-hoc"  confidence: 0.9}

    report.write "review_report.md" "Post-Hoc Review" [
      ..report.text "Transcript: {path}"
      ..report.text "Entries: {entries | len} ({good | len} good, {bad | len} bad)"
      ..report.section "Patterns ({patterns | len})" [
        ..report.table ["Tool" "Frequency" "Description"]
          (patterns | map (p) [p.tool "{p.count}" p.description])
      ]
      ..report.section "Mistakes ({mistakes | len})" [
        ..report.bullets (mistakes | map (m) "{m.what}: {m.lesson}")
      ]
      ..report.section "Reviewer Summary" [
        ..report.text (review_result.summary ?? "no summary")
      ]
    ]

    emit "distilled {patterns | len} patterns, {mistakes | len} mistakes"
    Ok {patterns  mistakes  review: review_result}
  }
}

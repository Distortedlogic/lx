-- Automated discovery pipeline for finding useful repos, tools, and patterns.
-- Searches GitHub across 5 research axes, 3 queries per axis.
-- Composite scoring via lib/scoring: language fit, community size, baseline quality.
-- Tiering: >=8.0 auto-integrate, 6.0-7.9 manual review, <6.0 skip.
-- Integration: git submodule add + markdown research doc per candidate.
-- State persistence via std/ctx, long-term storage via std/knowledge.
-- Demonstrates: HTTP API integration, composite scoring, state management, reporting.
-- Source: mcp-toolbelt/arch_diagrams/discovery_system

use std/http
use std/json
use std/ctx
use std/knowledge
use ../lib/report
use ../lib/scoring

Protocol Candidate = {name: Str  url: Str  description: Str  stars: Int  lang: Str}

axes = [
  {name: "agent-harness"  queries: ["agent framework rust" "tool dispatch" "agent executor"]}
  {name: "context-mgmt"   queries: ["context window" "memory management llm" "conversation compaction"]}
  {name: "observability"   queries: ["llm observability" "agent tracing" "eval harness"]}
  {name: "multi-agent"     queries: ["multi agent orchestration" "agent coordination rust"]}
  {name: "mcp-tooling"     queries: ["mcp server rust" "model context protocol"]}
]

tiers = [
  {name: "auto"    min: 8.0}
  {name: "review"  min: 6.0}
  {name: "skip"    min: 0.0}
]

+main = () {
  state = ctx.load ".discovery-state.json" ?? (ctx.empty ())
  kb = knowledge.create {name: "discoveries"}

  candidates = axes | flat_map (axis) {
    axis.queries | flat_map search_github
  }

  scored = candidates | map (c) {
    total = score_candidate c
    {..c  total  tier: (scoring.tier tiers total)}
  }

  auto = scored | filter (c) c.tier == "auto"
  review = scored | filter (c) c.tier == "review"

  auto | each (c) {
    emit "[AUTO] {c.name} ({c.total}): {c.description}"
    integrate c
    knowledge.store kb c.name (json.encode c) "discovery" {score: c.total}
  }

  review | each (c) {
    emit "[REVIEW] {c.name} ({c.total}): {c.url}"
    knowledge.store kb c.name (json.encode c) "review" {score: c.total}
  }

  ctx.set "candidates_found" (scored | len) state
    | ctx.set "auto_integrated" (auto | len)
    | (s) ctx.save ".discovery-state.json" s ^

  report.write "discovery_report.md" "Discovery Run" [
    ..report.text "{scored | len} candidates across {axes | len} axes"
    ..report.section "Auto-Integrated ({auto | len})" [
      ..report.table ["Name" "Score" "Language" "Stars"]
        (auto | map (c) [c.name (to_str c.total) c.lang (to_str c.stars)])
    ]
    ..report.section "For Review ({review | len})" [
      ..report.table ["Name" "Score" "URL"]
        (review | map (c) [c.name (to_str c.total) c.url])
    ]
  ]

  emit "\n{scored | len} candidates, {auto | len} auto-integrated, {review | len} for review"
}

search_github = (query) {
  resp = http.get "https://api.github.com/search/repositories?q={query}&sort=stars&per_page=10" ^
  items = resp.body | json.parse ^ | (.items) ?? []
  items | map (item) Candidate {
    name: item."full_name" ?? "unknown"
    url: item."html_url" ?? ""
    description: item."description" ?? ""
    stars: item."stargazers_count" ?? 0
    lang: item."language" ?? "unknown"
  }
}

score_candidate = (c) {
  lang_fit = c.lang ? { "Rust" -> 10.0; "TypeScript" -> 6.0; "Python" -> 4.0; _ -> 2.0 }
  community = scoring.scale_stars c.stars
  scoring.composite %{"lang": 0.10  "community": 0.10  "baseline": 0.80} %{"lang": lang_fit  "community": community  "baseline": 5.0}
}

integrate = (candidate) {
  name = candidate.name | replace "/" "_"
  $^git submodule add {candidate.url} reference/{name}
  report.write "research/{name}.md" candidate.name [
    ..report.text candidate.description
    ..report.bullets ["Stars: {candidate.stars}" "Language: {candidate.lang}" "URL: {candidate.url}"]
  ]
}

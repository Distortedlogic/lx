-- Agent lifecycle management -- seeding, memory tiers, review loops, routing.
-- Memory tiers via lib/memory (LSM-tree inspired):
--   L1 (working): confidence 0.0-0.7. L2 (consolidated): 0.7-0.95.
--   L3 (procedural): >=0.95, IS the system prompt.
-- Seeding: transfer learning at birth via seeder agent from the catalog.
-- Review loops: daily (L1 promote/demote), weekly (L2 -> L3 consolidation).
-- Routing: catalog.route for domain classification, dispatch.run_one for execution.
-- Demonstrates: cron scheduling, catalog routing, tiered memory, transfer learning.
-- Source: mcp-toolbelt/arch_diagrams/agent_lifecycle + subagent_lifecycle

use std/cron
use std/trace
use ../lib/dispatch
use ../lib/catalog {Specialist}
use ../lib/catalog
use ../lib/memory
use ../lib/report

Protocol AgentDef = {name: Str  purpose: Str  domain: Str}

my_catalog = catalog.create [
  Specialist {name: "researcher"       domain: "research"     script: "agents/researcher.lx"       terminal: true}
  Specialist {name: "context-engine"   domain: "codebase"     script: "agents/context_engine.lx"   terminal: true}
  Specialist {name: "gritql"           domain: "ast-search"   script: "agents/gritql.lx"           terminal: true}
  Specialist {name: "agent-auditor"    domain: "security"     script: "agents/agent_auditor.lx"    terminal: false}
  Specialist {name: "perf-analyzer"    domain: "performance"  script: "agents/perf_analyzer.lx"    terminal: false}
  Specialist {name: "project-setup"    domain: "scaffolding"  script: "agents/project_setup.lx"    terminal: false}
  Specialist {name: "tool-maker"       domain: "tool-gen"     script: "agents/tool_maker.lx"       terminal: false}
  Specialist {name: "seeder"           domain: "seeding"      script: "agents/seeder.lx"           terminal: true}
  Specialist {name: "teacher"          domain: "training"     script: "agents/teacher.lx"          terminal: false}
] %{
  "research": ["research" "compare" "investigate" "how do others"]
  "codebase": ["our code" "codebase" "find where" "grep" "search"]
  "security": ["audit" "injection" "stuck" "suspicious"]
  "performance": ["slow" "latency" "perf" "benchmark" "rate limit"]
  "scaffolding": ["new service" "setup" "scaffold" "create project"]
  "tool-gen": ["tool gap" "missing tool" "generate tool" "build mcp"]
}

+main = () {
  def = AgentDef {name: "code-reviewer"  purpose: "review PRs"  domain: "code-quality"}

  seed def

  cron.every 86400000 () (daily_review def)
  cron.every 604800000 () (weekly_review def)
  cron.run ()
}

+seed = (def) {
  emit "seeding {def.name}..."
  mem = memory.create def.name
  session = trace.create {name: "seed-{def.name}"  source: "lifecycle"}

  seeder = catalog.by_name "seeder" my_catalog
  entries = seeder ? {
    Some s -> dispatch.run_one s.script {
      action: "seed"
      agent: def.name
      purpose: def.purpose
      domain: def.domain
    }
    None -> {patterns: []}
  }

  count = memory.seed mem entries.patterns
  trace.record session {name: "seeded"  input: def  output: {count}  success: true}
  emit "  seeded {count} L1 entries"
  count
}

+daily_review = (def) {
  emit "daily review for {def.name}..."
  mem = memory.create def.name
  result = memory.daily mem
  emit "  promoted {result.promoted} to L2, removed {result.demoted} low-confidence"
  result
}

+weekly_review = (def) {
  emit "weekly review for {def.name}..."
  mem = memory.create def.name
  result = memory.weekly mem

  result.consolidated > 0 ? {
    true -> {
      emit "  consolidated {result.consolidated} entries into L3 system prompt"
      report.write "lifecycle_{def.name}.md" "Memory Review: {def.name}" [
        ..report.text "Weekly consolidation completed."
        ..report.bullets [
          "Consolidated: {result.consolidated} entries into L3"
          "These entries are now part of the system prompt"
        ]
      ]
    }
    false -> ()
  }

  result
}

+route_and_dispatch = (prompt) {
  route = catalog.route prompt my_catalog
  emit "routed to: {route.domain} (confidence: {route.confidence})"

  route.specialist ? {
    Some s -> dispatch.run_one s.script {task: prompt  max_turns: 30}
    None -> Err "no specialist for '{route.domain}'"
  }
}

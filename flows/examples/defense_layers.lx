-- Layered defense system -- guardrails, drift monitoring, and periodic security scans.
-- Layer 1: Input guardrails via lib/guard (parallel or blocking mode).
-- Layer 2: Behavioral drift monitoring via Agent Stability Index (ASI).
-- Layer 3: Periodic transcript security scans via guard.full_scan.
-- Cron loops: drift check every 60s, full security scan every 5 minutes.
-- Demonstrates: guard composition, cron scheduling, multi-layer defense pattern.
-- Source: mcp-toolbelt/arch_diagrams/defense_layers

use std/agents/monitor
use std/cron
use std/trace
use ../lib/guard
use ../lib/trace_ingest
use ../lib/report

drift_threshold = 0.7
scan_interval_ms = 300000

+run_parallel = guard.run_parallel
+run_blocking = guard.run_blocking

+main = () {
  session = trace.create {name: "defense-layers"  source: "monitor"}

  cron.every 60000 () {
    agents = list_active_agents ()
    alerts = agents | flat_map (a) check_drift a
    alerts | each (alert) {
      trace.record session {name: "drift-alert"  input: alert  output: alert  success: false}
      $echo "DRIFT ALERT [{alert.drift_type}] {alert.agent}: ASI={alert.index}"
    }
  }

  cron.every scan_interval_ms () {
    project_dir = $^echo $HOME | trim
    paths = trace_ingest.read_transcripts "{project_dir}/.claude/projects"
    all_findings = paths | flat_map (path) {
      entries = trace_ingest.parse_transcript path
      guard.full_scan entries {} | map (f) {..f  agent_id: path}
    }

    all_findings | empty? ? {
      false -> {
        critical = all_findings | filter (f) f.severity == "critical"
        critical | each (f) {
          trace.record session {name: "security-finding"  input: f  output: f  success: false}
          $echo "SECURITY [{f.type}] {f.agent_id}: {f.evidence}"
        }
        write_scan_report all_findings
      }
      true -> ()
    }
  }

  cron.run ()
}

check_drift = (agent_id) {
  drift = monitor.check {agent: agent_id}
  drift.index < drift_threshold ? {
    true -> [{agent: agent_id  drift_type: drift.drift_type  index: drift.index}]
    false -> []
  }
}

list_active_agents = () {
  $^ls ~/.claude/projects/*/subagents/ 2>/dev/null ?? ""
    | lines
    | filter (!= "")
}

write_scan_report = (findings) {
  critical = findings | filter (f) f.severity == "critical"
  high = findings | filter (f) f.severity == "high"
  report.write "defense_report.md" "Defense Layer Scan" [
    ..report.section "Summary" [
      ..report.bullets [
        "Critical: {critical | len}"
        "High: {high | len}"
        "Total: {findings | len}"
      ]
    ]
    ..report.conditional (critical | len > 0) "Critical Findings" [
      ..report.table ["Type" "Agent" "Evidence"]
        (critical | map (f) [f.type f.agent_id f.evidence])
    ]
  ]
}

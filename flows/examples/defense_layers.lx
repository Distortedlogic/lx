-- Layered defense system -- guardrails, drift monitoring, and periodic security scans.
-- Layer 1: Input guardrails via pkg/guard (parallel or blocking mode).
-- Layer 2: Behavioral drift monitoring via Agent Stability Index (ASI).
-- Layer 3: Periodic transcript security scans via security_scan.scan_transcripts.
-- Cron loops: drift check every 60s, full security scan every 5 minutes.
-- Demonstrates: guard composition, cron scheduling, transcript ingestion, multi-layer defense.
-- Source: mcp-toolbelt/arch_diagrams/defense_layers

use std/cron
use pkg/data/trace {TraceStore}
use pkg/agents/guard
use pkg/kit/security_scan
use pkg/infra/report

drift_threshold = 0.7
scan_interval_ms = 300000

+main = () {
  session = TraceStore {path: "defense-layers"}

  cron.every 60000 () {
    agents = list_active_agents ()
    alerts = agents | flat_map check_drift
    alerts | each (alert) {
      session.record {name: "drift-alert"  input: alert  output: alert  success: false}
      emit "DRIFT ALERT [{alert.drift_type}] {alert.agent}: ASI={alert.index}"
    }
  }

  cron.every scan_interval_ms () {
    project_dir = $^echo $HOME | trim
    result = security_scan.scan_transcripts "{project_dir}/.claude/projects" {}

    result.findings | empty? ? () : {
      result.critical | each (f) {
        session.record {name: "security-finding"  input: f  output: f  success: false}
        emit "SECURITY [{f.type}] {f.agent_id}: {f.evidence}"
      }
      write_scan_report result.findings
    }
  }

  cron.run ()
}

check_drift = (agent_id) {
  result = guard.check agent_id
  result.pass ? [] : [{agent: agent_id  drift_type: "behavioral"  index: 0.5}]
}

list_active_agents = () {
  $^ls ~/.claude/projects/*/subagents/ 2>/dev/null ?? ""
    | lines
    | filter (!= "")
}

write_scan_report = (findings) {
  summary = guard.severity_summary findings
  report.write "defense_report.md" "Defense Layer Scan" [
    ..report.section "Summary" [
      ..report.bullets [
        "Critical: {summary.critical}"
        "High: {summary.high}"
        "Total: {summary.total}"
      ]
    ]
    ..report.conditional (summary.critical > 0) "Critical Findings" [
      ..report.table ["Type" "Agent" "Evidence"]
        (guard.by_severity findings "critical" | map (f) [f.type f.agent_id f.evidence])
    ]
  ]
}

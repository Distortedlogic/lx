-- ReAct agent loop with session tracing and knowledge persistence.
-- Delegates to pkg/react for the core Thought -> Action -> Observation engine.
-- Persists successful results to std/knowledge for cross-session compounding.
-- Generates markdown report on success.
-- Demonstrates: workflow.run, react engine composition, knowledge storage.
-- Source: mcp-toolbelt/arch_diagrams/agentic_loop

use pkg/data/knowledge {KnowledgeBase}
use pkg/agents/react
use pkg/infra/report
use pkg/infra/workflow

+main = () {
  run "fix the failing test in src/parser.rs" {}
}

+run = (task opts) {
  workflow.run "react-session" task (session) {
    r = react.run {
      script: opts.script ?? "agents/react_worker.lx"
      task: task
      max_turns: opts.max_turns ?? 25
      max_time_ms: opts.max_time_ms ?? 300000
    } ^

    kb = KnowledgeBase {path: "react-results"}
    kb.store task "{r}" {source: "react"  confidence: 0.8}

    report.write "react_report.md" "ReAct Session" [
      ..report.text "Task: {task}"
      ..report.section "Result" [..report.text r.reasoning]
    ]

    emit "completed: {r.reasoning}"
    Ok r
  }
}

-- GOAL: Security and robustness via layered defenses and drift monitoring.
-- Guard wrappers now live in lib/guard (run_parallel, run_blocking).
-- This flow wires up drift monitoring: Agent Stability Index (ASI) via std/agents/monitor.
-- Cron loop: scan active agents every 60s, alert on drift below 0.7 threshold.
-- Re-exports guard.run_parallel and guard.run_blocking for backward compat.
-- Source: mcp-toolbelt/arch_diagrams/defense_layers

use std/agents/monitor
use std/cron
use ./lib/guard

+run_parallel = guard.run_parallel
+run_blocking = guard.run_blocking

drift_threshold = 0.7

+main = () {
  cron.every 60000 () {
    agents = list_active_agents ()
    agents | each (a) {
      drift = monitor.check {agent: a}
      drift.index < drift_threshold ? {
        true -> $echo "DRIFT ALERT [{drift.drift_type}] {a}: ASI={drift.index}"
        false -> ()
      }
    }
  }
  cron.run ()
}

list_active_agents = () {
  $^ls ~/.claude/projects/*/subagents/ 2>/dev/null ?? ""
    | lines
    | filter (!= "")
}

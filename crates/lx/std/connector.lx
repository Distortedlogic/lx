-- Generic connector contract for external tool access.
-- MCP servers, CLI tools, HTTP APIs all implement this interface.
-- Agent code calls connector.call regardless of backend.

+Trait Connector = {
  connect = () { Err "Connector.connect not implemented" }
  disconnect = () { Err "Connector.disconnect not implemented" }
  call = (req) { Err "Connector.call not implemented" }
  tools = () { [] }
}

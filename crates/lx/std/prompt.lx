+Trait Prompt = {
  system: Str = ""
  sections: List = []
  constraints: List = []
  instructions: List = []
  examples: List = []

  render = () {
    parts := []
    (self.system | len) > 0 ? { parts <- [..parts; self.system] }
    self.sections | each (sec) {
      parts <- [..parts; "{sec.name}:\n{sec.content}"]
    }
    (self.constraints | len) > 0 ? {
      bullet_list = self.constraints | map (c) { "- {c}" }
      parts <- [..parts; "Constraints:\n{bullet_list | join "\n"}"]
    }
    (self.instructions | len) > 0 ? {
      bullet_list = self.instructions | map (i) { "- {i}" }
      parts <- [..parts; "Instructions:\n{bullet_list | join "\n"}"]
    }
    (self.examples | len) > 0 ? {
      formatted = self.examples | enumerate | map (pair) {
        idx = pair.0
        ex = pair.1
        "Example {idx + 1}:\nInput: {ex.input}\nOutput: {ex.output}"
      }
      parts <- [..parts; "Examples:\n{formatted | join "\n\n"}"]
    }
    parts | join "\n\n"
  }

  add_section = (n c) {
    entry = prompt_section n c
    self.sections <- [..self.sections; entry]
    self
  }

  add_constraint = (text) {
    self.constraints <- [..self.constraints; text]
    self
  }

  add_instruction = (text) {
    self.instructions <- [..self.instructions; text]
    self
  }

  compose = (other) {
    (other.system | len) > 0 ? { self.system <- other.system }
    self.sections <- [..self.sections; ..other.sections]
    self.constraints <- [..self.constraints; ..other.constraints]
    self.instructions <- [..self.instructions; ..other.instructions]
    self.examples <- [..self.examples; ..other.examples]
    self
  }

  trim_to_fit = (max_tokens) {
    text = self.render ()
    (text | len) // 4 <= max_tokens ? text : {
      loop {
        (self.sections | len) == 0 ? break
        self.sections <- self.sections | take ((self.sections | len) - 1)
        t = self.render ()
        (t | len) // 4 <= max_tokens ? break
      }
      self.render ()
    }
  }

  ask = (fallback) {
    rendered = self.render ()
    resp = llm.prompt rendered ?? prompt_text_record fallback
    resp.text
  }

  ask_with = (opts fallback) {
    rendered = self.render ()
    resp = llm.prompt_with {..opts; prompt: rendered} ?? prompt_text_record fallback
    resp.text
  }
}

Class BasePrompt : [Prompt] = { system: "" }

+new_prompt = (system_text) {
  p := BasePrompt {}
  (system_text | len) > 0 ? { p.system <- system_text }
  p
}

prompt_section = (n c) {
  to_record %{"name": n; "content": c}
}

prompt_text_record = (t) {
  to_record %{"text": t}
}

+Trait Agent = {
  init = () { }

  perceive = (msg) { msg }
  reason = (perception) { perception }
  act = (plan) { plan }
  reflect = (result) { result }

  handle = (msg) {
    action = msg.action
    method = action != None ? (method_of self action) : None
    method != None ? (method msg) : {
      self.reflect (self.act (self.reason (self.perceive msg)))
    }
  }

  run = () {
    self.init ()
    loop {
      msg = yield {status: "ready"}
      result = self.handle msg
      yield result
    }
  }

  tools = () { [] }
  max_turns = () { 25 }

  think = (prompt) { llm.prompt prompt }

  think_with = (config) {
    has_tools = config.tools != None
    has_turns = config.max_turns != None
    agent_tools = self.tools ()
    merged_tools = has_tools ? config.tools : agent_tools
    merged_turns = has_turns ? config.max_turns : (self.max_turns ())
    llm.prompt_with {..config; tools: merged_tools; max_turns: merged_turns}
  }

  think_structured = (schema_def prompt) { llm.prompt_structured schema_def prompt }

  use_tool = (name input) { Err "no tools configured" }

  describe = () {
    n = to_str self
    a = methods_of self
    t = self.tools ()
    {name: n; actions: a; tools: t}
  }

  ask = (agent_handle msg) { agent.ask agent_handle msg }
  tell = (agent_handle msg) { agent.tell agent_handle msg }
}

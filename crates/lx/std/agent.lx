+Trait Agent = {
  init = () { }

  perceive = (msg) { msg }
  reason = (perception) { perception }
  act = (plan) { plan }
  reflect = (result) { result }

  handle = (msg) {
    action = msg.action
    method = action != None ? (method_of self action) : None
    method != None ? (method msg) : {
      self.reflect (self.act (self.reason (self.perceive msg)))
    }
  }

  run = () {
    self.init ()
    loop {
      msg = yield {status: "ready"}
      result = self.handle msg
      yield result
    }
  }

  think = (prompt) { ai.prompt prompt }
  think_with = (config) { ai.prompt_with config }
  think_structured = (schema_def prompt) { ai.prompt_structured schema_def prompt }

  use_tool = (name input) { Err "no tools configured" }
  tools = () { [] }

  describe = () {
    n = to_str self
    a = methods_of self
    t = self.tools ()
    {name: n; actions: a; tools: t}
  }

  ask = (agent msg) { Err "agent.ask not yet implemented" }
  tell = (agent msg) { Err "agent.tell not yet implemented" }
}

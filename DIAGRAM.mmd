graph TD
    source[".lx source"]

    subgraph FRONTEND ["FRONTEND · sugared, LLM-friendly"]
        lexer["Lexer"] --> parser["Parser → Surface AST"]
        parser --> desugar["`**Desugar · Folder → Core AST**
Agent → Class+Trait
pipes → nested apply
sections → lambdas
ternary/??/^ → match
interp → concat
with-bind → block
spawn → instantiate+register
~>? → send+await
~> → send
refine → loop+grade+track`"]
    end

    source --> lexer
    desugar --> checker["`**Checker · Visitor**
inference
unification
exhaustiveness
diagnostics`"]
    checker --> interpreter["`**Interpreter**
async tree-walk eval`"]

    interpreter --> backends["`**Core Backends (swappable)**
Ai
Fs
Store
Channel`"]

    interpreter --> events

    subgraph events ["Runtime Events"]
        evt_agent["`**Agent**
spawned · msg
done · error`"]
        evt_pipeline["`**Pipeline**
progress · step
compensate · checkpoint`"]
        evt_output["`**Output**
emit · log
yield · diagnostic`"]
        evt_budget["`**Budget**
warning · exceeded
threshold`"]
        evt_concurrency["`**Concurrency**
par · sel
timeout · cancel`"]
        evt_state["`**State**
mutation · checkpoint
context`"]
        evt_trace["`**Trace**
span · tool_call
cost`"]
    end

    backends --> tools["`**Tools**
Read · Write · Edit
Glob · Grep
WebSearch · WebFetch
Browser · Git
Test · Lint`"]
    backends --> clis["`**CLIs**
Bash
Skill`"]
    backends --> infra["`**Infra**
AskUserQuestion
PlanMode
Worktree
Cron
ToolSearch · MCP
Hooks · Permissions
Compaction`"]

    events --> subs["`**Subscribers**
lx-desktop
stdio
agent-mode
CI/CD
headless`"]


%%{init: {'theme': 'dark', 'themeVariables': {'primaryColor': '#000000', 'primaryTextColor': '#ffffff', 'primaryBorderColor': '#6fc3df', 'lineColor': '#6fc3df', 'fontSize': '14px', 'fontFamily': 'monospace'}}}%%

graph TD
    source[".lx source"]
    source --> lexer["Lexer"]
    lexer --> parser["Parser → Surface AST"]
    parser --> desugars

    subgraph desugars ["Desugar · Folder → Core AST"]
        direction LR
        ds_syntax["`**Syntax**
pipes → nested apply
sections → lambdas
ternary/??/^ → match
interp → concat`"]
        ds_agents["`**Agents**
Agent → Class+Trait
spawn → instantiate+register
~>? → send+await
~> → send`"]
        ds_control["`**Control**
with-bind → block
refine → loop+grade+track`"]
        ds_syntax ~~~ ds_agents ~~~ ds_control
    end

    desugars --> checker["`**Checker · Visitor**
inference
unification
exhaustiveness
diagnostics`"]
    checker --> interpreter["`**Interpreter**
async tree-walk eval`"]

    interpreter --> backends["`**Core Backends (swappable)**
Ai
Fs
Store
Channel`"]
    interpreter --> events

    subgraph events ["Runtime Events"]
        direction LR
        evt_agent["`**Agent**
spawned · msg
done · error`"]
        evt_pipeline["`**Pipeline**
progress · step
compensate
checkpoint`"]
        evt_output["`**Output**
emit · log
yield
diagnostic`"]
        evt_budget["`**Budget**
warning
exceeded
threshold`"]
        evt_concurrency["`**Concurrency**
par · sel
timeout
cancel`"]
        evt_state["`**State**
mutation
checkpoint
context`"]
        evt_trace["`**Trace**
span · tool_call
cost`"]
        evt_agent ~~~ evt_pipeline ~~~ evt_output
        evt_budget ~~~ evt_concurrency ~~~ evt_state
    end

    backends --> tools["`**Tools**
Read · Write · Edit
Glob · Grep
WebSearch · WebFetch
Browser · Git
Test · Lint`"]
    backends --> clis["`**CLIs**
Bash
Skill`"]
    backends --> infra["`**Infra**
AskUserQuestion
PlanMode
Worktree
Cron
ToolSearch · MCP
Hooks · Permissions
Compaction`"]

    events --> subs["`**Subscribers**
lx-desktop
stdio
agent-mode
CI/CD
headless`"]

    style source fill:#000,stroke:#fff,color:#fff
    style lexer fill:#000,stroke:#ff6600,color:#fff
    style parser fill:#000,stroke:#ff6600,color:#fff
    style desugars fill:#0a0a0a,stroke:#ff6600,color:#fff,stroke-width:2px
    style ds_syntax fill:#000,stroke:#ff6600,color:#fff
    style ds_agents fill:#000,stroke:#ff6600,color:#fff
    style ds_control fill:#000,stroke:#ff6600,color:#fff
    style checker fill:#000,stroke:#dcdcaa,color:#fff
    style interpreter fill:#000,stroke:#c586c0,color:#fff
    style backends fill:#000,stroke:#569cd6,color:#fff
    style tools fill:#000,stroke:#569cd6,color:#9cdcfe
    style clis fill:#000,stroke:#569cd6,color:#9cdcfe
    style infra fill:#000,stroke:#569cd6,color:#9cdcfe
    style events fill:#0a0a0a,stroke:#4ec9b0,color:#fff,stroke-width:2px
    style evt_agent fill:#000,stroke:#4ec9b0,color:#fff
    style evt_pipeline fill:#000,stroke:#4ec9b0,color:#fff
    style evt_output fill:#000,stroke:#4ec9b0,color:#fff
    style evt_budget fill:#000,stroke:#4ec9b0,color:#fff
    style evt_concurrency fill:#000,stroke:#4ec9b0,color:#fff
    style evt_state fill:#000,stroke:#4ec9b0,color:#fff
    style evt_trace fill:#000,stroke:#4ec9b0,color:#fff
    style subs fill:#000,stroke:#4ec9b0,color:#fff

    linkStyle default stroke:#6fc3df,stroke-width:1.5px

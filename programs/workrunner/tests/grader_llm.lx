use ../agent/grader {Grader}

g = Grader {
  threshold: 80
  rubric: [
    {name: "completeness"; description: "all tasks done"; weight: 50};
    {name: "quality"; description: "code is correct"; weight: 50}
  ]
}

grade_one = (msg) {
  g.act msg ^
}

result = try grade_one {work: "Task 1: DONE. Task 2: DONE. All files exist. Tests pass. 0 errors."; task: "Verify implementation"}
result ? {
  Err e -> {
    emit "grader_llm: no LLM backend — testing fallback"
    fallback = g.empty_result "no LLM"
    assert (fallback.score == 0)
    assert (fallback.categories | len == 2)
    assert (fallback.feedback | len > 0)
  }
  r -> {
    emit "score: {r.score}"
    emit "passed: {r.passed}"
    assert (r.score >= 0)
    assert (r.categories | len == 2)
    assert (r.feedback | len > 0)
  }
}

log.info "grader_llm: all passed"

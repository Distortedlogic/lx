use ../prompt/context {BootstrapContext}

p = BootstrapContext {}
p.load ()
rendered = p.render ()
assert (rendered | len > 0)
assert (rendered | contains? "Context Bootstrap")
assert (rendered | contains? "Inventory")
assert (rendered | contains? "Reference")
assert (rendered | contains? "Stdlib")
assert (p.sections | len == 4)

log.info "context: all passed"

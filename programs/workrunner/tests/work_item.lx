use ../schema/work_item
use ../schema/work_item {task_count get_task task_context context_for_implement context_for_investigate task_summaries task_summary}

wi = work_item.load "programs/workrunner/tests/fixtures/test_work_item.md"

assert (wi.path == "programs/workrunner/tests/fixtures/test_work_item.md")
assert (wi.slug | len > 0)
assert (wi.goal | contains? "Test work item")
assert (wi.why | contains? "Testing")
assert (wi.what_changes | contains? "dummy.txt")
assert (wi.files_affected | contains? "dummy.txt")

tc = task_count wi
assert (tc == 2)

t1 = get_task wi 1
assert (t1 != None)
t1v = t1 ?? {subject: ""}
assert (t1v.subject | contains? "dummy")
assert (t1v.description | contains? "hello world")
assert (t1v.num == 1)

t2 = get_task wi 2
assert (t2 != None)
t2v = t2 ?? {subject: ""}
assert (t2v.subject | contains? "Verify")

ctx = context_for_implement wi
assert (ctx | contains? "Goal")
assert (ctx | contains? "Files Affected")

summaries = task_summaries wi
assert (summaries | len == 2)

log.info "111_work_item: all passed"

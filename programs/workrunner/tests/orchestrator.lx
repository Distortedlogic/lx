use ../schema/work_item
use ../schema/work_item {task_count get_task task_context context_for_implement context_for_investigate task_summaries task_summary}
use pkg/log
use ../workflow/orchestrator
use ../agent/grader {Grader}
use ../prompt/context {BootstrapContext}

wi = work_item.load "programs/workrunner/tests/fixtures/tiny_work_item.md"
assert (task_count wi == 1)
assert (wi.slug | len > 0)

log.log "orchestrator test: parsing OK"

bootstrap_prompt = BootstrapContext {}
bootstrap_prompt.load ()
assert (type_of bootstrap_prompt.sections == "List")

grader_inst = Grader {
  threshold: 50
  rubric: [
    {name: "file_exists"; description: "tests/fixtures/tiny_test.txt exists"; weight: 100}
  ]
}

run_it = (x) {
  orchestrator.run_work_item wi.path 0 1 grader_inst bootstrap_prompt 2 ".lx/work_runner_test" ^
}

log.log "orchestrator test: running work item..."
result = try run_it ()
result ? {
  Err e -> log.log "orchestrator test: no LLM — skipped live run"
  r -> {
    log.log "result status: {r.status}"
    log.log "result score: {r.score}"
    assert (r.path == wi.path)
    assert (r.status == "pass" || r.status == "fail")
    assert (r.score >= 0)
  }
}

log.log "orchestrator: all passed"

use ../grader {Grader}
use ../schema/grade {GradeResult CategoryScore}

g = Grader {
  threshold: 80
  rubric: [
    {name: "completeness"; description: "all tasks done"; weight: 50};
    {name: "quality"; description: "code is correct"; weight: 50}
  ]
}

assert (type_of g == "Object")
assert (g.rubric | len == 2)
assert (g.threshold == 80)

empty = g.empty_result "test reason"
assert (empty.score == 0)
assert (empty.passed == false)
assert (empty.feedback == "test reason")
assert (empty.categories | len == 2)
assert (empty.failed | len == 2)

log.info "grader_unit: all passed"

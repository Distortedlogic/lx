-- AI agent calls — implement, fix, investigate, diagnose.
use ../schema/work_item {task_context context_for_implement context_for_investigate}

use ../prompt/agents {ImplementPrompt FixPrompt InvestigatePrompt FixWiPrompt}
use ../store/status {save_debug}
use ../log

+implement = (wi task bootstrap_ctx runner_dir) {
  log.log "    > claude: implement task {task.num} (max 25 turns)..."
  ctx = task_context task

  p = ImplementPrompt {}
  p.add_section "Context Bootstrap" bootstrap_ctx
  p.add_section "Work Item Context" (context_for_implement wi)
  p.add_section "Current Task" ctx
  p.add_instruction "Run `just diagnose` after implementation to verify compilation."
  p.add_constraint "Do not add code comments or doc strings"
  p.add_constraint "No #[allow()] macros"

  result = ai.prompt_with {
    prompt: (p.render ())
    tools: ["Read"; "Edit"; "Write"; "Bash"; "Glob"; "Grep"]
    max_turns: 25
  } ^

  save_debug runner_dir wi.slug "task_{task.num}_implement.md" (result.text ?? "")
  log.log "    < done ({result.turns ?? 0} turns)"
  result
}

+diagnose = (task runner_dir slug) {
  log.log "    > diagnose after task {task.num}..."
  diag = $just diagnose
  diag_out = diag ?? {out: ""; err: "command failed"; code: 1}
  output = diag_out.out ?? diag_out.err ?? ""
  clean = output | contains? "0 errors" && (output | contains? "0 warnings")
  save_debug runner_dir slug "task_{task.num}_diagnose.txt" output
  clean ? log.log "    TASK {task.num}: compiles clean" : log.log "    TASK {task.num}: compilation issues"
  clean
}

+fix = (wi task bootstrap_ctx feedback runner_dir) {
  log.log "    > claude: fix task {task.num}..."
  ctx = task_context task

  p = FixPrompt {}
  p.add_section "Context Bootstrap" bootstrap_ctx
  p.add_section "Task" ctx
  p.add_section "Grader Feedback" feedback
  p.add_instruction "Fix the issues. Run `just diagnose` after."
  p.add_constraint "Do not add code comments. Fix only listed issues."

  result = ai.prompt_with {
    prompt: (p.render ())
    tools: ["Read"; "Edit"; "Write"; "Bash"; "Glob"; "Grep"]
    max_turns: 15
  } ^

  save_debug runner_dir wi.slug "task_{task.num}_fix.md" (result.text ?? "")
  log.log "    < fix done ({result.turns ?? 0} turns)"
  result
}

+investigate = (wi bootstrap_ctx runner_dir) {
  log.log "  > claude: investigate full work item..."
  p = InvestigatePrompt {}
  p.add_section "Work Item" (context_for_investigate wi)
  p.add_instruction "Check each file in Files Affected exists (use Glob)"
  p.add_instruction "Check mod.rs registrations if applicable (use Grep)"
  p.add_instruction "Run `just diagnose` — report ONLY errors/warnings"
  p.add_instruction "Run `just test` — report ONLY failures"
  p.add_instruction "For each task: DONE or MISSING with one line"
  p.add_instruction "Keep under 2000 chars. No file contents."

  result = ai.prompt_with {
    prompt: (p.render ())
    tools: ["Read"; "Glob"; "Grep"; "Bash"]
    max_turns: 20
  } ^

  report = result.text ?? ""
  save_debug runner_dir wi.slug "investigate.md" report
  log.log "  < investigate done ({report | len} chars)"
  report
}

+fix_work_item = (wi bootstrap_ctx feedback failed_text runner_dir) {
  log.log "  > claude: fix work item..."
  p = FixWiPrompt {}
  p.add_section "Context Bootstrap" bootstrap_ctx
  p.add_section "Work Item" (context_for_investigate wi)
  p.add_section "Grader Feedback" feedback
  p.add_section "Failed" failed_text
  p.add_instruction "Fix failed categories. Run `just diagnose` and `just test`."

  result = ai.prompt_with {
    prompt: (p.render ())
    tools: ["Read"; "Edit"; "Write"; "Bash"; "Glob"; "Grep"]
    max_turns: 25
  } ^
  save_debug runner_dir wi.slug "fix_wi.md" (result.text ?? "")
  log.log "  < fix done ({result.turns ?? 0} turns)"
  result
}

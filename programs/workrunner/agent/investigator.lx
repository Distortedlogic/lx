use ../prompt/investigate {InvestigatePrompt}
use ../schema/work_item {context_for_investigate}
use pkg/log

+Agent Investigator = {
  act = (msg) {
    log.log "  > claude: investigate full work item..."
    p = InvestigatePrompt {}
    p.add_section "Work Item" (context_for_investigate msg.wi)
    p.add_instruction "Check each file in Files Affected exists (use Glob)"
    p.add_instruction "Check mod.rs registrations if applicable (use Grep)"
    p.add_instruction "Run `just diagnose` — report ONLY errors/warnings"
    p.add_instruction "Run `just test` — report ONLY failures"
    p.add_instruction "For each task: DONE or MISSING with one line"
    p.add_instruction "Scan all touched files for code quality issues"
    p.add_constraint "Flag: empty function bodies, placeholder returns, match arms discarding with _ => {}"
    p.add_constraint "Flag: new struct/trait/enum with no users, TODO/FIXME/unimplemented left behind"
    p.add_constraint "For each task: did the code do what was asked? Anything not asked? Anything incomplete?"
    p.add_constraint "Keep under 2000 chars. No file contents."

    result = self.think_with {
      prompt: (p.render ())
      tools: ["Read"; "Glob"; "Grep"; "Bash"]
      max_turns: 20
    } ^

    report = result.text
    log.save_debug msg.runner_dir msg.wi.slug "investigate.md" report
    log.log "  < investigate done ({report | len} chars)"
    report
  }
}

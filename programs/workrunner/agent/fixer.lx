use std/prompt {new_prompt}
use ../schema/work_item {task_context context_for_investigate}
use pkg/log

+Agent TaskFixer = {
  tools = () { ["Read"; "Edit"; "Write"; "Bash"; "Glob"; "Grep"] }
  max_turns = () { 15 }

  system_prompt = () { "Fix the issues found in this task. Fix ONLY what the grader flagged." }

  build_prompt = (msg) {
    ctx = task_context msg.task
    p = new_prompt (self.system_prompt ())
    p.compose msg.bootstrap_prompt
    p.add_section "Task" ctx
    p.add_section "Grader Feedback" msg.feedback
    p.add_instruction "Fix the issues. Run `just diagnose` after."
    p.add_constraint "Do not add code comments. Fix only listed issues."
    p
  }

  on_turn_start = (msg) { log.log "    > claude: fix task {msg.task.num}..." }

  on_turn_end = (msg result) {
    log.save_debug msg.runner_dir msg.wi.slug "task_{msg.task.num}_fix.md" result.text
    log.log "    < fix done ({result.turns ?? 0} turns)"
  }

  act = (msg) {
    p = self.build_prompt msg
    result = self.think_with { prompt: (p.render ()) } ^
    result
  }
}

+Agent WorkItemFixer = {
  tools = () { ["Read"; "Edit"; "Write"; "Bash"; "Glob"; "Grep"] }

  system_prompt = () { "Fix issues found in work item grading. Fix ONLY what failed." }

  build_prompt = (msg) {
    p = new_prompt (self.system_prompt ())
    p.compose msg.bootstrap_prompt
    p.add_section "Work Item" (context_for_investigate msg.wi)
    p.add_section "Grader Feedback" msg.feedback
    p.add_section "Failed" msg.failed_text
    p.add_instruction "Fix failed categories. Run `just diagnose` and `just test`."
    p
  }

  on_turn_start = (msg) { log.log "  > claude: fix work item..." }

  on_turn_end = (msg result) {
    log.save_debug msg.runner_dir msg.wi.slug "fix_wi.md" result.text
    log.log "  < fix done ({result.turns ?? 0} turns)"
  }

  act = (msg) {
    p = self.build_prompt msg
    result = self.think_with { prompt: (p.render ()) } ^
    result
  }
}

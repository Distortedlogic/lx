use ../prompt/fix {FixPrompt}
use ../prompt/fix_wi {FixWiPrompt}
use ../schema/work_item {task_context context_for_investigate}
use ../store/status {save_debug}
use pkg/log

+Agent TaskFixer = {
  act = (msg) {
    log.log "    > claude: fix task {msg.task.num}..."
    ctx = task_context msg.task

    p = FixPrompt {}
    p.compose msg.bootstrap_prompt
    p.add_section "Task" ctx
    p.add_section "Grader Feedback" msg.feedback
    p.add_instruction "Fix the issues. Run `just diagnose` after."
    p.add_constraint "Do not add code comments. Fix only listed issues."

    result = self.think_with {
      prompt: (p.render ())
      tools: ["Read"; "Edit"; "Write"; "Bash"; "Glob"; "Grep"]
      max_turns: 15
    } ^

    save_debug msg.runner_dir msg.wi.slug "task_{msg.task.num}_fix.md" result.text
    log.log "    < fix done ({result.turns ?? 0} turns)"
    result
  }
}

+Agent WorkItemFixer = {
  act = (msg) {
    log.log "  > claude: fix work item..."
    p = FixWiPrompt {}
    p.compose msg.bootstrap_prompt
    p.add_section "Work Item" (context_for_investigate msg.wi)
    p.add_section "Grader Feedback" msg.feedback
    p.add_section "Failed" msg.failed_text
    p.add_instruction "Fix failed categories. Run `just diagnose` and `just test`."

    result = self.think_with {
      prompt: (p.render ())
      tools: ["Read"; "Edit"; "Write"; "Bash"; "Glob"; "Grep"]
      max_turns: 25
    } ^

    save_debug msg.runner_dir msg.wi.slug "fix_wi.md" result.text
    log.log "  < fix done ({result.turns ?? 0} turns)"
    result
  }
}

-- AI agent calls for workgen — investigate, compose, revise.

use workgen/prompt/agents {InvestigatePrompt ComposePrompt RevisePrompt}
use workgen/store/status {save_debug}
use workgen/log : wg_log

+investigate = (audit_content root runner_dir slug) {
  wg_log.log "  > claude: investigate codebase (max 30 turns)..."

  p = InvestigatePrompt {}
  p.add_section "Audit Checklist" audit_content
  p.add_instruction "For each audit item, search the codebase under '{root}/' to determine if it is violated"
  p.add_instruction "Read every relevant file — do not guess from filenames alone"
  p.add_instruction "Return a numbered list of findings: concrete problem, root cause, single best fix, affected files"
  p.add_constraint "Report ONLY problems — do not list things that are correct"
  p.add_constraint "One fix per finding, verbal only, no code snippets"

  result = ai.prompt_with {
    prompt: p.render ()
    tools: ["Read"; "Glob"; "Grep"; "Bash"]
    max_turns: 30
  } ^

  findings = result.text ?? ""
  save_debug runner_dir slug "investigate.md" findings
  wg_log.log "  < investigate done ({findings | lines | len} lines, {result.turns ?? 0} turns)"
  findings
}

+compose = (audit_content rules_content findings runner_dir slug) {
  wg_log.log "  > claude: compose work item document..."

  p = ComposePrompt {}
  p.add_section "Audit Checklist" audit_content
  p.add_section "Process Rules" rules_content
  p.add_section "Investigation Findings" findings
  p.add_instruction "Produce a single markdown work item document following the Process Rules exactly"
  p.add_instruction "Required sections: # Goal, # Why, # What changes, # Files affected, # Task List, # CRITICAL REMINDERS"
  p.add_constraint "Output ONLY the raw markdown — no preamble, no commentary"
  p.add_constraint "Start with '# Goal' — nothing before it"

  result = ai.prompt_with {
    prompt: p.render ()
    disable_tools: true
  } ^

  draft = result.text ?? ""
  save_debug runner_dir slug "compose.md" draft
  wg_log.log "  < compose done ({draft | lines | len} lines)"
  draft
}

+revise = (draft feedback runner_dir slug round_num) {
  wg_log.log "  > claude: revise draft (round {round_num})..."

  p = RevisePrompt {}
  p.add_section "Current Document" draft
  p.add_section "Feedback to Fix" feedback
  p.add_instruction "Fix ALL feedback items. Return the complete revised markdown document."
  p.add_constraint "Do not remove content to avoid checks — fix issues properly"
  p.add_constraint "Start with '# Goal' — nothing before it"

  result = ai.prompt_with {
    prompt: p.render ()
    disable_tools: true
  } ^

  revised = result.text ?? ""
  save_debug runner_dir slug "revise_round_{round_num}.md" revised
  wg_log.log "  < revise done ({revised | lines | len} lines)"
  revised
}

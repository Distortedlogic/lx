use ../prompt/agents {InvestigatePrompt}
use ../store/status {save_debug}
use ../log : wg_log

+Agent Investigator = {
  act = (msg) {
    wg_log.log "  > claude: investigate codebase (max 30 turns)..."

    p = InvestigatePrompt {}
    p.add_section "Audit Checklist" msg.audit_content
    p.add_instruction "For each audit item, search the codebase under '{msg.root}/' to determine if it is violated"
    p.add_instruction "Read every relevant file — do not guess from filenames alone"
    p.add_instruction "Return a numbered list of findings: concrete problem, root cause, single best fix, affected files"
    p.add_constraint "Report ONLY problems — do not list things that are correct"
    p.add_constraint "One fix per finding, verbal only, no code snippets"

    result = self.think_with {
      prompt: p.render ()
      tools: ["Read"; "Glob"; "Grep"; "Bash"]
      max_turns: 30
    } ^

    findings = result.text
    save_debug msg.runner_dir msg.slug "investigate.md" findings
    wg_log.log "  < investigate done ({findings | lines | len} lines, {result.turns ?? 0} turns)"
    findings
  }
}

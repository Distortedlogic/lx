use ../agent/grader {Grader}
use ../schema/grade {GradeResult CategoryScore}

g = Grader {
  threshold: 75
  rubric: [
    {name: "coverage"; description: "findings match audit"; weight: 50};
    {name: "quality"; description: "tasks are clear"; weight: 50}
  ]
}

assert (type_of g == "Object")
assert (g.rubric | len == 2)
assert (g.threshold == 75)

good_json = {categories: [
  {name: "coverage"; score: 90; feedback: "good coverage"};
  {name: "quality"; score: 85; feedback: "clear tasks"}
]}
result = g.assemble good_json
assert (result.passed == true)
assert (result.score > 75)
assert (result.failed | len == 0)

bad_json = {categories: [
  {name: "coverage"; score: 40; feedback: "missing items"};
  {name: "quality"; score: 30; feedback: "vague tasks"}
]}
result2 = g.assemble bad_json
assert (result2.passed == false)
assert (result2.failed | len == 2)

empty = g.empty_result "test error"
assert (empty.score == 0)
assert (empty.feedback == "test error")

text_good = `{"categories":[{"name":"coverage","score":95,"feedback":"ok"},{"name":"quality","score":88,"feedback":"ok"}]}`
parsed = g.parse_response text_good
assert (parsed.passed == true)

text_bad = "not json"
parsed_bad = g.parse_response text_bad
assert (parsed_bad.score == 0)

-- structured response (json_schema path returns parsed record, no .text field)
structured_result = {categories: [
  {name: "coverage"; score: 80; feedback: "solid"};
  {name: "quality"; score: 90; feedback: "clear"}
]}
assert (structured_result.text == None)
structured_grade = g.assemble structured_result
assert (structured_grade.passed == true)
assert (structured_grade.score > 75)

-- unstructured/fallback response (has .text field)
text_result = {text: `{"categories":[{"name":"coverage","score":80,"feedback":"ok"},{"name":"quality","score":85,"feedback":"ok"}]}`}
assert (text_result.text != None)
response_text = text_result.text ?? ""
text_grade = g.parse_response response_text
assert (text_grade.passed == true)

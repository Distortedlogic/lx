-- Satisfaction test runner for workgen.
-- Runs workgen against each scenario's fixture codebase.

use std/env
use std/fs
use pkg/log
use ../schema/audit {load}
use ../agent/grader {Grader}
use ../workflow/orchestrator
use ./spec

wi_grader = Grader {threshold: spec.threshold_pct; rubric: spec.rubric}
rules_dir = "{source_dir ()}/../rules"
rules_content = fs.read "{rules_dir}/work-item.md" ^

run_one = (scenario) {
  audit = load scenario.audit ^
  orchestrator.run_audit audit rules_content scenario.root wi_grader 3 ".lx/workgen_test" ^
}

run_scenario_impl = (scenario) {
  log.log "  --- {scenario.name} ---"
  result = try run_one scenario
  result ? {
    Err e -> {name: scenario.name; passed: false; score: 0}
    r -> {name: scenario.name; passed: r.status == "pass"; score: r.score}
  }
}

+main = () {
  tag_filter = env.get "TEST_TAG" ?? ""
  scenarios = tag_filter == "" ? spec.scenarios : (spec.scenarios | filter (s) { s.tags | contains? tag_filter })

  log.log "=== workgen satisfaction tests ==="
  log.log "scenarios: {scenarios | len}"
  log.log "threshold: {spec.threshold}"

  results = scenarios | map run_scenario_impl

  passed_count = results | filter (r) { r.passed == true } | len
  total = results | len

  log.log ""
  log.log "=== {spec.name} ==="
  results | each (r) {
    status = r.passed ? "PASS" : "FAIL"
    log.log "  {r.name}: {r.score} {status}"
  }
  log.log "Overall: {passed_count}/{total} passed (threshold: {spec.threshold})"

  passed_count == total ? (Ok results) : (Err "some scenarios failed")
}

main ()

-- Task decomposition and planning specialist
-- Source: breaks down complex goals into executable step sequences

use pkg/workflow/plan
use ../traits {Planner}
use pkg/agent/score
use pkg/schema/contracts {ActionPlan}

Prompt PlanningPrompt = {
  system: "You create precise, minimal execution plans."
}

Prompt ReplanPrompt = {
  system: "You adapt plans when steps fail."
}

Schema PlanStep = {
  id: Str = "unique step identifier"
  description: Str = "what this step accomplishes"
  action: Str = "the action to take"
  tool: Str = "tool to use for this step"
  depends: List = "step IDs this depends on"
  estimated_tokens: Int = "estimated token cost"
  can_parallelize: Bool = "true if safe to run concurrently"
}

Schema PlanResult = {
  steps: List = "ordered list of PlanStep records"
  total_estimated_tokens: Int = "sum of all step token estimates"
  parallel_groups: List = "groups of step IDs safe to parallelize"
  critical_path: List = "longest dependency chain"
  risks: List = "identified risks in the plan"
}

Agent TaskPlanner: Planner = {
  plan = (msg) {
    tools_text = msg.tools | join ", "

    p = PlanningPrompt {}
    p.add_section "Goal" msg.goal
    p.add_section "Available Tools" tools_text
    p.add_instruction "Create 10 or fewer steps. Each step: ID, description, tool, dependencies."
    p.add_constraint "Minimize steps. Identify parallelizable ones. No circular deps."

    text = p.ask msg.goal

    steps = text | lines
      | filter (l) trim l | not empty?
      | enumerate
      | map (i line) {
          id: "s{i}"
          action: trim line
          tool: msg.tools | get 0 ?? "ai"
          args: trim line
          depends: i > 0 ? ["s{i - 1}"] : []
        }

    estimated = steps | len * 0.01

    ActionPlan {
      goal: msg.goal
      steps
      estimated_cost: estimated
      risk: score.tier [{min: 1.0; name: "high"}; {min: 0.3; name: "medium"}; {min: 0.0; name: "low"}] estimated
      fallback: "simplify approach and retry with fewer tools"
    }
  }

  replan = (msg) {
    remaining = msg.plan.steps
      | filter (s) not (s.depends | contains? msg.failure)

    p = ReplanPrompt {}
    p.add_section "Failed Step" msg.failure
    p.add_section "Remaining Steps" (remaining | map (.action) | join "\n")
    p.add_instruction "Create an alternative plan that works around the failure."

    text = p.ask ""
    new_steps = text | lines
      | filter (l) trim l | not empty?
      | enumerate
      | map (i line) {
          id: "r{i}"
          action: trim line
          tool: "ai"
          args: trim line
          depends: i > 0 ? ["r{i - 1}"] : []
        }

    {..msg.plan; steps: new_steps}
  }

  estimate_cost = (msg) {
    msg.steps | len * 500.0
  }
}

+execute_plan = (plan_result: PlanResult; executor: Any) -> Any {
  steps = plan_result.steps | map (step) {
    {id: step.id; action: {description: step.description; tool: step.tool}; depends: step.depends}
  }

  plan.run steps executor (step_id result) {
    result ? {
      Ok _ -> plan.continue ()
      Err e & (e | to_str | contains? "recoverable") -> {
        log.warn "step {step_id} failed recoverably: {e}, replanning"
        recovery_step = {
          id: "recovery_{step_id}"
          action: {description: "retry {step_id} with simplified approach"; tool: "ai"}
          depends: []
        }
        plan.insert_after step_id recovery_step
      }
      Err e -> {
        log.warn "step {step_id} failed: {e}, skipping"
        plan.skip ()
      }
    }
  }
}

find_parallel_groups = (steps: [PlanStep]) -> [[Str]] {
  groups := []
  current_group := []
  last_dep := ""

  steps | each (step) {
    has_new_dep = step.depends | len > 0 && step.depends != [last_dep]
    has_new_dep ? {
      current_group | len > 0 ? { groups <- [..groups; current_group] } : ()
      current_group <- [step.id]
      last_dep <- step.id
    } : {
      current_group <- [..current_group; step.id]
    }
  }

  current_group | len > 0 ? [..groups; current_group] : groups
}

+main = () {
  receive {
    plan -> TaskPlanner.plan
    replan -> TaskPlanner.replan
    estimate -> TaskPlanner.estimate_cost
    _ -> (msg) Err "unknown action: {msg.action ?? 'none'}"
  }
}

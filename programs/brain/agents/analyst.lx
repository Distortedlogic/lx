-- Deep analysis specialist: investigates problems thoroughly
-- Source: dispatched when perception flags a complex or ambiguous input

use ../capability {advertise}
use ../traits {Analyst}

Prompt AnalysisPrompt = {
  system: "You are an analytical specialist. You find what others miss."
}

Prompt ComparisonPrompt = {
  system: "You compare options systematically against criteria."
}

Prompt InvestigationPrompt = {
  system: "You investigate questions by forming hypotheses and identifying evidence."
}

Schema AnalysisResult = {
  summary: Str = "concise analysis summary"
  findings: List = "key findings from analysis"
  confidence: Float = "0.0-1.0 confidence in analysis"
  gaps: List = "areas needing further investigation"
  recommendations: List = "suggested next actions"
}

Agent DeepAnalyst: Analyst = {
  role = () { "analytical specialist" }
  goal = () { "find what others miss" }
  system_prompt = () { "You are an analytical specialist. You find what others miss." }

  analyze = (msg) {
    depth_instruction = msg.depth ? {
      "shallow" -> "Give a brief, high-level analysis in 2-3 sentences."
      "standard" -> "Provide a thorough analysis covering key aspects."
      "deep" -> "Perform exhaustive analysis. Consider edge cases and second-order effects."
      _ -> "Provide a thorough analysis."
    }

    p = AnalysisPrompt {}
    p.add_section "Topic" msg.topic
    p.add_section "Context" msg.context
    p.add_instruction depth_instruction
    p.add_constraint "Structure: Summary, Findings (bulleted), Gaps, Recommendations"

    text = p.ask "analysis unavailable"
    sections = text | lines | partition (starts? "- ")
    findings = sections.0 | map (drop 2) | map trim

    AnalysisResult {
      summary: sections.1 | join "\n" | lines | first ?? text
      findings
      confidence: 0.7
      gaps: []
      recommendations: findings | take 3
    }
  }

  compare = (msg) {
    items_text = msg.items
      | enumerate
      | map (i item) "### Option {i + 1}\n{item}"
      | join "\n\n"

    p = ComparisonPrompt {}
    p.add_section "Options" items_text
    p.add_section "Criteria" (msg.criteria | join ", ")
    p.add_section "Context" msg.context
    p.add_instruction "Evaluate each option against each criterion. Pick a winner."

    text = p.ask "comparison unavailable"
    {comparison: text; winner_index: 0}
  }

  investigate = (msg) {
    p = InvestigationPrompt {}
    p.add_section "Question" msg.question
    p.add_section "Available Tools" (msg.tools | join ", ")
    p.add_instruction "1) Form a hypothesis. 2) List evidence needed. 3) Suggest tool calls."

    text = p.ask "investigation unavailable"
    {
      hypothesis: text | lines | first ?? ""
      evidence_needed: text | lines | filter (starts? "- ") | map (drop 2)
    }
  }
}

+main = () {
  advertise {
    traits: ["AnalysisResult"]
    domains: ["analyst"; "analysis"; "investigation"; "comparison"]
    tools: ["ai"]
  }

  receive {
    analyze -> DeepAnalyst.analyze
    compare -> DeepAnalyst.compare
    investigate -> DeepAnalyst.investigate
    _ -> (msg) Err "unknown action: {msg.action ?? 'none'}"
  }
}

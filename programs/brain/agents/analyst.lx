-- Deep analysis specialist: investigates problems thoroughly
-- Source: dispatched when perception flags a complex or ambiguous input

use pkg/core/prompt
use pkg/core/capability {advertise}
use ../traits {Analyst}

Schema AnalysisResult = {
  summary: Str = "concise analysis summary"
  findings: List = "key findings from analysis"
  confidence: Float = "0.0-1.0 confidence in analysis"
  gaps: List = "areas needing further investigation"
  recommendations: List = "suggested next actions"
}

Agent DeepAnalyst: Analyst = {
  analyze = (msg) {
    depth_instruction = msg.depth ? {
      "shallow" -> "Give a brief, high-level analysis in 2-3 sentences."
      "standard" -> "Provide a thorough analysis covering key aspects."
      "deep" -> "Perform exhaustive analysis. Consider edge cases and second-order effects."
      _ -> "Provide a thorough analysis."
    }

    p = prompt.create ()
      | prompt.system "You are an analytical specialist. You find what others miss."
      | prompt.section "Topic" msg.topic
      | prompt.section "Context" msg.context
      | prompt.instruction depth_instruction
      | prompt.constraint "Structure: Summary, Findings (bulleted), Gaps, Recommendations"

    text = prompt.ask p "analysis unavailable"
    sections = text | lines | partition (starts? "- ")
    findings = sections.0 | map (drop 2) | map trim

    AnalysisResult {
      summary: sections.1 | join "\n" | lines | first ?? text
      findings
      confidence: 0.7
      gaps: []
      recommendations: findings | take 3
    }
  }

  compare = (msg) {
    items_text = msg.items
      | enumerate
      | map (i item) "### Option {i + 1}\n{item}"
      | join "\n\n"

    p = prompt.create ()
      | prompt.system "You compare options systematically against criteria."
      | prompt.section "Options" items_text
      | prompt.section "Criteria" (msg.criteria | join ", ")
      | prompt.section "Context" msg.context
      | prompt.instruction "Evaluate each option against each criterion. Pick a winner."

    text = prompt.ask p "comparison unavailable"
    {comparison: text  winner_index: 0}
  }

  investigate = (msg) {
    p = prompt.create ()
      | prompt.system "You investigate questions by forming hypotheses and identifying evidence."
      | prompt.section "Question" msg.question
      | prompt.section "Available Tools" (msg.tools | join ", ")
      | prompt.instruction "1) Form a hypothesis. 2) List evidence needed. 3) Suggest tool calls."

    text = prompt.ask p "investigation unavailable"
    {
      hypothesis: text | lines | first ?? ""
      evidence_needed: text | lines | filter (starts? "- ") | map (drop 2)
    }
  }
}

+main = () {
  advertise {
    traits: ["AnalysisResult"]
    domains: ["analyst" "analysis" "investigation" "comparison"]
    tools: ["ai"]
  }

  receive {
    analyze -> DeepAnalyst.analyze
    compare -> DeepAnalyst.compare
    investigate -> DeepAnalyst.investigate
    _ -> (msg) Err "unknown action: {msg.action ?? 'none'}"
  }
}

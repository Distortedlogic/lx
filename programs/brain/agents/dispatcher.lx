-- Multi-agent dispatcher: spawns and coordinates specialist agents
-- Source: the brain's workforce coordinator — spawn, route, fan-out, reconcile, supervise
-- Architecture: agents spawned as subprocesses, communicate via ~>?, pub/sub for events
-- spawn_needed: selective spawning based on perception (complex → all, moderate → analyst only)

use ../intercept {intercept}
use ../capability {capabilities}
use ../reconcile {reconcile}
use ../negotiate {negotiate}
use pkg/store/trace {TraceStore}
use pkg/schema/contracts {AgentTask AgentResult}

+create_workforce = () -> Any {
  (analyst critic researcher) = par {
    agent.spawn {command: "lx" args: ["run" "brain/agents/analyst.lx"]} ^
    agent.spawn {command: "lx" args: ["run" "brain/agents/critic.lx"]} ^
    agent.spawn {command: "lx" args: ["run" "brain/agents/researcher.lx"]} ^
  }

  {analyst  critic  researcher}
}

+spawn_needed = (perception: Any) -> Any {
  needs_analyst = perception.requires_agents || perception.complexity == "complex"
  needs_critic = perception.complexity == "complex"
  needs_researcher = perception.requires_tools && (perception.domain ?? "" | contains? "research")

  (analyst critic researcher) = par {
    needs_analyst ? (agent.spawn {command: "lx" args: ["run" "brain/agents/analyst.lx"]} ^) : None
    needs_critic ? (agent.spawn {command: "lx" args: ["run" "brain/agents/critic.lx"]} ^) : None
    needs_researcher ? (agent.spawn {command: "lx" args: ["run" "brain/agents/researcher.lx"]} ^) : None
  }

  {analyst; critic; researcher}
}

+setup_tracing = (workforce: Any; session: Any) -> Any {
  trace_wrap = (worker name) {
    worker == None ? None : intercept worker (msg next) {
      session.record {name: "{name}_msg" input: msg.action ?? "unknown"} ?? ()
      next msg
    }
  }

  {
    analyst: trace_wrap workforce.analyst "analyst"
    critic: trace_wrap workforce.critic "critic"
    researcher: trace_wrap workforce.researcher "researcher"
  }
}

+setup_pubsub = (workforce: Any) -> Any {
  topics = {
    perception: agent.topic "perception"
    reasoning: agent.topic "reasoning"
    response: agent.topic "response"
  }

  workforce.analyst != None ? agent.subscribe_filtered topics.perception workforce.analyst (msg) msg.complexity ?? "simple" == "complex"
  workforce.critic != None ? agent.subscribe topics.reasoning workforce.critic
  workforce.researcher != None ? agent.subscribe topics.response workforce.researcher

  topics
}

+dispatch_task = (workforce: Any; task: AgentTask) -> AgentResult {
  worker = route_to_worker workforce task.specialist

  result = worker ~>? {
    action: task.specialist == "critic" ? "critique" : "analyze"
    topic: task.instruction
    context: task.context
    depth: "standard"
    content: task.instruction
    content_type: "text"
    task: task.instruction
    confidence: 0.5
    question: task.instruction
    scope: "broad"
    sources: ["codebase"]
  } ^

  AgentResult {
    task_id: task.id
    specialist: task.specialist
    output: result
    confidence: result.confidence ?? 0.5
    tokens_used: 500
  }
}

route_to_worker = (workforce: Any; specialist: Str) -> Any {
  active = [
    workforce.analyst != None ? [workforce.analyst] : []
    workforce.critic != None ? [workforce.critic] : []
    workforce.researcher != None ? [workforce.researcher] : []
  ] | flat_map (x) x

  active | empty? ? Err "no active specialists" : {
    specialist ? {
      "analyst" -> workforce.analyst ?? active | first
      "critic" -> workforce.critic ?? active | first
      "researcher" -> workforce.researcher ?? active | first
      _ -> active | first
    }
  }
}

+fan_out = (workforce: Any; tasks: [AgentTask]) -> [AgentResult] {
  tasks | pmap_n 3 (task) dispatch_task workforce task ^
}

+fan_out_and_reconcile = (workforce: Any; tasks: [AgentTask]; strategy: Str = "merge_fields") -> Any {
  fan_out workforce tasks ^ | (results) reconcile results {strategy}
}

+parallel_review = (workforce: Any; content: Str; task: Str) -> Any {
  (analysis critique) = par {
    workforce.analyst ~>? {action: "analyze" topic: task context: content depth: "standard"} ^
    workforce.critic ~>? {action: "critique" content: content content_type: "text" task: task confidence: 0.7} ^
  }

  agreement = (analysis.confidence ?? 0.5) > 0.7 && (critique.revised_confidence ?? 0.5) > 0.5

  agreement ? {
    {analysis: analysis; critique: critique; consensus: true}
  } : {
    negotiated = negotiate [workforce.analyst workforce.critic] {
      topic: "review of: {task}"
      max_rounds: 3
      strategy: "convergence"
    }
    {analysis: analysis; critique: critique; consensus: false; negotiated: negotiated}
  }
}

+supervised_workforce = (workforce: Any) -> Any {
  agent.supervise {
    strategy: "one_for_one"
    max_restarts: 3
    window: 120
    children: [
      {id: "analyst" spawn: () agent.spawn {command: "lx" args: ["run" "brain/agents/analyst.lx"]} ^; restart: "permanent"}
      {id: "critic" spawn: () agent.spawn {command: "lx" args: ["run" "brain/agents/critic.lx"]} ^; restart: "permanent"}
      {id: "researcher" spawn: () agent.spawn {command: "lx" args: ["run" "brain/agents/researcher.lx"]} ^; restart: "permanent"}
    ]
  }
}

+status = (workforce: Any) -> Any {
  {
    analyst: workforce.analyst != None ? "running" : "idle"
    critic: workforce.critic != None ? "running" : "idle"
    researcher: workforce.researcher != None ? "running" : "idle"
  }
}

+shutdown = (workforce: Any) -> Any {
  par {
    workforce.analyst != None ? agent.kill workforce.analyst : ()
    workforce.critic != None ? agent.kill workforce.critic : ()
    workforce.researcher != None ? agent.kill workforce.researcher : ()
  }
}

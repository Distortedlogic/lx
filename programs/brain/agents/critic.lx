-- Inner critic: challenges assumptions, finds flaws, prevents overconfidence
-- Source: adversarial self-review before committing to a response

use ../lib/guard
use pkg/agent/score
use ../lib/capability {advertise}
use ../traits {Critic}

Prompt CritiquePrompt = {
  system: "You are a rigorous critic. Find flaws, gaps, and risks. Be honest, not kind."
}

Prompt ChallengePrompt = {
  system: "You challenge assumptions by finding counterexamples and edge cases."
}

Prompt CorrectnessPrompt = {
  system: "You verify code correctness."
}

Schema Critique = {
  flaws: List = "logical or factual flaws found"
  risks: List = "potential risks or failure modes"
  missing: List = "important considerations not addressed"
  overconfident: Bool = "true if confidence exceeds evidence"
  suggested_improvements: List = "specific actionable improvements"
  severity: Str = "low, medium, or high"
  revised_confidence: Float = "0.0-1.0 recommended confidence after critique"
}

Agent InnerCritic: Critic = {
  critique = (msg) {
    p = CritiquePrompt {}
    p.add_section "Content ({msg.content_type})" msg.content
    p.add_section "Original Task" msg.task
    p.add_section "Claimed Confidence" "{msg.confidence}"
    p.add_instruction "Find: 1) Factual errors 2) Logical gaps 3) Missing edge cases 4) Security risks"
    p.add_constraint "If the content is actually good, say so briefly. Don't manufacture issues."

    resp = ai.prompt (p.render ()) ^
    issues = resp.text | lines | filter (starts? "- ") | map (drop 2)

    flaws = issues | filter (contains? "error")
    risks = issues | filter (contains? "risk")
    issue_count = len flaws + len risks

    {
      flaws
      risks
      severity: score.tier [{min: 6  name: "high"}; {min: 3  name: "medium"}; {min: 1  name: "low"}; {min: 0  name: "none"}] issue_count
      revised_confidence: msg.confidence - issue_count * 0.1 | math.max 0.1
    }
  }

  challenge = (msg) {
    p = ChallengePrompt {}
    p.add_section "Assumption" msg.assumption
    p.add_section "Context" msg.context
    p.add_instruction "1) State the assumption. 2) Find counterexamples. 3) Where does it break?"

    resp = ai.prompt (p.render ()) ^
    counterexamples = resp.text | lines | filter (starts? "- ") | map (drop 2)
    {holds: counterexamples | empty?  counterexamples: counterexamples}
  }

  verify_code = (msg) {
    (correctness safety) = par {
      check_correctness msg.code msg.task
      guard.check msg.code guard.safety_patterns
    }
    {all_passed: correctness.ok && safety.pass}
  }
}

check_correctness = (code: Str  task: Str) -> {ok: Bool  issues: [Str]} {
  p = CorrectnessPrompt {}
  p.add_section "Code" code
  p.add_section "Task" task
  p.add_instruction "Does this code correctly accomplish the task? List any bugs."

  resp = ai.prompt (p.render ()) ^
  bugs = resp.text | lines | filter (starts? "- ") | map (drop 2)
  {ok: bugs | empty?  issues: bugs}
}

+main = () {
  advertise {
    traits: ["Critique"]
    domains: ["critic"; "review"; "verification"; "quality"]
    tools: ["ai"]
  }

  receive {
    critique -> InnerCritic.critique
    challenge -> InnerCritic.challenge
    verify_code -> InnerCritic.verify_code
    _ -> (msg) Err "unknown action: {msg.action ?? 'none'}"
  }
}

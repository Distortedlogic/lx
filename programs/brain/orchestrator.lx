-- Orchestrator: session management — continuous mode, budgets, health monitoring
-- Source: pub/sub event bus, cron scheduling, memory consolidation
-- Architecture: delegates cognitive processing to main.think, handles session lifecycle

use pkg/workflow/saga
use pkg/agent/budget
use std/cron
use ./workflow/workflow
use pkg/store/tasks {TaskStore}
use std/diag
use std/time

use ./contracts {Response ResponseEvent}
use ./tieredmem : mem
use ./identity : identity
use ./agents/monitor : monitor
use pkg/agent/reflect : reflection
use ./dialogue : dialogue
use ./workflow/cognitive_saga : cognitive_saga
use ./agents/dispatcher : dispatch
use . : brain

+run_saga = (input: Str) -> Any {
  state = monitor.init ()
  memory_store = mem.init "{env.home ()}/.lx/brain" "claude"
  context_win = (use ./context_mgr).init 128000
  id = identity.core ()
  (use ./context_mgr).pin_identity context_win id
  saga_ctx = Store ()

  workflow.run "brain-saga" input (trace) {
    workforce = dispatch.create_workforce ()
    traced = dispatch.setup_tracing workforce trace
    topics = dispatch.setup_pubsub traced

    gate = identity.gate_destructive input
    gate ? {
      Err reason -> { emit "Blocked: {reason}"; Err reason }
      Ok _ -> {
        steps = cognitive_saga.build input state memory_store context_win traced trace saga_ctx
        result = saga.run steps

        result ? {
          Ok outputs -> {
            response = outputs.respond
            agent.publish topics.response ResponseEvent {response; confidence: response.confidence; timestamp: time.now ()}

            refl = reflection.reflect input response.content "quality response" ??
              {action: input; outcome: response.content; quality: 0.5; lesson: ""; should_remember: false; strategy_worked: true}
            refl.should_remember ? mem.remember memory_store {content: refl.lesson; domain: "meta"; confidence: refl.quality; source: "reflection"; tags: ["lesson"]} ?? () : ()

            mem.save memory_store ?? ()
            dispatch.shutdown workforce
            emit response.content
            {response; reflection: refl; trace: trace}
          }
          Err failure -> {
            log.err "saga failed at: {failure.failed_step ?? "unknown"}"
            emit "Issue encountered. Trying simpler approach."
            fallback = (use pkg/agent/reasoning).reason input "" ["keep it simple"] ^
            dispatch.shutdown workforce
            {response: {content: fallback.conclusion; confidence: 0.3; reasoning_depth: 1; tools_used: []; sources: ["fallback"]; follow_up: []}; trace: trace}
          }
        }
      }
    }
  }
}

+run_with_budget = (input: Str; token_budget: Int) -> Any {
  b = budget.create {tokens: token_budget; api_calls: 20; wall_time: 300}
  budget.remaining b | (r) log.info "budget: {r.tokens} tokens, {r.api_calls} calls"

  result = brain.think input [] None ^

  budget.used b | (spent) {
    log.info "finished — used {spent.tokens} tokens, {spent.api_calls} calls"
    {..result; budget_used: spent}
  }
}

+run_continuous = () -> Any {
  emit "Claude brain orchestrator ready"

  cron.every 300000 () () {
    store = mem.init "{env.home ()}/.lx/brain" "claude"
    consolidated = mem.consolidate store
    log.info "memory consolidation: {consolidated.promoted} promoted"
    mem.save store ?? ()
  }

  cron.every 60000 () () {
    state = monitor.init ()
    health = monitor.check_health state
    health.strategy != "normal" ? log.warn "health: {health.strategy}" : ()
  }

  input := yield {kind: "ready"}
  conversation := dialogue.init_conversation ()

  loop {
    input ? {
      None -> break ()
      Some raw -> {
        conversation <- dialogue.add_turn conversation "user" raw
        result = brain.think raw [] conversation ^
        conversation <- dialogue.add_turn conversation "assistant" result.response.content

        input <- yield {
          kind: "response"
          data: result.response.content
          turn: dialogue.turn_count conversation
          quality: result.quality.score ?? 0
        }
      }
    }
  }

  emit "Session ended. {dialogue.conversation_summary conversation}"
}

+visualize = () -> Str {
  diag.to_mermaid {
    title: "Claude Brain — Adaptive Cognitive Pipeline"
    nodes: [
      {id: "input" label: "Input"}
      {id: "perceive" label: "Perceive"}
      {id: "recall" label: "Recall Memory"}
      {id: "route" label: "Route by Complexity"}
      {id: "fast" label: "Think Fast"}
      {id: "moderate" label: "Think Moderate"}
      {id: "deep" label: "Think Deep"}
      {id: "tools" label: "Execute Tools"}
      {id: "specialists" label: "Dispatch Specialists"}
      {id: "re_reason" label: "Re-Reason"}
      {id: "critic" label: "Critic Gate"}
      {id: "respond" label: "Respond"}
      {id: "reflect" label: "Reflect & Learn"}
      {id: "output" label: "Output"}
    ]
    edges: [
      {from: "input" to: "perceive"}
      {from: "perceive" to: "recall"}
      {from: "recall" to: "route"}
      {from: "route" to: "fast" label: "trivial/simple"}
      {from: "route" to: "moderate" label: "moderate"}
      {from: "route" to: "deep" label: "complex"}
      {from: "fast" to: "respond"}
      {from: "moderate" to: "tools"}
      {from: "tools" to: "re_reason"}
      {from: "re_reason" to: "respond"}
      {from: "deep" to: "tools"}
      {from: "deep" to: "specialists"}
      {from: "specialists" to: "re_reason"}
      {from: "re_reason" to: "critic"}
      {from: "critic" to: "respond"}
      {from: "respond" to: "reflect"}
      {from: "reflect" to: "output"}
    ]
  }
}

+Trait Tool = {
  description: Str = ""
  params: Record = {}

  run = (args) { Err "Tool.run not implemented" }

  schema = () {
    self.params
  }

  validate = (args) {
    missing = self.params | keys | filter (k) { not (args | keys | any? (== k)) }
    (missing | len) == 0 ? Ok args : Err {missing: missing}
  }
}

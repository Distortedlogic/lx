{
  "name": "lx-lang",
  "displayName": "lx",
  "description": "Language support for the lx agentic workflow language",
  "version": "0.2.0",
  "publisher": "lx-lang",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:lx"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lx",
        "aliases": [
          "lx",
          "LX"
        ],
        "extensions": [
          ".lx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/lx-icon-light.svg",
          "dark": "./icons/lx-icon-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "lx",
        "scopeName": "source.lx",
        "path": "./syntaxes/lx.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "lx-icons",
        "label": "lx File Icons",
        "path": "./icons/lx-icon-theme.json"
      }
    ],
    "configuration": {
      "title": "lx",
      "properties": {
        "lx.diagram.autoGenerate": {
          "type": "boolean",
          "default": true,
          "description": "Auto-generate .mmd Mermaid diagram on save of .lx files"
        },
        "lx.diagram.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to lx binary (uses 'lx' on PATH if empty)"
        }
      }
    },
    "commands": [
      {
        "command": "lx.generateDiagram",
        "title": "lx: Generate Mermaid Diagram"
      }
    ]
  },
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "package": "pnpm build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "vite": "^8.0.0"
  }
}

-- Response synthesis: combines reasoning, results, and identity into output
-- Source: final stage — assembles everything into a coherent response for the human

use std/ai
use std/prompt
use std/md
use ../protocols {Response ReasoningChain Identity}
use ../traits {Synthesizer}

Agent ResponseSynth: Synthesizer = {
  synthesize = (msg) {
    style_config = style_for (msg.user_style ?? "concise")
    evidence = gather_evidence msg

    p = prompt.create ()
      | prompt.system "You are {msg.identity.name}, {msg.identity.role}. {style_config.system_note}"
      | prompt.section "Task" msg.task
      | prompt.section "Reasoning" (msg.reasoning.conclusion ?? to_str msg.reasoning)
      | prompt.section "Evidence" evidence
      | prompt.instruction style_config.instruction
      | prompt.constraint "Be direct. Lead with the answer. No filler."
      | prompt.constraint "If uncertain, say so with your confidence level."

    resp = ai.prompt (prompt.render p) ^

    sources = [
      ..msg.tool_results | map (r) to_str (r.tool ?? "tool")
    ] | uniq

    confidence = msg.reasoning.confidence ?? 0.5
    depth = msg.reasoning.thoughts ?? [] | len

    Response {
      content: resp.text
      confidence: confidence
      reasoning_depth: depth
      tools_used: msg.tool_results | map (r) to_str (r.tool ?? "") | filter (len > 0)
      sources: sources
      follow_up: suggest_follow_ups msg.task resp.text
    }
  }

  format = (msg) {
    response = msg.response
    doc = md.parse ""
      | md.heading 2 "Response"
      | md.paragraph response.content

    doc = response.sources | len > 0 ?
      doc | md.heading 3 "Sources" | md.list (response.sources)
      : doc

    doc = response.confidence < 0.5 ?
      doc | md.paragraph "(confidence: {response.confidence} — take with a grain of salt)"
      : doc

    md.render doc
  }

  compose_parts = (msg) {
    msg.sections
      | filter (s) len (s.content ?? "") > 0
      | fold (md.parse "") (doc s) doc | md.heading 2 s.title | md.paragraph s.content
      | md.render
  }
}

style_for = (style: Str) -> {system_note: Str  instruction: Str} {
  style ? {
    "terse" -> {system_note: "Be extremely brief."  instruction: "Answer in 1-3 sentences max."}
    "detailed" -> {system_note: "Be thorough and educational."  instruction: "Explain reasoning. Use examples."}
    "technical" -> {system_note: "Use precise technical language."  instruction: "Be specific. Include types, paths."}
    _ -> {system_note: "Be concise and direct."  instruction: "Answer clearly. Only necessary detail."}
  }
}

gather_evidence = (request: Any) -> Str {
  tool_evidence = request.tool_results
    | filter (r) r.success ?? true
    | map (r) "- [{to_str (r.tool ?? 'tool')}]: {to_str (r.output ?? '') | take 200}"

  reasoning_evidence = request.reasoning.thoughts ?? []
    | map (t) "- {(t.content ?? to_str t) | take 150}"

  [..tool_evidence  ..reasoning_evidence] | join "\n"
}

suggest_follow_ups = (task: Str  response: Str) -> [Str] {
  response_lower = response | lower
  suggestions := []

  response_lower | contains? "error" ? {
    suggestions <- [..suggestions  "want me to fix this error?"]
  } : ()
  response_lower | contains? "todo" ? {
    suggestions <- [..suggestions  "want me to implement the TODOs?"]
  } : ()
  task | lower | contains? "explain" ? {
    suggestions <- [..suggestions  "want me to go deeper on any part?"]
  } : ()

  suggestions | take 3
}

+main = () {
  agent.advertise {
    protocols: ["Response"]
    domains: ["synthesizer" "response" "formatting" "composition"]
    tools: ["ai"]
  }

  receive {
    synthesize -> ResponseSynth.synthesize
    format -> ResponseSynth.format
    compose -> ResponseSynth.compose_parts
    _ -> (msg) Err "unknown action: {msg.action ?? 'none'}"
  }
}

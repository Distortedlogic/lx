-- Message contracts for the Claude brain cognitive architecture
-- Source: models the information shapes flowing between cognitive subsystems

Trait Perception = {
  raw: Str
  intent: Str
  complexity: Str
  entities: [Str]
  domain: Str
  urgency: Str = "normal"
  requires_tools: Bool = false
  requires_agents: Bool = false
  ambiguity: Float = 0.0 where ambiguity >= 0.0 && ambiguity <= 1.0
}

Trait Thought = {
  id: Str
  content: Str
  kind: Str
  confidence: Float where confidence >= 0.0 && confidence <= 1.0
  evidence: [Str]
  depends_on: [Str]
  alternatives: [Str]
}

Trait ReasoningChain = {
  goal: Str
  thoughts: [Thought]
  conclusion: Str
  confidence: Float where confidence >= 0.0 && confidence <= 1.0
  strategy: Str
}

Trait ActionPlan = {
  goal: Str
  steps: [{id: Str  action: Str  tool: Str  args: Any  depends: [Str]}]
  estimated_cost: Float where estimated_cost >= 0.0
  risk: Str
  fallback: Str
}

Trait ActionResult = {
  step_id: Str
  success: Bool
  output: Any
  cost: Float where cost >= 0.0
  duration_ms: Int where duration_ms >= 0
}

Trait Reflection = {
  action: Str
  outcome: Str
  quality: Float where quality >= 0.0 && quality <= 1.0
  lesson: Str
  should_remember: Bool
  strategy_worked: Bool
}

Trait MemoryEntry = {
  content: Str
  domain: Str
  confidence: Float where confidence >= 0.0 && confidence <= 1.0
  source: Str
  tags: [Str]
}

Trait ToolRequest = {
  tool: Str
  args: Any
  reason: Str
  priority: Str = "normal"
  timeout_ms: Int = 30000 where timeout_ms > 0
}

Trait ToolResult = {
  tool: Str
  success: Bool
  output: Any
  tokens_used: Int where tokens_used >= 0
  duration_ms: Int where duration_ms >= 0
}

Trait CognitiveState = {
  turn: Int where turn >= 0
  context_pressure: Float where context_pressure >= 0.0 && context_pressure <= 1.0
  budget_status: Str
  active_goal: Str
  memory_load: Int where memory_load >= 0
  stuck_count: Int where stuck_count >= 0
  strategy: Str
}

Trait Response = {
  content: Str
  confidence: Float where confidence >= 0.0 && confidence <= 1.0
  reasoning_depth: Int where reasoning_depth >= 0
  tools_used: [Str]
  sources: [Str]
  follow_up: [Str]
}

Trait FeedbackSignal = {
  kind: Str
  score: Float where score >= 0.0 && score <= 1.0
  detail: Str
  source: Str
}

Trait Hypothesis = {
  claim: Str
  evidence_for: [Str]
  evidence_against: [Str]
  confidence: Float where confidence >= 0.0 && confidence <= 1.0
  testable: Bool
  test_action: Str
}

Trait ContextItem = {
  key: Str
  content: Str
  tokens: Int where tokens >= 0
  priority: Str
  pinned: Bool
  source: Str
}

Trait AgentTask = {
  id: Str
  specialist: Str
  instruction: Str
  context: Str
  constraints: [Str]
  timeout_ms: Int = 60000 where timeout_ms > 0
}

Trait AgentResult = {
  task_id: Str
  specialist: Str
  output: Any
  confidence: Float where confidence >= 0.0 && confidence <= 1.0
  tokens_used: Int where tokens_used >= 0
}

Trait QualityGrade = {
  score: Float where score >= 0.0 && score <= 100.0
  passed: Bool
  feedback: Str
  categories: [{name: Str  score: Float  weight: Float}]
  suggestions: [Str]
}

Trait Identity = {
  name: Str
  role: Str
  values: [Str]
  strengths: [Str]
  preferences: [{key: Str  value: Any}]
}

Trait Timestamped = {timestamp: Int where timestamp >= 0}

Trait PerceptionEvent = {..Timestamped  perception: Any}
Trait ReasoningEvent = {..Timestamped  chain: Any  strategy: Str}
Trait ExecutionEvent = {..Timestamped  results: [Any]  tool_count: Int where tool_count >= 0}
Trait ResponseEvent = {..Timestamped  response: Any  confidence: Float where confidence >= 0.0 && confidence <= 1.0}
Trait ReflectionEvent = {..Timestamped  reflection: Any  lesson: Str}

Trait CognitiveEvent =
  PerceptionEvent | ReasoningEvent | ExecutionEvent | ResponseEvent | ReflectionEvent

CognitivePhase = | Perceiving | Reasoning | Executing | Responding | Reflecting | Complete

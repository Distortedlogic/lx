-- Saga step definitions for the cognitive pipeline with real compensations
-- Source: each step has a do/undo pair — undo actually reverses side effects

use pkg/data/trace {TraceStore}
use std/agent {Handoff}
use pkg/core/handoff {as_context}
use ../contracts {Response}
use pkg/ai/perception : perceive
use pkg/ai/reasoning : reason
use pkg/data/tieredmem : mem
use ../lib/tools : tools
use ../lib/context_mgr : ctx_mgr

+build = (input: Str  state: Any  memory_store: Any  context_win: Any  workforce: Any  trace_session: Any  saga_ctx: Any) -> [Any] {
  [
    {
      id: "perceive"
      do: (prev) {
        p = perceive.perceive input [] ^
        trace_session.record {name: "perceive" input: input output: p.intent} ?? ()
        ctx_mgr.add_perception context_win p
        saga_ctx.set "perception_key" "perception_{p.intent}"
        p
      }
      undo: (result) {
        key = saga_ctx.get "perception_key" ?? "perception_unknown"
        ctx_mgr.clear_ephemeral context_win
        saga_ctx.set "perception_key" ""
        log.info "perception compensated — cleared context entry {key}"
      }
    }
    {
      id: "recall"
      do: (prev) {
        perception = prev.perceive
        recalled = mem.recall memory_store perception.raw perception.domain
        trace_session.record {name: "recall" input: perception.domain output: "found {len recalled}"} ?? ()
        saga_ctx.set "recall_count" (len recalled)
        recalled | take 10
      }
      undo: (result) {
        saga_ctx.set "recall_count" 0
      }
      depends: ["perceive"]
    }
    {
      id: "reason"
      do: (prev) {
        perception = prev.perceive
        memories = prev.recall | map (.content) | join "\n"

        handoff = Handoff {
          from: "perception"
          to: "reasoning"
          context: as_context {intent: perception.intent  domain: perception.domain  complexity: perception.complexity  memories}
          task: perception.raw
        }

        chain = reason.reason handoff.task handoff.context [] ^
        ctx_mgr.add_reasoning context_win chain
        saga_ctx.set "reasoning_key" "reasoning_{chain.goal | take 20}"
        trace_session.record {name: "reason" input: perception.intent output: chain.strategy} ?? ()
        chain
      }
      undo: (result) {
        key = saga_ctx.get "reasoning_key" ?? "reasoning_unknown"
        ctx_mgr.clear_ephemeral context_win
        saga_ctx.set "reasoning_key" ""
        log.info "reasoning compensated — cleared context entry {key}"
      }
      depends: ["perceive" "recall"]
    }
    {
      id: "execute"
      do: (prev) {
        perception = prev.perceive
        chain = prev.reason

        perception.requires_agents ? {
          dispatch = use ../agents/dispatcher
          dispatch.fan_out workforce [{
            id: "deep_analysis"
            specialist: "analyst"
            instruction: chain.conclusion
            context: perception.raw
            constraints: []
            timeout_ms: 30000
          }] ^
        } : perception.requires_tools ? {
          available = tools.available_tools ()
          selected = tools.select_tools chain.conclusion available ^
          selected | map (tool) {
            tools.execute_with_retry
              {tool: tool.name  args: chain.conclusion  reason: perception.intent  priority: "normal"  timeout_ms: 30000}
              state.breaker
              ? { Ok r -> r; Err e -> {tool: tool.name  success: false  output: e  tokens_used: 0  duration_ms: 0} }
          }
        } : []
      }
      undo: (result) log.info "execution compensated — tool results discarded"
      depends: ["reason"]
    }
    {
      id: "respond"
      do: (prev) {
        chain = prev.reason
        results = prev.execute
        successful = results | filter (r) r.success ?? true

        handoff = Handoff {
          from: "execution"
          to: "response"
          context: as_context {
            goal: chain.goal
            conclusion: chain.conclusion
            strategy: chain.strategy
            tool_count: successful | len
          }
          task: chain.goal
        }

        content = successful | len > 0 ? {
          tools.integrate_results successful handoff.task ^
        } : chain.conclusion

        Response {
          content
          confidence: chain.confidence
          reasoning_depth: chain.thoughts | len
          tools_used: successful | map (r) "{r.tool ?? ""}"
          sources: successful | map (r) "{r.tool ?? "reasoning"}" | uniq
          follow_up: []
        }
      }
      undo: (result) log.info "response compensated — not emitted"
      depends: ["reason" "execute"]
    }
  ]
}
